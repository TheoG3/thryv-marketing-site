---
import BaseLayout from './BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';

interface Props {
  slug: string;
  title: string;
  metaTitle: string;
  description: string;
  ogImage?: string;
  icon: string;
  pageLead: string;
  contactSubject: string;
  applicationCategory?: string;
}

const {
  slug,
  title,
  metaTitle,
  description,
  ogImage = 'https://thryvmarketingsolutions.com/og-free-tools.jpg',
  icon,
  pageLead,
  contactSubject,
  applicationCategory = 'BusinessApplication',
} = Astro.props;

const canonical = `https://thryvmarketingsolutions.com/free-tools/${slug}/`;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thryvmarketingsolutions.com/" },
        { "@type": "ListItem", "position": 2, "name": "Free Tools", "item": "https://thryvmarketingsolutions.com/free-tools/" },
        { "@type": "ListItem", "position": 3, "name": title, "item": canonical }
      ]
    },
    {
      "@type": "WebApplication",
      "name": title,
      "url": canonical,
      "description": description,
      "applicationCategory": applicationCategory,
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "provider": {
        "@type": "Organization",
        "name": "Thryv Marketing Solutions",
        "url": "https://thryvmarketingsolutions.com"
      }
    }
  ]
};
---

<BaseLayout
  title={metaTitle}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  schema={schema}
>

  <section class="tool-hero">
    <div class="container">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Home</a><span aria-hidden="true"> › </span>
        <a href="/free-tools/">Free Tools</a><span aria-hidden="true"> › </span>
        <span>{title}</span>
      </nav>
      <div class="hero-flex">
        <span class="hero-icon" aria-hidden="true">{icon}</span>
        <div>
          <span class="label">Free Tool</span>
          <h1>{title}</h1>
          <p class="lead">{pageLead}</p>
        </div>
      </div>
      <p class="tools-disclaimer">This tool produces an estimate based on industry averages and the inputs you provide. Results are illustrative and are not financial, legal, business, or tax advice. Actual results vary based on factors not captured here, including market conditions, competition, execution, and timing.</p>
    </div>
  </section>

  <section class="section tool-body-section">
    <div class="container">
      <div class="tool-wrap">
        <slot />
      </div>
      <p class="back-link"><a href="/free-tools/">← Back to all Free Tools</a></p>
    </div>
  </section>

  <section class="section contact-section">
    <div class="container">
      <div class="contact-split">
        <div>
          <span class="label">Next Step</span>
          <h2>Want Us to Fix What This Tool Found?</h2>
          <p class="lead" style="margin-bottom:24px;">Get a free professional audit from our team. We will dig into your Google Business Profile, reviews, SEO, and website and tell you exactly what to fix.</p>
        </div>
        <ContactForm title="Get Your Free Proposal" subject={contactSubject} />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .tool-hero {
    padding: 64px 0 48px;
    background: linear-gradient(135deg, var(--blue-deeper) 0%, var(--blue) 100%);
    color: var(--white);
  }
  .tool-hero .label { background: rgba(255,255,255,.15); color: var(--white); }
  .tool-hero h1 {
    font-size: clamp(28px, 4.5vw, 44px); font-weight: 800;
    line-height: 1.1; letter-spacing: -.02em; margin: 12px 0 12px;
    color: var(--white); max-width: 720px;
  }
  .tool-hero .lead { color: rgba(255,255,255,.85); max-width: 680px; }
  .hero-flex { display: flex; gap: 24px; align-items: flex-start; }
  .hero-icon { font-size: 72px; line-height: 1; flex-shrink: 0; }
  .tools-disclaimer {
    margin-top: 22px; padding: 12px 16px;
    background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.14);
    border-radius: 10px; color: rgba(255,255,255,.7);
    font-size: 12.5px; line-height: 1.55; max-width: 760px;
  }
  .breadcrumb { display: flex; align-items: center; gap: 4px; font-size: 13px; color: rgba(255,255,255,.6); margin-bottom: 24px; flex-wrap: wrap; }
  .breadcrumb a { color: rgba(255,255,255,.6); }
  .breadcrumb a:hover { color: var(--white); }

  .tool-body-section { background: var(--white); }
  .tool-wrap {
    max-width: 880px; margin: 0 auto;
    background: var(--white); border: 1.5px solid var(--border);
    border-radius: var(--radius-lg); padding: 40px;
    box-shadow: 0 6px 28px rgba(0,0,0,.04);
  }
  .back-link { max-width: 880px; margin: 24px auto 0; font-size: 14px; }
  .back-link a { color: var(--blue); font-weight: 700; text-decoration: none; }
  .back-link a:hover { text-decoration: underline; }

  .contact-section { background: var(--light); }
  .contact-split { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }

  @media (max-width: 860px) {
    .hero-icon { font-size: 56px; }
    .tool-wrap { padding: 24px; }
    .contact-split { grid-template-columns: 1fr; gap: 40px; }
  }
  @media (max-width: 560px) {
    .hero-flex { flex-direction: column; gap: 12px; }
    .hero-icon { font-size: 48px; }
  }

  /* Shared calculator styles available to every tool page slot */
  :global(.calc-grid) { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: start; }
  :global(.calc-field) { margin-bottom: 16px; }
  :global(.calc-field label) { display: block; font-size: 13px; font-weight: 700; color: var(--dark); margin-bottom: 8px; }
  :global(.calc-field input[type="number"]),
  :global(.calc-field input[type="text"]) {
    width: 100%; border: 1.5px solid var(--border); border-radius: 10px;
    padding: 11px 14px; font-size: 14px; color: var(--dark);
    background: var(--white); font-family: var(--font); outline: none;
  }
  :global(.calc-field input:focus),
  :global(.calc-field select:focus) { border-color: var(--blue); }
  :global(.input-prefix) { display: flex; align-items: center; border: 1.5px solid var(--border); border-radius: 10px; background: var(--white); overflow: hidden; }
  :global(.input-prefix span) { padding: 11px 14px; background: var(--light); color: var(--gray); font-weight: 700; font-size: 14px; border-right: 1.5px solid var(--border); }
  :global(.input-prefix input) { flex: 1; border: none; outline: none; padding: 11px 14px; font-size: 14px; color: var(--dark); background: var(--white); font-family: var(--font); }
  :global(.calc-field select) { width: 100%; border: 1.5px solid var(--border); border-radius: 10px; padding: 11px 14px; font-size: 14px; color: var(--dark); background: var(--white); font-family: var(--font); outline: none; }
  :global(.calc-result) { background: var(--light); border-radius: var(--radius-lg); padding: 32px; text-align: center; border: 1.5px solid var(--border); }
  :global(.result-label) { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: .12em; color: var(--gray); margin-bottom: 8px; }
  :global(.result-amount) { font-size: 56px; font-weight: 800; color: var(--blue); letter-spacing: -.03em; line-height: 1; margin-bottom: 12px; }
  :global(.result-note) { font-size: 14px; line-height: 1.6; color: var(--gray); }

  :global(.audit-questions) { display: flex; flex-direction: column; gap: 10px; padding: 0; list-style: none; margin: 0; }
  :global(.audit-q) { display: flex; justify-content: space-between; align-items: center; padding: 14px 18px; background: var(--light); border: 1.5px solid var(--border); border-radius: var(--radius); gap: 16px; }
  :global(.q-text) { font-size: 14px; color: var(--dark); font-weight: 500; flex: 1; }
  :global(.q-opts) { display: flex; gap: 20px; flex-shrink: 0; }
  :global(.q-opts label) { display: flex; align-items: center; gap: 6px; font-size: 14px; font-weight: 600; color: var(--gray); cursor: pointer; }
  :global(.q-opts input[type="radio"]) { accent-color: var(--blue); }
  :global(.audit-result) { text-align: center; padding: 8px 0; }
  :global(.score-display) { display: flex; align-items: baseline; justify-content: center; gap: 4px; margin-bottom: 12px; }
  :global(.score-num) { font-size: 88px; font-weight: 800; color: var(--blue); line-height: 1; }
  :global(.score-denom) { font-size: 32px; color: var(--gray); }
  :global(.score-msg) { font-size: 17px; font-weight: 700; color: var(--dark); margin-bottom: 4px; }
  :global(.btn-retake) { display: block; margin: 12px auto 0; background: none; border: none; color: var(--blue); font-size: 13px; font-weight: 700; cursor: pointer; text-decoration: underline; font-family: var(--font); }

  @media (max-width: 720px) {
    :global(.calc-grid) { grid-template-columns: 1fr; gap: 24px; }
  }
  @media (max-width: 560px) {
    :global(.audit-q) { flex-direction: column; align-items: flex-start; gap: 10px; }
  }
</style>
