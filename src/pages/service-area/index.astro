---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { neighborhoods, verticals } from '../../data/ecosystem.ts';

// Filter to Miami neighborhoods only (currently all are Miami; this stays correct as we add cities)
const miamiNeighborhoods = neighborhoods.filter((n) => n.citySlug === 'miami');

const BASE = 'https://thryvmarketingsolutions.com';
const canonical = `${BASE}/service-area/`;

// Each card links to the highest-priority page for that neighborhood.
// Today that's the med-spa SEO page (since /medspas/seo/miami/miami-beach/ has the only neighborhood-override).
// As more vertical/service combinations get neighborhood overrides, we can promote them here.
function primaryLinkFor(slug: string) {
  return `/medspas/seo/miami/${slug}/`;
}

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${BASE}/` },
      { "@type": "ListItem", "position": 2, "name": "Service Area", "item": canonical },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": canonical,
    "url": canonical,
    "name": "Service Area — Miami Neighborhoods",
    "description": "Thryv Marketing Solutions provides local SEO, Google Ads, and reputation management across 12 Miami neighborhoods including Brickell, Coral Gables, Miami Beach, Doral, Wynwood, and Aventura.",
    "isPartOf": { "@id": `${BASE}/#website` },
    "about": { "@id": `${BASE}/#business` },
    "mainEntity": {
      "@type": "ItemList",
      "numberOfItems": miamiNeighborhoods.length,
      "itemListElement": miamiNeighborhoods.map((n, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": `${n.name}, Miami, FL`,
        "item": `${BASE}${primaryLinkFor(n.slug)}`,
      })),
    },
  },
];
---

<BaseLayout
  title="Service Area | Miami Marketing Agency — 12 Neighborhoods"
  description="Thryv Marketing Solutions covers 12 Miami neighborhoods — Brickell, Coral Gables, Miami Beach, Doral, Wynwood, Aventura, Coconut Grove, and more. Local SEO, Google Ads, GBP management."
  canonical={canonical}
  schema={schema}
>

  <section class="sa-hero">
    <div class="container">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Home</a><span> › </span><span>Service Area</span>
      </nav>
      <span class="post-label">Miami-Dade Coverage</span>
      <h1>Where We Work — 12 Miami Neighborhoods, One Marketing Team</h1>
      <p class="lead">
        Thryv Marketing Solutions runs local SEO, Google Business Profile management, and paid
        media campaigns across Miami-Dade. Every neighborhood below has its own local market dynamics —
        we build the page, the ad, and the listing to match.
      </p>
      <div class="meta-row">
        <span>{miamiNeighborhoods.length} neighborhoods</span>
        <span>{verticals.length} verticals served</span>
        <span>Miami-based team</span>
      </div>
    </div>
  </section>

  <section class="sa-grid-section">
    <div class="container">
      <h2>Miami Neighborhoods We Cover</h2>
      <p class="section-lead">
        Click into any neighborhood to see how we approach med-spa marketing in that specific market. As we build out
        more service-by-neighborhood pages, this hub becomes your map.
      </p>

      <div class="sa-grid">
        {miamiNeighborhoods.map((n) => (
          <a href={primaryLinkFor(n.slug)} class="sa-card" aria-label={`Marketing services in ${n.name}, Miami`}>
            <div class="sa-card-head">
              <h3>{n.name}</h3>
              <span class="sa-pin" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
            </div>
            <p class="sa-desc">{n.desc}</p>
            <span class="sa-cta">See {n.name} marketing services <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="sa-map-section">
    <div class="container">
      <h2>Coverage Map</h2>
      <p class="section-lead">
        We cover three South Florida counties end to end. <strong>Miami-Dade, Broward, and Palm Beach</strong>, outlined in red below.
        Office in Brickell. On-site visits across the region by appointment.
      </p>
      <div class="sa-map-wrap">
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
        <div id="sa-map" style="width:100%;height:480px;border-radius:var(--radius-lg);overflow:hidden;border:1px solid var(--border);"></div>
        <p class="sa-map-caption">Red outline = our service area. Markers = cities and neighborhoods we publish dedicated pages for.</p>
      </div>
    </div>
  </section>

  <script
    is:inline
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
  ></script>
  <script is:inline>
    (function () {
      function init() {
        if (typeof L === 'undefined') return setTimeout(init, 200);
        var map = L.map('sa-map', { scrollWheelZoom: false, attributionControl: true }).setView([26.3, -80.3], 9);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
          maxZoom: 18,
        }).addTo(map);

        // Approximate county outlines for visual reference. Simplified for low payload.
        // Source: Florida county boundary references, manually simplified to under 25 points each.
        var counties = [
          {
            name: 'Palm Beach County',
            coords: [
              [26.967, -80.880], [26.967, -80.030], [26.317, -80.030],
              [26.317, -80.180], [26.330, -80.880], [26.967, -80.880]
            ]
          },
          {
            name: 'Broward County',
            coords: [
              [26.330, -80.880], [26.330, -80.075], [25.975, -80.110],
              [25.975, -80.880], [26.330, -80.880]
            ]
          },
          {
            name: 'Miami-Dade County',
            coords: [
              [25.975, -80.880], [25.975, -80.110], [25.345, -80.110],
              [25.180, -80.530], [25.180, -80.880], [25.975, -80.880]
            ]
          }
        ];

        counties.forEach(function (c) {
          L.polygon(c.coords, {
            color: '#E63946',
            weight: 3,
            opacity: 0.95,
            fill: false,
          }).addTo(map).bindTooltip(c.name, { permanent: false, direction: 'center', className: 'sa-county-tip' });
        });

        // City markers (the 7 cities we publish dedicated city pages for)
        var cities = [
          { name: 'Miami',           lat: 25.7617, lng: -80.1918 },
          { name: 'Fort Lauderdale', lat: 26.1224, lng: -80.1373 },
          { name: 'Hollywood',       lat: 26.0112, lng: -80.1495 },
          { name: 'Pompano Beach',   lat: 26.2379, lng: -80.1248 },
          { name: 'Boca Raton',      lat: 26.3683, lng: -80.1289 },
          { name: 'Delray Beach',    lat: 26.4615, lng: -80.0728 },
          { name: 'West Palm Beach', lat: 26.7153, lng: -80.0534 }
        ];
        var cityIcon = L.divIcon({
          className: 'sa-city-marker',
          html: '<span class="sa-city-dot"></span>',
          iconSize: [14, 14],
          iconAnchor: [7, 7],
        });
        cities.forEach(function (city) {
          L.marker([city.lat, city.lng], { icon: cityIcon }).addTo(map).bindPopup('<strong>' + city.name + '</strong>');
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>

<style is:global>
  .sa-map-caption { font-size: 12.5px; color: var(--gray); margin-top: 10px; text-align: center; font-style: italic; }
  .sa-city-marker .sa-city-dot { display: block; width: 14px; height: 14px; background: var(--blue); border: 2.5px solid #fff; border-radius: 50%; box-shadow: 0 2px 6px rgba(0,0,0,.35); }
  .sa-county-tip { background: rgba(230,57,70,.95); color: #fff; border: 0; border-radius: 6px; padding: 4px 10px; font-weight: 700; font-size: 12px; box-shadow: 0 4px 12px rgba(0,0,0,.18); }
  .sa-county-tip::before { border-top-color: rgba(230,57,70,.95) !important; }
  .leaflet-container { font-family: inherit; }
</style>

  <section class="sa-cta">
    <div class="container">
      <div class="sa-cta-card">
        <h2>Not Sure Which Neighborhood Page Fits Your Business?</h2>
        <p>If your med spa, dental practice, or service business serves multiple Miami neighborhoods, we'll build a custom local SEO plan that targets all of them. Tell us your zip codes — we'll come back with a free proposal.</p>
        <div class="cta-buttons">
          <a href="/contact/" class="btn btn-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            Book a Free Proposal
          </a>
          <a href="/medspas/" class="btn btn-blue">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            See Med Spa Services
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .sa-hero {
    background: linear-gradient(135deg, #0A2E6E 0%, var(--blue) 100%);
    padding: 56px 0 64px; color: var(--white);
  }
  .breadcrumb { display: flex; align-items: center; gap: 4px; font-size: 13px; color: rgba(255,255,255,.55); margin-bottom: 20px; flex-wrap: wrap; }
  .breadcrumb a { color: rgba(255,255,255,.55); }
  .breadcrumb a:hover { color: var(--white); }
  .post-label {
    display: inline-block; font-size: 11px; font-weight: 800; letter-spacing: .12em;
    text-transform: uppercase; background: rgba(255,255,255,.15);
    border-radius: 100px; padding: 4px 12px; margin-bottom: 16px; color: var(--white);
  }
  .sa-hero h1 {
    font-size: clamp(28px, 4.5vw, 44px); font-weight: 800; line-height: 1.15;
    letter-spacing: -0.02em; margin-bottom: 16px; max-width: 760px; color: var(--white);
  }
  .sa-hero .lead { font-size: 17px; line-height: 1.7; color: rgba(255,255,255,.8); margin-bottom: 24px; max-width: 700px; }
  .meta-row { display: flex; gap: 24px; font-size: 13px; color: rgba(255,255,255,.6); flex-wrap: wrap; }

  .sa-grid-section { padding: 72px 0 56px; background: var(--white); }
  .sa-grid-section h2 { font-size: clamp(24px, 3vw, 30px); font-weight: 800; color: var(--dark); margin: 0 0 12px; letter-spacing: -0.01em; }
  .section-lead { font-size: 16px; line-height: 1.65; color: var(--gray); max-width: 720px; margin: 0 0 32px; }

  .sa-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px;
  }
  .sa-card {
    background: var(--white); border: 1.5px solid var(--border, #e2e8f0);
    border-radius: var(--radius-lg, 14px); padding: 20px 22px;
    text-decoration: none; color: inherit;
    display: flex; flex-direction: column; gap: 12px;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }
  .sa-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 30px -14px rgba(10, 46, 110, 0.22);
    border-color: rgba(10, 46, 110, 0.18); text-decoration: none;
  }
  .sa-card-head { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .sa-card h3 { font-size: 19px; font-weight: 800; color: var(--dark); margin: 0; letter-spacing: -0.01em; }
  .sa-pin { color: var(--orange); display: inline-flex; }
  .sa-desc { font-size: 14px; line-height: 1.55; color: var(--gray); margin: 0; flex: 1; }
  .sa-cta { font-size: 13px; font-weight: 700; color: var(--blue); margin-top: auto; }

  .sa-map-section { padding: 56px 0; background: var(--light, #f8fafc); border-top: 1.5px solid var(--border, #e2e8f0); }
  .sa-map-section h2 { font-size: clamp(24px, 3vw, 30px); font-weight: 800; color: var(--dark); margin: 0 0 12px; letter-spacing: -0.01em; }
  .sa-map-wrap {
    border-radius: var(--radius-lg, 14px); overflow: hidden;
    box-shadow: 0 10px 30px -12px rgba(10, 46, 110, 0.18);
    border: 1.5px solid var(--border, #e2e8f0); background: var(--white);
  }
  .sa-map-wrap iframe { display: block; }

  .sa-cta { padding: 72px 0; background: var(--white); }
  .sa-cta-card {
    background: var(--light, #f8fafc); border: 1.5px solid var(--border, #e2e8f0);
    border-radius: var(--radius-lg, 14px); padding: 40px;
    max-width: 920px; margin: 0 auto;
  }
  .sa-cta-card h2 { font-size: 24px; font-weight: 800; color: var(--dark); margin: 0 0 12px; }
  .sa-cta-card p { font-size: 15px; line-height: 1.7; color: var(--gray); margin: 0 0 24px; }
  .cta-buttons { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; gap: 8px; padding: 12px 22px;
    border-radius: 8px; font-size: 14px; font-weight: 700; text-decoration: none; transition: opacity .2s;
    color: var(--white);
  }
  .btn:hover { opacity: .9; text-decoration: none; color: var(--white); }
  .btn-primary { background: var(--orange); }
  .btn-blue { background: var(--blue); }

  @media (max-width: 900px) {
    .sa-grid { grid-template-columns: repeat(2, 1fr); }
    .sa-cta-card { padding: 28px 22px; }
  }
  @media (max-width: 600px) {
    .sa-grid { grid-template-columns: 1fr; }
    .sa-hero { padding: 40px 0 48px; }
    .cta-buttons { flex-direction: column; }
    .btn { justify-content: center; width: 100%; }
  }
</style>
