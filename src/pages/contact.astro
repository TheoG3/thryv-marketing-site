---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How quickly will you respond?",
        "acceptedAnswer": { "@type": "Answer", "text": "We respond to all audit requests within 24 hours, Monday through Friday." }
      },
      {
        "@type": "Question",
        "name": "Is the audit really free?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. No credit card, no obligation. We review your online presence and share exactly what we find." }
      },
      {
        "@type": "Question",
        "name": "What happens after the audit?",
        "acceptedAnswer": { "@type": "Answer", "text": "We walk you through the findings and recommend which services would have the biggest impact for your business. You decide if you want to move forward." }
      }
    ]
  }
];
---

<BaseLayout
  title="Contact Thryv Marketing Solutions | Free Marketing Audit"
  description="Get a free marketing audit for your Miami business. We review your Google Business Profile, reviews, SEO, and website. Respond within 24 hours."
  canonical="https://thryvmarketingsolutions.com/contact/"
  ogImage="https://thryvmarketingsolutions.com/og-contact.jpg"
  schema={schema}
>

  <section class="contact-hero">
    <div class="container">
      <span class="label">Let's Talk</span>
      <h1>Get Your Free Marketing Audit</h1>
      <p class="lead">Tell us about your business. We will take a look at your online presence and tell you exactly what is and is not working, no charge, no obligation.</p>
    </div>
  </section>

  <section class="section contact-main">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info reveal">
          <h2>What the Audit Covers</h2>
          <ul class="audit-list">
            <li>
              <div class="audit-icon">📍</div>
              <div>
                <strong>Google Business Profile</strong>
                <p>We check your profile for completeness, keyword targeting, and missed opportunities.</p>
              </div>
            </li>
            <li>
              <div class="audit-icon">⭐</div>
              <div>
                <strong>Review Score and Response Rate</strong>
                <p>How your rating compares to local competitors, and whether you are responding to reviews.</p>
              </div>
            </li>
            <li>
              <div class="audit-icon">🔍</div>
              <div>
                <strong>Local Keyword Rankings</strong>
                <p>A snapshot of where you rank for the searches your customers actually use.</p>
              </div>
            </li>
            <li>
              <div class="audit-icon">💻</div>
              <div>
                <strong>Website Speed and Mobile</strong>
                <p>We run your site through Google's PageSpeed tools and flag what is slowing you down.</p>
              </div>
            </li>
          </ul>

          <div class="contact-direct">
            <h3>Prefer to reach out directly?</h3>
            <a href="mailto:hello@thryvmarketingsolutions.com" class="contact-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              hello@thryvmarketingsolutions.com
            </a>
            <p class="bilingual">Hablamos Espa&ntilde;ol</p>
          </div>
        </div>

        <div class="reveal">
          <ContactForm title="Request Your Free Audit" subject="New Contact Page Inquiry | Thryv" />
        </div>
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container">
      <div class="section-head center">
        <h2>Common Questions</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal"><summary>How quickly will you respond?</summary><p>We respond to all audit requests within 24 hours, Monday through Friday.</p></details>
        <details class="faq-item reveal"><summary>Is the audit really free?</summary><p>Yes. No credit card, no obligation. We review your online presence and share exactly what we find.</p></details>
        <details class="faq-item reveal"><summary>What happens after the audit?</summary><p>We walk you through the findings and recommend which services would have the biggest impact for your business. You decide if you want to move forward.</p></details>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .contact-hero { padding: 80px 0 64px; background: linear-gradient(135deg, var(--blue-deeper) 0%, var(--blue) 100%); color: var(--white); }
  .contact-hero .label { background: rgba(255,255,255,.15); color: var(--white); }
  .contact-hero h1 { font-size: clamp(32px, 5vw, 52px); font-weight: 800; line-height: 1.1; letter-spacing: -.02em; margin: 16px 0; color: var(--white); }
  .contact-hero .lead { color: rgba(255,255,255,.8); max-width: 540px; }

  .contact-main { background: var(--light); }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }

  .contact-info h2 { font-size: 26px; font-weight: 800; margin-bottom: 32px; }
  .audit-list { display: flex; flex-direction: column; gap: 24px; list-style: none; }
  .audit-list li { display: flex; gap: 16px; align-items: flex-start; }
  .audit-icon { font-size: 28px; min-width: 40px; }
  .audit-list strong { display: block; font-size: 15px; font-weight: 700; color: var(--dark); margin-bottom: 4px; }
  .audit-list p { font-size: 14px; line-height: 1.6; color: var(--gray); margin: 0; }

  .contact-direct { margin-top: 40px; padding-top: 32px; border-top: 1.5px solid var(--border); }
  .contact-direct h3 { font-size: 16px; font-weight: 700; margin-bottom: 12px; }
  .contact-link { display: inline-flex; align-items: center; gap: 10px; font-size: 15px; font-weight: 700; color: var(--blue); transition: opacity .2s; }
  .contact-link:hover { opacity: .7; }
  .bilingual { margin-top: 12px; font-size: 13px; color: var(--gray); font-style: italic; }

  .faq-section { background: var(--white); }
  .faq-list { max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; gap: 12px; }
  .faq-item { border: 1.5px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .faq-item summary { padding: 18px 24px; font-size: 16px; font-weight: 700; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; font-size: 20px; font-weight: 400; color: var(--blue); transition: transform .2s; }
  .faq-item[open] summary::after { transform: rotate(45deg); }
  .faq-item p { padding: 0 24px 18px; font-size: 15px; line-height: 1.7; color: var(--gray); margin: 0; }

  .reveal { opacity: 0; transform: translateY(24px); transition: opacity .55s ease, transform .55s ease; }
  .reveal.visible { opacity: 1; transform: none; }

  @media (max-width: 860px) {
    .contact-grid { grid-template-columns: 1fr; gap: 48px; }
  }
</style>

<script>
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>
