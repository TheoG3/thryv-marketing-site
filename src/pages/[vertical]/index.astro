---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import ToolCallout from '../../components/ToolCallout.astro';
import { verticals, services, getServiceDef, getVerticalOverride } from '../../data/ecosystem.ts';
import type { Vertical, ServiceSlug } from '../../data/ecosystem.ts';
import { categoryMeta, getPostsByCategory, getRealCategories } from '../../data/blog-posts.ts';
import { getProfessionVocabulary } from '../../data/profession-vocabulary.ts';

// Vertical slug -> blog category label. Closes the topic-cluster loop:
// vertical page <-> blog category page. Only verticals whose mapped category
// has a real page (>=3 posts) will render the Insights section below; others
// silently skip until content fills in.
const verticalToBlogCategory: Record<string, string> = {
  medspas: 'Med Spa Marketing',
  // Add other verticals as their blog categories cross the 3-post threshold:
  // dentists: 'Dental Marketing',
  // contractors: 'Contractor Marketing',
};

const realCategoryLabels = new Set(getRealCategories(3).map((c) => c.label));

export async function getStaticPaths() {
  return verticals.map(v => ({
    params: { vertical: v.slug },
    props: { vertical: v },
  }));
}

interface Props { vertical: Vertical; }
const { vertical: v } = Astro.props;

const override = getVerticalOverride(v.slug);
const pv = getProfessionVocabulary(v.slug);

const BASE = 'https://thryvmarketingsolutions.com';
const canonical = `${BASE}/${v.slug}/`;

const titleMap: Record<string, string> = {
  contractors: 'Contractor Marketing Miami | Thryv Marketing Solutions',
  'cleaning-services': 'Cleaning Company Marketing Miami | Thryv',
  landscaping: 'Landscaping Marketing Miami | Thryv Marketing Solutions',
  'moving-companies': 'Moving Company Marketing Miami | Thryv',
  dentists: 'Dental Office Marketing Miami | Thryv Marketing Solutions',
  medspas: 'Med Spa Marketing Agency Miami | Medical Spa SEO',
  'yacht-services': 'Yacht Service Marketing Miami | Thryv',
  'real-estate-agents': 'Real Estate Agent Marketing Miami | Thryv',
  'immigration-lawyers': 'Immigration Lawyer Marketing Miami | Thryv',
  'beauty-salons': 'Beauty Salon Marketing Miami | Thryv Marketing Solutions',
};

const descMap: Record<string, string> = {
  contractors: 'Marketing for contractors in Miami. Google Business Profile, SEO, Google Ads, and reputation management. Get found when homeowners search. Free audit.',
  'cleaning-services': 'Marketing for Miami cleaning companies. GBP, SEO, and review management to attract higher-value residential and commercial clients. Free audit.',
  landscaping: 'Marketing for Miami landscapers. Google Business Profile, SEO, and Google Ads to keep your calendar full year-round. Miami-based. Free audit.',
  'moving-companies': 'Marketing for Miami moving companies. Capture high-intent moving searches with GBP, SEO, and Google Ads. Build your review profile. Free audit.',
  dentists: 'Marketing for Miami dental offices. Attract more cosmetic and private-pay patients with targeted SEO, Google Ads, and reputation management. Free audit.',
  medspas: 'Med spa marketing agency in Miami. Medical spa SEO, social ads, GBP, and reputation management to keep treatment rooms booked. Founder-led. Free audit.',
  'yacht-services': 'Marketing for Miami yacht services. SEO, GBP, and Google Ads to reach yacht owners before they call anyone else. Miami marine market. Free audit.',
  'real-estate-agents': 'Marketing for Miami real estate agents. Own your target neighborhood in search with SEO, GBP, and social ads. Stop paying portal fees. Free audit.',
  'immigration-lawyers': 'Marketing for Miami immigration lawyers. Bilingual SEO, GBP, and Google Ads to turn urgent searches into consultations. Miami-based. Free audit.',
  'beauty-salons': 'Marketing for Miami beauty salons. GBP, SEO, and Instagram ads to keep your chairs booked. Build your review profile in your neighborhood. Free audit.',
};

const pageTitle = override?.pageTitle ?? titleMap[v.slug] ?? `${v.name} Marketing Miami | Thryv Marketing Solutions`;
const pageDesc = override?.pageDesc ?? descMap[v.slug] ?? `Marketing for ${v.name.toLowerCase()} in Miami. Google Business Profile, SEO, Google Ads, and reputation management. Free audit.`;

const h1 = override?.h1 ?? v.pillarHeadline;
const lead = override?.lead ?? v.pillarLead;
const marketHeadline = override?.marketHeadline;
const marketBody = override?.marketBody;
const overrideSignals = override?.signals;
const faqs = override?.faqs ?? v.faqs;

// Determine whether this vertical has a matching blog category with a real page.
// If yes, fetch the 3 most recent posts to render in the Marketing Insights section.
const mappedCategory = verticalToBlogCategory[v.slug];
const showInsights = !!(mappedCategory && realCategoryLabels.has(mappedCategory));
const insightsCategory = showInsights ? categoryMeta[mappedCategory] : null;
const insightsPosts = showInsights ? getPostsByCategory(mappedCategory).slice(0, 3) : [];

const verticalToolMap: Record<string, { href: string; icon: string; title: string; desc: string }> = {
  medspas: {
    href: '/free-tools/med-spa-marketing-roi-calculator/',
    icon: '💉',
    title: 'See ROI on your Miami med spa marketing budget',
    desc: 'Plug in your treatment price, marketing spend, and patient LTV. Get new-patient projections, CAC, year-one revenue, and 5-year value.',
  },
  dentists: {
    href: '/free-tools/missed-call-revenue-calculator/',
    icon: '📞',
    title: 'What unanswered calls cost your practice',
    desc: 'Most dental offices answer under 40% of new-patient calls. See exactly what each missed call is costing your monthly revenue.',
  },
  contractors: {
    href: '/free-tools/missed-call-revenue-calculator/',
    icon: '📞',
    title: 'What missed calls cost a contractor',
    desc: 'Homeowners call the next contractor when nobody answers. See exactly what each unanswered call is costing you each month.',
  },
  'junk-removal': {
    href: '/free-tools/missed-call-revenue-calculator/',
    icon: '📞',
    title: 'What unanswered junk-removal calls cost you',
    desc: 'Same-day jobs are won by whoever picks up first. See exactly what each missed call is costing your monthly revenue.',
  },
  'cleaning-services': {
    href: '/free-tools/missed-call-revenue-calculator/',
    icon: '📞',
    title: 'What unanswered cleaning inquiries cost',
    desc: 'High-LTV recurring clients go to whoever answers first. See exactly what each missed call is costing you each month.',
  },
  landscaping: {
    href: '/free-tools/missed-call-revenue-calculator/',
    icon: '📞',
    title: 'What missed calls cost a landscaper',
    desc: 'Seasonal demand spikes mean missed calls compound fast. See exactly what each unanswered call is costing your monthly revenue.',
  },
  'moving-companies': {
    href: '/free-tools/missed-call-revenue-calculator/',
    icon: '📞',
    title: 'What missed calls cost a mover',
    desc: 'Moves get booked the same day or lost forever. See exactly what each unanswered call is costing you each month.',
  },
  'yacht-services': {
    href: '/free-tools/missed-call-revenue-calculator/',
    icon: '📞',
    title: 'What unanswered yacht-service calls cost',
    desc: 'High-ticket marine jobs are won on the first ring. See exactly what each missed call is costing your monthly revenue.',
  },
  'beauty-salons': {
    href: '/free-tools/review-revenue-calculator/',
    icon: '💰',
    title: 'What a higher Google rating could earn your salon',
    desc: 'Plug in your monthly revenue and current star rating. See the revenue gap between where you are and a 4.8 rating.',
  },
  'real-estate-agents': {
    href: '/free-tools/review-revenue-calculator/',
    icon: '💰',
    title: 'What a higher Google rating could earn your business',
    desc: 'Plug in your monthly revenue and current star rating. See the revenue gap between where you are and a 4.8 rating.',
  },
  'immigration-lawyers': {
    href: '/free-tools/local-seo-score-checker/',
    icon: '🔍',
    title: 'Score your local SEO foundation in 60 seconds',
    desc: 'Urgent searches like "immigration lawyer near me" go to the top 3 results. See whether your site is positioned to rank.',
  },
};
const tool = verticalToolMap[v.slug] ?? {
  href: '/free-tools/',
  icon: '🧰',
  title: 'See all seven free marketing tools',
  desc: 'Review revenue, missed call revenue, GBP audit, local SEO score, Google Ads budget, review gap, med spa ROI. Pick the one that matches your question.',
};

const svcIcons: Record<ServiceSlug, string> = {
  'google-business-profile': '<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/>',
  seo: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>',
  'google-ads': '<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>',
  'reputation-management': '<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>',
  'website-design': '<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
  'social-media-ads': '<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>',
};

// Industry-specific schema mapping. Augments the sitewide LocalBusiness signal
// with the vertical-specific Schema.org type Google uses for E-E-A-T / YMYL.
type IndustrySchemaSpec = {
  type: string | string[];
  category: string;       // human-readable category for the audience field
  ymyl?: boolean;         // your-money-your-life industries get added trust treatment
  medicalSpecialty?: string;
};
const industrySchemaBySlug: Record<string, IndustrySchemaSpec> = {
  'contractors':         { type: 'HomeAndConstructionBusiness', category: 'general contractors and home builders' },
  'cleaning-services':   { type: 'LocalBusiness',               category: 'residential and commercial cleaning services' },
  'landscaping':         { type: 'LocalBusiness',               category: 'landscaping, lawn care, and outdoor design services' },
  'moving-companies':    { type: 'MovingCompany',               category: 'residential and commercial moving and relocation' },
  'dentists':            { type: ['Dentist', 'MedicalBusiness'], category: 'dental practices', ymyl: true, medicalSpecialty: 'Dentistry' },
  'medspas':             { type: ['MedicalBusiness', 'HealthAndBeautyBusiness'], category: 'medical spas and aesthetic clinics', ymyl: true, medicalSpecialty: 'CosmeticDermatology' },
  'yacht-services':      { type: 'LocalBusiness',               category: 'yacht maintenance, charter, and detailing services' },
  'real-estate-agents':  { type: 'RealEstateAgent',             category: 'residential and luxury real estate agents', ymyl: true },
  'immigration-lawyers': { type: ['Attorney', 'LegalService'],  category: 'immigration law firms and attorneys', ymyl: true },
  'beauty-salons':       { type: ['BeautySalon', 'HealthAndBeautyBusiness'], category: 'hair salons, nail salons, and beauty studios' },
  'junk-removal':        { type: 'LocalBusiness',               category: 'junk removal, hauling, and debris cleanup services' },
  'hvac':                { type: ['HVACBusiness', 'HomeAndConstructionBusiness'], category: 'HVAC contractors and air-conditioning service companies' },
  'roofing':             { type: ['RoofingContractor', 'HomeAndConstructionBusiness'], category: 'roofing contractors and roof repair and replacement specialists' },
  'restoration':         { type: 'LocalBusiness',               category: 'water damage restoration, mold remediation, fire damage, and biohazard cleanup specialists', ymyl: true },
  'plumber':             { type: ['Plumber', 'HomeAndConstructionBusiness'], category: 'plumbing contractors and emergency plumbing service companies' },
  'electrician':         { type: ['Electrician', 'HomeAndConstructionBusiness'], category: 'electrical contractors and licensed electricians' },
  'pressure-washing':    { type: 'LocalBusiness', category: 'pressure washing, power washing, paver sealing, soft wash roof cleaning, and exterior cleaning services' },
};
const industrySpec = industrySchemaBySlug[v.slug] ?? { type: 'LocalBusiness', category: v.name.toLowerCase() };

const industrySchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": industrySpec.type,
  "@id": `${canonical}#industry-service`,
  "name": `Thryv Marketing Solutions for ${v.name}`,
  "url": canonical,
  "description": `${v.pillarLead} Specialist marketing services for ${industrySpec.category} across Miami and South Florida.`,
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": "Miami-Dade County, Broward County, and Palm Beach County, Florida",
  },
  "provider": { "@id": `${BASE}/#business` },
  "audience": {
    "@type": "BusinessAudience",
    "audienceType": industrySpec.category,
  },
};
if (industrySpec.medicalSpecialty) {
  industrySchema.medicalSpecialty = industrySpec.medicalSpecialty;
}
if (industrySpec.ymyl) {
  // YMYL trust signal: explicit publishing principles + knowsAbout for E-E-A-T.
  industrySchema.publishingPrinciples = `${BASE}/about/`;
  industrySchema.knowsAbout = industrySpec.category;
}

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${BASE}/` },
      { "@type": "ListItem", "position": 2, "name": v.name, "item": canonical },
    ],
  },
  industrySchema,
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  },
];
---

<BaseLayout title={pageTitle} description={pageDesc} canonical={canonical} schema={schema}>

  <section class="v-hero">
    <div class="container">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Home</a><span> › </span><span>{v.name}</span>
      </nav>
      <span class="label">Who We Serve</span>
      <h1>{h1}</h1>
      <p class="lead">{lead}</p>
      <div class="hero-ctas">
        <a href="#contact" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Get a Free Proposal
        </a>
        <a href="/contact/" class="btn btn-outline-white">Contact Us</a>
      </div>
    </div>
  </section>

  {pv && (
    <section class="section pv-section">
      <div class="container">
        <div class="section-head">
          <span class="label">Researched, Not Templated</span>
          <h2>We Speak Your Industry's Language</h2>
          <p class="lead" style="max-width:760px;">{pv.intro}</p>
        </div>

        <div class="pv-grid">
          <div class="pv-block pv-slang reveal">
            <div class="pv-block-label">Insider Vocabulary</div>
            <p class="pv-block-sub">Terms you use every day. The ones a generic agency would have to Google.</p>
            <dl class="pv-slang-list">
              {pv.slang.map(s => (
                <div class="pv-slang-item">
                  <dt>{s.term}</dt>
                  <dd>{s.meaning}</dd>
                </div>
              ))}
            </dl>
          </div>

          <div class="pv-side">
            <div class="pv-block pv-tech reveal">
              <div class="pv-block-label">The Tech You Already Run</div>
              <p class="pv-block-sub">Your operational stack shapes what marketing can do. We start by knowing it.</p>
              <ul class="pv-tech-list">
                {pv.opsTech.map(t => <li>{t}</li>)}
              </ul>
            </div>

            <div class="pv-block pv-mkt reveal">
              <div class="pv-block-label">Marketing Tech + Practices Specific to Your Industry</div>
              <p class="pv-block-sub">The plays that work because your category rewards them. Not the generic ones.</p>
              <ul class="pv-mkt-list">
                {pv.marketingTech.map(t => <li>{t}</li>)}
              </ul>
            </div>
          </div>
        </div>

        <div class="pv-edge reveal">
          <div class="pv-edge-label">Our Insider Edge</div>
          <p>{pv.insiderEdge}</p>
        </div>
      </div>
    </section>
  )}

  <section class="section services-section">
    <div class="container">
      <div class="section-head">
        <span class="label">Our Services for {v.name}</span>
        <h2>Every service we offer, built specifically for {v.name.toLowerCase()} in Miami.</h2>
      </div>
      <div class="svc-grid">
        {v.services.map(sSlug => {
          const svc = getServiceDef(sSlug);
          const config = v.serviceConfigs[sSlug];
          return (
            <a href={`/${v.slug}/${sSlug}/`} class="svc-card reveal">
              <div class="svc-icon-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={svcIcons[sSlug]} />
              </div>
              <div class="svc-body">
                <h3>{svc.name}</h3>
                <p>{config?.lead ?? svc.defaultIncludes[0]}</p>
                <div class="svc-price">{svc.price}</div>
              </div>
              <svg class="svc-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {marketBody && marketBody.length > 0 && (
    <section class="section market-section">
      <div class="container">
        <div class="two-col">
          <div class="reveal">
            <span class="label">{v.name}</span>
            {marketHeadline && <h2>{marketHeadline}</h2>}
            {marketBody.map((para, i) => (
              <p set:html={para} style={i === 0 ? '' : 'margin-top:16px;'}></p>
            ))}
          </div>
          {overrideSignals && (
            <div class="local-pills reveal">
              {overrideSignals.map(s => (
                <div class="local-pill">
                  <span class="pill-label">{s.label}</span>
                  <span class="pill-val" set:html={s.val}></span>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <section class="section problem-section">
    <div class="container">
      <div class="problem-inner">
        <div class="problem-copy reveal">
          <span class="label">The Problem</span>
          <h2>{v.problemHeadline}</h2>
          <p>{v.problemBody}</p>
        </div>
        <div class="stat-pills reveal">
          {v.stats.map(s => (
            <div class={`stat-pill${s.accent ? ' accent' : ''}`}>
              <div class="stat-num">{s.num}</div>
              <div class="stat-lbl">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section why-section">
    <div class="container">
      <div class="section-head center">
        <span class="label">Why Thryv</span>
        <h2>Miami-based. Built for local service businesses. No long-term contracts.</h2>
      </div>
      <div class="why-grid">
        <div class="why-card reveal">
          <div class="why-icon">📍</div>
          <h3>We Know Miami</h3>
          <p>We are based in Miami. We know the neighborhoods, the competition, and what Miami consumers actually respond to. Every strategy is built for this market, not adapted from a generic playbook.</p>
        </div>
        <div class="why-card reveal">
          <div class="why-icon">📊</div>
          <h3>Measurable Results</h3>
          <p>Every service we run is tracked. You get monthly reports showing rankings, leads, review growth, and what moved. No vanity metrics: just the numbers that matter for your business.</p>
        </div>
        <div class="why-card reveal">
          <div class="why-icon">🤝</div>
          <h3>Month-to-Month</h3>
          <p>No contracts. No lock-ins. We earn your business every month. If you are not seeing results, you can cancel with 30 days notice. We stay because our work works, not because of paperwork.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container">
      <div class="section-head center">
        <span class="label">Common Questions</span>
        <h2>Questions from {v.name} in Miami</h2>
      </div>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item reveal">
            <summary>{f.q}</summary>
            <p set:html={f.a}></p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {showInsights && insightsCategory && (
    <section class="section insights-section" aria-labelledby="insights-heading">
      <div class="container">
        <div class="section-head center">
          <span class="label">Marketing Insights</span>
          <h2 id="insights-heading">{insightsCategory.label} articles for {v.name.toLowerCase()}</h2>
          <p class="insights-lead">{insightsCategory.description}</p>
        </div>
        <div class="insights-grid">
          {insightsPosts.map((post) => (
            <a href={post.slug} class="insight-card reveal" aria-label={post.title}>
              <div class="insight-category">{post.category}</div>
              <h3 class="insight-title">{post.title}</h3>
              <p class="insight-excerpt">{post.excerpt}</p>
              <div class="insight-meta">
                <span>{post.date}</span>
                <span>{post.readTime}</span>
              </div>
            </a>
          ))}
        </div>
        <div class="insights-cta-row">
          <a href={`/blog/category/${insightsCategory.slug}/`} class="insights-cta">
            Browse all {insightsCategory.label} articles
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <ToolCallout
    href={tool.href}
    icon={tool.icon}
    title={tool.title}
    desc={tool.desc}
  />

  <section class="section contact-section" id="contact">
    <div class="container">
      <div class="contact-split">
        <div class="reveal">
          <span class="label">Free Proposal</span>
          <h2>See What Your Competition Sees When They Search for {v.singular === 'Dental Office' || v.singular === 'Med Spa' ? 'a ' + v.singular : 'a ' + v.singular} in Miami</h2>
          <p class="lead" style="margin-bottom:24px;">We audit your Google Business Profile, search rankings, and reviews, then tell you exactly where you stand versus your top competitors in Miami.</p>
          <p style="font-size:14px;color:var(--gray);">Hablamos Espa&ntilde;ol</p>
        </div>
        <ContactForm
          title="Get My Free Proposal"
          subject={`${v.name} Marketing Inquiry | Thryv`}
          showOrgField={true}
        />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .v-hero { padding: 80px 0 64px; background: linear-gradient(135deg, var(--blue-deeper) 0%, #1a3a70 100%); color: var(--white); }
  .v-hero .label { background: rgba(255,255,255,.15); color: var(--white); }
  .v-hero h1 { font-size: clamp(28px, 4.5vw, 50px); font-weight: 800; line-height: 1.1; letter-spacing: -.02em; margin: 16px 0; color: var(--white); max-width: 700px; }
  .v-hero .lead { color: rgba(255,255,255,.8); max-width: 600px; font-size: 17px; line-height: 1.7; }
  .breadcrumb { display: flex; align-items: center; gap: 4px; font-size: 13px; color: rgba(255,255,255,.6); margin-bottom: 24px; flex-wrap: wrap; }
  .breadcrumb a { color: rgba(255,255,255,.6); } .breadcrumb a:hover { color: var(--white); }
  .hero-ctas { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-top: 32px; }
  .btn-outline-white { display: inline-flex; align-items: center; gap: 8px; padding: 13px 24px; border-radius: 10px; font-weight: 700; font-size: 15px; border: 2px solid rgba(255,255,255,.5); color: var(--white); text-decoration: none; transition: border-color .2s, background .2s; }
  .btn-outline-white:hover { border-color: var(--white); background: rgba(255,255,255,.1); }

  .market-section { background: var(--white); padding: 56px 0; }
  .market-section .label { background: var(--blue-deeper); color: var(--white); display: inline-block; padding: 4px 12px; border-radius: 100px; font-size: 11px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; margin-bottom: 12px; }
  .market-section h2 { font-size: clamp(22px, 2.5vw, 30px); font-weight: 800; color: var(--dark); margin: 0 0 16px; letter-spacing: -0.01em; }
  .market-section p { font-size: 15px; line-height: 1.75; color: var(--gray); }
