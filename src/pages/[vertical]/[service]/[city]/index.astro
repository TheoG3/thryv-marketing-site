  .why-miami-section { background: var(--white); }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
  .two-col h2 { font-size: clamp(22px, 2.5vw, 32px); font-weight: 800; color: var(--dark); margin: 12px 0; line-height: 1.2; }
  .two-col p { font-size: 15px; line-height: 1.75; color: var(--gray); margin-top: 12px; }
  .why-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .why-stat { background: var(--light); border: 1.5px solid var(--border); border-radius: var(--radius); padding: 20px; }
  .why-stat.accent { background: var(--blue-deeper); border-color: var(--blue-deeper); }
  .why-stat-num { font-size: 28px; font-weight: 800; color: var(--blue); line-height: 1; margin-bottom: 8px; }
  .why-stat.accent .why-stat-num { color: var(--white); }
