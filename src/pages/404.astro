---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Thryv Marketing Solutions"
  description="This page doesn't exist. Head back to Thryv Marketing Solutions."
  canonical="https://thryvmarketingsolutions.com/404/"
>

  <section class="notfound">
    <div class="container">
      <div class="notfound-inner">
        <div class="notfound-num">404</div>
        <h1>Page Not Found</h1>
        <p>The page you are looking for does not exist or has been moved. Here are some places to start:</p>
        <div class="notfound-links">
          <a href="/" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
            Back to Home
          </a>
          <a href="/services/" class="btn btn-blue">View Services</a>
          <a href="/contact/" class="btn btn-outline">Get Free Audit</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .notfound { padding: 120px 0; text-align: center; }
  .notfound-inner { max-width: 480px; margin: 0 auto; }
  .notfound-num { font-size: 120px; font-weight: 800; color: var(--border); line-height: 1; margin-bottom: 8px; letter-spacing: -.04em; }
  .notfound h1 { font-size: 32px; font-weight: 800; color: var(--dark); margin-bottom: 16px; }
  .notfound p { font-size: 16px; line-height: 1.7; color: var(--gray); margin-bottom: 40px; }
  .notfound-links { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .btn-outline { background: transparent; color: var(--blue); border: 2px solid var(--blue); padding: 13px 24px; border-radius: 100px; font-weight: 700; font-size: 15px; transition: all .2s; display: inline-flex; align-items: center; }
  .btn-outline:hover { background: var(--blue); color: var(--white); }
</style>
