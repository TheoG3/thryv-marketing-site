---
import BaseLayout from '../../layouts/BaseLayout.astro';

const WORKER_URL = 'https://thryv-ada-scanner.theodoreg3.workers.dev';
const TURNSTILE_SITE_KEY = '0x4AAAAAADX9NuDDs59nhLJU';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home",     "item": "https://thryvmarketingsolutions.com/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://thryvmarketingsolutions.com/services/" },
      { "@type": "ListItem", "position": 3, "name": "ADA Website Compliance", "item": "https://thryvmarketingsolutions.com/services/ada-compliance/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Is there an official ADA certified badge for websites?", "acceptedAnswer": { "@type": "Answer", "text": "No. The government does not certify websites, and anyone selling you a certified badge is overselling. A fake badge can actually be used against you. What is real is conforming to WCAG 2.2 AA and documenting it." } },
      { "@type": "Question", "name": "Does the free scan mean my site is compliant?", "acceptedAnswer": { "@type": "Answer", "text": "No. The free scan is an automated snapshot of your homepage. It catches common issues, but real compliance requires every page checked plus human testing of keyboard and screen-reader use." } },
      { "@type": "Question", "name": "Am I really at risk as a small local business?", "acceptedAnswer": { "@type": "Answer", "text": "Small businesses are common targets precisely because they are the least prepared and most likely to settle quickly. Fixing your site is the same move whether you are motivated by the legal risk or the customers you are currently losing." } },
      { "@type": "Question", "name": "Do accessibility overlay widgets work?", "acceptedAnswer": { "@type": "Answer", "text": "No. Overlays do not equal compliance per the DOJ, the FTC fined a major overlay maker 1 million dollars in 2025, and overlay-equipped sites get sued more, not less. We fix the actual code instead." } },
      { "@type": "Question", "name": "Can you guarantee I will not get sued?", "acceptedAnswer": { "@type": "Answer", "text": "No one honest can promise that. We meaningfully lower your risk by fixing real barriers and documenting your good-faith effort, which is what matters in practice. This is technical work, not legal advice." } },
      { "@type": "Question", "name": "How much does it cost to fix my site for ADA compliance?", "acceptedAnswer": { "@type": "Answer", "text": "It depends on your site's size and how it is built. Run the free scan, then book a call and we will scope it honestly with no pressure. Our audit starts at $297 and the full audit-plus-fix package is $997." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "ADA Website Compliance",
    "provider": { "@type": "LocalBusiness", "name": "Thryv Marketing Solutions", "address": { "@type": "PostalAddress", "addressLocality": "Miami", "addressRegion": "FL" } },
    "areaServed": "Miami, FL",
    "description": "Free WCAG 2.2 AA accessibility scan plus full audit, remediation, and monthly monitoring for Miami small businesses.",
    "offers": [
      { "@type": "Offer", "name": "Full Audit", "price": "297", "priceCurrency": "USD" },
      { "@type": "Offer", "name": "Audit + Fix", "price": "997", "priceCurrency": "USD" },
      { "@type": "Offer", "name": "Monthly Monitoring", "price": "97", "priceCurrency": "USD" }
    ]
  }
];
---

<BaseLayout
  title="ADA Website Compliance Miami. Free WCAG Scan. Thryv Marketing Solutions"
  description="Is your Miami business website ADA compliant? Scan free in 30 seconds. Thryv fixes WCAG 2.2 AA violations with real code changes, no overlay widgets."
  schema={schema}
>

<style>
  :root{
    --blue:#1B4FA8;--blue-dark:#0F3272;--blue-deeper:#070F2B;--blue-light:#EEF4FF;
    --orange:#F5A623;--orange-dark:#D4890A;--dark:#0D1B2A;--gray:#4B5563;--gray-light:#9CA3AF;
    --border:#E5E7EB;--light:#F8F9FB;--white:#FFFFFF;--radius:12px;--radius-lg:20px;
    --shadow:0 4px 24px rgba(0,0,0,.08);--shadow-lg:0 12px 48px rgba(0,0,0,.14);
    --red:#C0392B;--amber:#B7791F;--green:#15803D;
    --font:'Plus Jakarta Sans',sans-serif;
  }
  a{text-decoration:none;color:inherit}
  img{display:block;max-width:100%}
  .container{max-width:1160px;margin:0 auto;padding:0 24px}
  .narrow{max-width:780px}
  .section{padding:86px 0}
  :focus-visible{outline:3px solid var(--blue);outline-offset:2px;border-radius:4px}

  .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-family:var(--font);font-size:15px;font-weight:700;border-radius:100px;cursor:pointer;border:none;padding:14px 28px;transition:transform .15s,box-shadow .2s,background .2s;text-decoration:none}
  .btn-primary{background:var(--orange);color:var(--dark);box-shadow:0 4px 16px rgba(245,166,35,.35)}
  .btn-primary:hover{background:var(--orange-dark);transform:translateY(-1px)}
  .btn-blue{background:var(--blue);color:#fff}
  .btn-blue:hover{background:var(--blue-dark)}
  .btn-ghost{background:transparent;border:1.5px solid var(--border);color:var(--dark)}

  .eyebrow{display:inline-block;font-size:12px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:var(--orange-dark)}
  .label{display:inline-flex;font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--blue);background:var(--blue-light);border-radius:100px;padding:6px 14px;margin-bottom:18px}
  h2{font-size:clamp(26px,3.6vw,38px);font-weight:800;line-height:1.15;letter-spacing:-.015em;margin-bottom:14px}
  .lead{font-size:16.5px;line-height:1.7;color:var(--gray);text-align:center}
  .section-head{max-width:680px;margin:0 auto 42px;text-align:center}
  .section-head.left{margin:0 0 42px;text-align:left}
  /* center all section-level headings, chips, and body text by default */
  .section h2{text-align:center}
  .section p{text-align:center}
  .section .eyebrow{display:block;text-align:center}
  .section .label{display:flex;justify-content:center}
  /* prose blocks stay left for readability */
  .section .prose p{text-align:left}
  /* override: left-align inside cards and two-column layouts */
  .why-card h3,.why-card p,.check h4,.check p,.ov-task,.ov-row,.price-tier,.price-sub,.price-feat,.acc-q,.acc-a-inner,.case-grid h2,.case-grid p,.case-grid .lead,.case-grid .eyebrow{text-align:left}
  .case-grid .eyebrow{justify-content:flex-start}
  .prose p{font-size:16px;line-height:1.8;color:var(--gray);margin-bottom:16px}
  .prose p b{color:var(--dark)}

  .hero{background:linear-gradient(135deg,var(--blue-deeper) 0%,var(--blue-dark) 60%,#1a3a7a 100%);position:relative;overflow:hidden;padding:70px 0 78px}
  .hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 800px 600px at 75% 40%,rgba(245,166,35,.08) 0%,transparent 70%)}
  .hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:54px;align-items:center;position:relative;z-index:1}
  .hero-eyebrow{color:var(--orange);font-size:12px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;margin-bottom:18px;display:inline-block}
  .hero h1{font-size:clamp(31px,4.3vw,49px);font-weight:800;line-height:1.1;letter-spacing:-.02em;color:#fff;margin-bottom:18px}
  .hero h1 em{font-style:normal;color:var(--orange)}
  .hero-sub{font-size:16.5px;line-height:1.7;color:rgba(255,255,255,.74);margin-bottom:22px;max-width:500px}
  .hero-sub b{color:#fff;font-weight:700}
  .hero-pills{display:flex;flex-wrap:wrap;gap:8px}
  .hero-pill{font-size:12.5px;font-weight:600;color:rgba(255,255,255,.82);background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.13);border-radius:100px;padding:6px 13px}
  @media(max-width:880px){.hero-grid{grid-template-columns:1fr;gap:34px}}

  .scanner{background:#fff;border-radius:var(--radius-lg);box-shadow:0 24px 70px rgba(0,0,0,.3);padding:28px}
  .scanner-head{display:flex;align-items:center;gap:10px;margin-bottom:6px}
  .scanner-dot{width:9px;height:9px;border-radius:50%;background:var(--green);box-shadow:0 0 0 4px rgba(21,128,61,.15)}
  .scanner-head h3{font-size:16px;font-weight:800}
  .scanner-tag{font-size:12.5px;color:var(--gray);margin-bottom:18px}
  .scan-form{display:flex;gap:8px}
  .scan-form input{flex:1;font-family:var(--font);font-size:15px;border:1.5px solid var(--border);border-radius:10px;padding:13px 15px;outline:none;transition:border-color .2s,box-shadow .2s;min-width:0}
  .scan-form input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(27,79,168,.12)}
  .scan-form .btn{flex-shrink:0;padding:13px 20px}
  .scan-note{font-size:11.5px;color:var(--gray-light);margin-top:10px;text-align:center}
  .scan-loading{display:none;padding:22px 4px 6px}
  .scan-loading.on{display:block}
  .scan-step{display:flex;align-items:center;gap:10px;font-size:13.5px;color:var(--gray);padding:6px 0;opacity:.4;transition:opacity .3s}
  .scan-step.active{opacity:1;color:var(--dark);font-weight:600}
  .scan-step.done{opacity:1;color:var(--green)}
  .spin{width:15px;height:15px;border:2px solid var(--border);border-top-color:var(--blue);border-radius:50%;animation:spin .7s linear infinite;display:inline-block}
  @keyframes spin{to{transform:rotate(360deg)}}
  .scan-results{display:none;animation:fade .4s ease}
  .scan-results.on{display:block}
  .scan-error{display:none;padding:16px;background:#FEF2F2;border:1px solid #FECACA;border-radius:10px;font-size:13.5px;color:#991B1B;margin-top:12px}
  .scan-error.on{display:block}
  @keyframes fade{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
  .score-row{display:flex;align-items:center;gap:18px;padding:6px 2px 18px;border-bottom:1px solid var(--border);margin-bottom:16px}
  .score-ring{width:84px;height:84px;border-radius:50%;flex-shrink:0;display:grid;place-items:center;background:conic-gradient(#B7791F 68%,#E5E7EB 0)}
  .score-ring span{width:64px;height:64px;border-radius:50%;background:#fff;display:grid;place-items:center;font-size:23px;font-weight:800}
  .score-meta h4{font-size:16px;font-weight:800;margin-bottom:3px}
  .score-meta p{font-size:13px;color:var(--gray)}
  .sev-row{display:flex;gap:8px;margin-bottom:18px;flex-wrap:wrap}
  .sev{font-size:12px;font-weight:700;border-radius:8px;padding:5px 11px}
  .sev-critical{background:#FEE2E2;color:#991B1B}
  .sev-serious{background:#FDEAD7;color:#9A3412}
  .sev-mod{background:#FEF3C7;color:var(--amber)}
  .sev-minor{background:var(--blue-light);color:var(--blue)}
  .issue{display:flex;gap:11px;padding:12px;border:1px solid var(--border);border-radius:12px;margin-bottom:9px}
  .issue-ic{width:30px;height:30px;border-radius:8px;display:grid;place-items:center;flex-shrink:0;font-size:15px;background:#FDEAD7}
  .issue h5{font-size:14px;font-weight:700;margin-bottom:2px}
  .issue p{font-size:12.5px;color:var(--gray);line-height:1.5}
  .issue .wcag{font-size:10.5px;font-weight:700;color:var(--blue);background:var(--blue-light);border-radius:5px;padding:2px 7px;display:inline-block;margin-top:5px}
  .gate{margin-top:16px;background:var(--light);border:1px solid var(--border);border-radius:12px;padding:16px}
  .gate p{font-size:13px;color:var(--dark);margin-bottom:10px}
  .gate-form{display:flex;gap:8px}
  .gate-form input{flex:1;font-family:var(--font);font-size:14px;border:1.5px solid var(--border);border-radius:10px;padding:11px 14px;outline:none}
  .gate-form input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(27,79,168,.12)}
  .gate-success{display:none;text-align:center;padding:8px 0}
  .gate-success.on{display:block}
  .gate-success .chk{width:46px;height:46px;border-radius:50%;background:#DCFCE7;display:grid;place-items:center;margin:0 auto 10px;font-size:22px;color:var(--green)}
  .gate-success h4{font-size:16px;font-weight:800;margin-bottom:4px}
  .gate-success p{font-size:13px;color:var(--gray);margin-bottom:14px}
  .disclaimer{font-size:11px;color:var(--gray-light);margin-top:14px;line-height:1.5;text-align:center}
  .scan-joke{display:none;text-align:center;padding:20px 6px 8px;animation:fade .4s ease}
  .scan-joke.on{display:block}
  .joke-emoji{font-size:42px;margin-bottom:8px}
  .scan-joke h4{font-size:20px;font-weight:800;margin-bottom:8px}
  .scan-joke p{font-size:14px;color:var(--gray);line-height:1.6;margin-bottom:16px;max-width:350px;margin-left:auto;margin-right:auto}
  .scan-joke p b{color:var(--green)}

  .stats{background:var(--blue);padding:26px 0}
  .stats-inner{display:grid;grid-template-columns:repeat(3,1fr);text-align:center}
  .stats-src{text-align:center;font-size:11.5px;color:rgba(255,255,255,.55);margin-top:18px}
  .stats-src a{color:rgba(255,255,255,.82);text-decoration:underline}
  .stat{padding:0 20px;border-right:1px solid rgba(255,255,255,.16)}
  .stat:last-child{border-right:none}
  .stat-n{font-size:27px;font-weight:800;color:var(--orange);line-height:1}
  .stat-d{font-size:12.5px;color:rgba(255,255,255,.8);margin-top:6px}
  @media(max-width:680px){.stats-inner{grid-template-columns:1fr;gap:18px}.stat{border-right:none}}

  .straight{background:var(--light)}
  .straight .lead{font-size:18px;color:var(--dark);line-height:1.75;text-align:center}
  .straight .lead b{color:var(--blue-dark)}

  .why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
  .why-card{border:1px solid var(--border);border-radius:var(--radius-lg);padding:26px;background:#fff;transition:box-shadow .25s,transform .25s}
  .why-card:hover{box-shadow:var(--shadow-lg);transform:translateY(-3px)}
  .why-ic{width:46px;height:46px;border-radius:12px;background:var(--blue-light);display:grid;place-items:center;font-size:22px;margin-bottom:14px}
  .why-card h3{font-size:17px;font-weight:700;margin-bottom:8px}
  .why-card p{font-size:14px;color:var(--gray);line-height:1.6}
  @media(max-width:860px){.why-grid{grid-template-columns:1fr}}

  .timeline{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:38px}
  .tl-node{position:relative;padding-top:26px}
  .tl-node::before{content:'';position:absolute;top:6px;left:0;width:14px;height:14px;border-radius:50%;background:var(--orange)}
  .tl-node::after{content:'';position:absolute;top:12px;left:14px;right:-18px;height:2px;background:var(--border)}
  .tl-node:last-child::after{display:none}
  .tl-year{font-size:15px;font-weight:800;color:var(--blue)}
  .tl-node p{font-size:13.5px;color:var(--gray);margin-top:6px;line-height:1.55}
  @media(max-width:760px){.timeline{grid-template-columns:1fr;gap:8px}.tl-node{padding-top:0;padding-left:26px}.tl-node::before{top:4px;left:0}.tl-node::after{top:18px;left:6px;right:auto;bottom:-8px;width:2px;height:auto}}

  .machine{background:var(--blue-deeper);color:#fff}
  .machine h2{color:#fff}
  .machine .prose p{color:rgba(255,255,255,.74)}
  .machine .prose p b{color:#fff}
  .callout{background:rgba(245,166,35,.1);border:1px solid rgba(245,166,35,.28);border-radius:14px;padding:18px 22px;margin-top:8px}
  .callout p{font-size:14.5px;color:rgba(255,255,255,.88);margin:0;line-height:1.7}
  .callout b{color:var(--orange)}

  .checks-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:8px}
  .check{display:flex;gap:11px;align-items:flex-start;background:#fff;border:1px solid var(--border);border-radius:14px;padding:18px}
  .check .ck{flex-shrink:0;color:var(--green);font-weight:800;font-size:16px}
  .check h4{font-size:14.5px;font-weight:700;margin-bottom:3px}
  .check p{font-size:13px;color:var(--gray);line-height:1.5}
  @media(max-width:860px){.checks-grid{grid-template-columns:1fr}}

  .overlap-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px}
  .ov-card{background:#fff;border:1px solid var(--border);border-radius:16px;padding:22px;transition:box-shadow .25s,transform .25s}
  .ov-card:hover{box-shadow:var(--shadow-lg);transform:translateY(-3px)}
  .ov-task{font-size:16.5px;font-weight:800;margin-bottom:14px}
  .ov-row{display:flex;gap:10px;font-size:13.5px;color:var(--gray);line-height:1.55;margin-bottom:11px;align-items:flex-start}
  .ov-row:last-child{margin-bottom:0}
  .ov-tag{flex-shrink:0;font-size:10px;font-weight:800;border-radius:6px;padding:4px 8px;white-space:nowrap;min-width:106px;text-align:center;letter-spacing:.02em}
  .ov-tag.a11y{background:var(--blue-light);color:var(--blue)}
  .ov-tag.seo{background:#FEF3C7;color:var(--orange-dark)}
  @media(max-width:760px){.overlap-grid{grid-template-columns:1fr}}

  .case{background:var(--blue-deeper);color:#fff}
  .case-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
  .case h2{color:#fff}.case .lead{color:rgba(255,255,255,.7)}
  .case-card{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:var(--radius-lg);padding:28px}
  .case-ba{display:flex;align-items:center;gap:16px;margin-bottom:18px}
  .ba-box{flex:1;text-align:center;padding:16px;border-radius:12px}
  .ba-box.before{background:rgba(192,57,43,.15);border:1px solid rgba(192,57,43,.3)}
  .ba-box.after{background:rgba(21,128,61,.15);border:1px solid rgba(21,128,61,.3)}
  .ba-n{font-size:30px;font-weight:800;line-height:1}
  .ba-box.before .ba-n{color:#fca5a5}.ba-box.after .ba-n{color:#86efac}
  .ba-l{font-size:11.5px;color:rgba(255,255,255,.6);margin-top:5px}
  .ba-arrow{color:var(--orange);font-size:20px}
  @media(max-width:860px){.case-grid{grid-template-columns:1fr;gap:30px}}

  .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;margin-top:8px}
  .step{text-align:center;padding:0 12px}
  .step-n{width:56px;height:56px;border-radius:50%;background:var(--blue);color:#fff;font-size:20px;font-weight:800;display:grid;place-items:center;margin:0 auto 16px}
  .step:nth-child(2) .step-n{background:var(--orange);color:var(--dark)}
  .step:nth-child(3) .step-n{background:var(--blue-dark)}
  .step h4{font-size:16px;font-weight:700;margin-bottom:7px}
  .step p{font-size:14px;color:var(--gray);line-height:1.6}
  @media(max-width:760px){.steps{grid-template-columns:1fr;gap:20px}}

  .pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;align-items:start}
  .price-card{border:2px solid var(--border);border-radius:var(--radius-lg);padding:30px 26px;background:#fff;position:relative}
  .price-card.feat{border-color:var(--blue);box-shadow:0 8px 40px rgba(27,79,168,.16)}
  .price-badge{position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:var(--blue);color:#fff;font-size:11px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;border-radius:100px;padding:5px 15px;white-space:nowrap}
  .price-tier{font-size:13px;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px}
  .price-n{font-size:34px;font-weight:800;line-height:1;margin-bottom:4px}
  .price-sub{font-size:13px;color:var(--gray);margin-bottom:18px}
  .price-feats{display:flex;flex-direction:column;gap:9px;margin-bottom:22px}
  .price-feat{display:flex;gap:9px;font-size:13.5px;align-items:flex-start}
  .price-feat .ck{color:var(--green);flex-shrink:0;font-weight:800}
  .price-card .btn{width:100%;display:flex}
  @media(max-width:860px){.pricing-grid{grid-template-columns:1fr}}

  .faq{max-width:780px;margin:0 auto}
  .acc{border:1px solid var(--border);border-radius:12px;margin-bottom:10px;overflow:hidden;background:#fff}
  .acc-q{width:100%;display:flex;align-items:center;justify-content:space-between;gap:14px;text-align:left;background:none;border:none;cursor:pointer;font-family:inherit;font-size:16px;font-weight:700;color:var(--dark);padding:18px 20px}
  .acc-q:hover{background:var(--light)}
  .acc-icon{flex-shrink:0;width:22px;height:22px;border-radius:50%;background:var(--blue-light);color:var(--blue);display:grid;place-items:center;font-size:16px;font-weight:800;transition:transform .25s}
  .acc[aria-expanded="true"] .acc-icon{transform:rotate(45deg)}
  .acc-a{max-height:0;overflow:hidden;transition:max-height .3s ease}
  .acc-a-inner{padding:0 20px 18px;font-size:14.5px;color:var(--gray);line-height:1.7}
  .acc-a-inner b{color:var(--dark)}

  .final{background:linear-gradient(135deg,var(--blue) 0%,var(--blue-dark) 100%);color:#fff;text-align:center}
  .final h2{color:#fff}
  .final p{color:rgba(255,255,255,.8);font-size:16px;max-width:520px;margin:0 auto 26px}
  .cf-turnstile{margin-top:10px}
</style>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<section class="hero" id="scan">
  <div class="container hero-grid">
    <div>
      <span class="hero-eyebrow">ADA · WCAG 2.2 AA · Miami</span>
      <h1>Is your website <em>ADA compliant?</em> Find out in 30 seconds.</h1>
