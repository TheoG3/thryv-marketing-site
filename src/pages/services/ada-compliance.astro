<script define:vars={{ WORKER_URL, TURNSTILE_SITE_KEY }}>
  const nav = document.querySelector('nav');
  if (nav) addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 20), { passive: true });

  const form    = document.getElementById('scanForm');
  const wrap    = document.getElementById('scanFormWrap');
  const loading = document.getElementById('scanLoading');
  const results = document.getElementById('scanResults');
  const joke    = document.getElementById('scanJoke');
  const errBox  = document.getElementById('scanError');
  const steps   = [...document.querySelectorAll('.scan-step')];
  let pendingUrl = null;
  let tsToken    = null;

  window.onTurnstileSuccess = (token) => { tsToken = token; if (pendingUrl) runScan(pendingUrl); };

  function showLoading() {
    wrap.style.display = 'none';
    loading.classList.add('on');
    steps.forEach(s => s.classList.remove('active', 'done'));
    steps[0].classList.add('active');
    let i = 0;
    const iv = setInterval(() => {
      steps[i].classList.remove('active'); steps[i].classList.add('done');
      i++;
      if (i < steps.length) steps[i].classList.add('active');
      else clearInterval(iv);
    }, 900);
  }

  async function runScan(url) {
    pendingUrl = null;
    showLoading();
    try {
      const res = await fetch(WORKER_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url, turnstileToken: tsToken }),
      });
      tsToken = null;
      const data = await res.json();
      loading.classList.remove('on');
      if (!res.ok || data.error) { errBox.classList.add('on'); wrap.style.display = ''; return; }
      renderResults(data, url);
    } catch {
      loading.classList.remove('on');
      errBox.classList.add('on');
      wrap.style.display = '';
    }
  }

  function renderResults(data, url) {
    const domain = url.replace(/^https?:\/\//, '').replace(/\/.*$/, '') || 'your site';
    document.getElementById('scannedDomain').textContent = domain;
    document.getElementById('scoreNum').textContent = data.score ?? 0;
    document.getElementById('scoreLabel').textContent = data.label || 'Result';
    const ring = document.getElementById('scoreRing');
    const s = data.score || 0;
    const color = s >= 90 ? '#15803D' : s >= 70 ? '#B7791F' : '#C0392B';
    ring.style.background = `conic-gradient(${color} ${s}%, #E5E7EB 0)`;
    const sev = data.severities || {};
    const sevRow = document.getElementById('sevRow');
    sevRow.innerHTML = '';
    [['critical','sev-critical'],['serious','sev-serious'],['moderate','sev-mod'],['minor','sev-minor']].forEach(([key, cls]) => {
      const n = sev[key]; if (n) sevRow.insertAdjacentHTML('beforeend', `<span class="sev ${cls}">${n} ${key}</span>`);
    });
    const list = document.getElementById('issueList');
    list.innerHTML = '';
    const icons = { critical: '🚨', serious: '⚠️', moderate: '📋', minor: 'ℹ️' };
    (data.topIssues || []).forEach(issue => {
      const ic = icons[issue.impact] || '🔍';
      const wcag = (issue.wcag || []).map(w => `<span class="wcag">${w}</span>`).join(' ');
      list.insertAdjacentHTML('beforeend', `<div class="issue"><div class="issue-ic">${ic}</div><div><h5>${issue.help}</h5>${wcag}</div></div>`);
    });
    results.classList.add('on');
    document.getElementById('scan').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  form.addEventListener('submit', e => {
    e.preventDefault();
    const raw = document.getElementById('scanUrl').value.trim();
    errBox.classList.remove('on'); results.classList.remove('on'); joke.classList.remove('on');
    if (/thryv/i.test(raw)) { wrap.style.display = 'none'; joke.classList.add('on'); return; }
    const url = /^https?:\/\//i.test(raw) ? raw : 'https://' + raw;
    pendingUrl = url;
    if (tsToken) { runScan(url); return; }
    if (window.turnstile) { window.turnstile.reset(); window.turnstile.execute(); }
    else { tsToken = ''; runScan(url); }
  });

  document.getElementById('jokeReset').addEventListener('click', () => {
    joke.classList.remove('on'); wrap.style.display = '';
    const inp = document.getElementById('scanUrl'); inp.value = ''; inp.focus();
  });

  document.getElementById('gateForm').addEventListener('submit', e => {
    e.preventDefault();
    document.getElementById('gate').style.display = 'none';
    document.getElementById('gateSuccess').classList.add('on');
  });

  document.querySelectorAll('.acc-q').forEach(btn => {
    const acc = btn.parentElement;
    const panel = acc.querySelector('.acc-a');
    btn.addEventListener('click', () => {
      const open = acc.getAttribute('aria-expanded') === 'true';
      acc.setAttribute('aria-expanded', String(!open));
      btn.setAttribute('aria-expanded', String(!open));
      panel.style.maxHeight = open ? null : panel.scrollHeight + 'px';
    });
  });
</script>

</BaseLayout>
