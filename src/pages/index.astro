  .founding-tab:hover { transform: translateY(-50%) translateX(-4px); }
  .founding-tab-star { color: var(--orange); font-size: 18px; }
  .founding-tab-text strong { display: block; font-size: 13px; font-weight: 800; color: var(--dark); }
  .founding-tab-text span { display: block; font-size: 11.5px; color: var(--gray); margin-top: 2px; }
  @media (max-width: 600px) { .founding-tab { top: auto; bottom: 14px; right: 10px; transform: none; max-width: 210px; } .founding-tab:hover { transform: none; } }

  /* ── LOCAL MARKETING INTRO ───────────────── */
  .intro-section { background: var(--white); }
  .intro-head { max-width: 800px; }
  .intro-head h2 { font-size: clamp(24px, 3vw, 34px); font-weight: 800; color: var(--dark); line-height: 1.22; letter-spacing: -0.01em; margin-top: 12px; }
  .intro-body { max-width: 800px; margin-top: 22px; }
  .intro-body p { font-size: 16.5px; line-height: 1.8; color: var(--gray); margin: 0 0 16px; }
  .intro-body p:last-child { margin-bottom: 0; }
  .intro-focus { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 44px; }
  .intro-focus-card { background: var(--light); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 26px 24px; transition: transform .25s, box-shadow .25s; }
  .intro-focus-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); }
  .intro-focus-dot { width: 12px; height: 12px; border-radius: 50%; background: var(--orange); margin-bottom: 14px; }
  .intro-focus-card h3 { font-size: 17px; font-weight: 700; color: var(--dark); margin-bottom: 8px; }
  .intro-focus-card p { font-size: 14px; line-height: 1.65; color: var(--gray); }

  /* ── HERO ────────────────────────────────── */
  .hero {
    background: linear-gradient(135deg, var(--blue-deeper) 0%, var(--blue-dark) 60%, #1a3a7a 100%);
    position: relative; overflow: hidden;
    padding: 100px 0 80px;
  }
  .hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 800px 600px at 70% 50%, rgba(245,166,35,.07) 0%, transparent 70%);
  }
  .hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; position: relative; z-index: 1; }
  .hero-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--orange); margin-bottom: 20px; animation: heroFadeUp .55s cubic-bezier(.22,1,.36,1) .05s both; }
  .hero-eyebrow span { display: inline-block; width: 24px; height: 2px; background: var(--orange); border-radius: 2px; }
  .hero h1 { font-size: clamp(36px, 5vw, 58px); font-weight: 800; line-height: 1.1; letter-spacing: -0.02em; color: var(--white); margin-bottom: 24px; animation: heroFadeUp .65s cubic-bezier(.22,1,.36,1) .18s both; }
  .hero h1 em { font-style: normal; color: var(--orange); }
  .hero-sub { font-size: 17px; line-height: 1.7; color: rgba(255,255,255,.72); margin-bottom: 36px; max-width: 480px; animation: heroFadeUp .55s cubic-bezier(.22,1,.36,1) .28s both; }
  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; animation: heroFadeUp .55s cubic-bezier(.22,1,.36,1) .38s both; }
  .hero-pills { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 40px; animation: heroFadeUp .5s cubic-bezier(.22,1,.36,1) .44s both; }
  .hero-pill { display: inline-flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 600; color: rgba(255,255,255,.8); background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12); border-radius: 100px; padding: 7px 14px; }
  .hero-pill svg { color: var(--orange); }
  .hero-visual { display: flex; flex-direction: column; gap: 16px; }
  .hero-card { background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.1); border-radius: var(--radius-lg); padding: 24px; backdrop-filter: blur(12px); }
  .hero-card-label { font-size: 11px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--orange); margin-bottom: 10px; }
