  .hero-card-sub { font-size: 13px; color: rgba(255,255,255,.55); }
  .hero-cards-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .hero-visual > .hero-card:first-child { animation: heroScaleIn .65s cubic-bezier(.22,1,.36,1) .22s both; }
  .hero-visual .hero-cards-row { animation: heroScaleIn .65s cubic-bezier(.22,1,.36,1) .34s both; }
  .hero-visual > .hero-card:last-child { animation: heroScaleIn .65s cubic-bezier(.22,1,.36,1) .44s both; }

  /* ── STATS BAR ───────────────────────────── */
  .stats-bar { background: var(--blue); padding: 28px 0; }
  .stats-inner { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; text-align: center; }
  .stat-item { padding: 0 24px; border-right: 1px solid rgba(255,255,255,.15); }
