<script>
  // Intersection Observer scroll reveals
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, { threshold: 0.12 });
  revealEls.forEach(el => observer.observe(el));

  // Hamburger menu
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger.addEventListener('click', () => {
    mobileMenu.classList.toggle('open');
    const isOpen = mobileMenu.classList.contains('open');
    hamburger.setAttribute('aria-expanded', isOpen.toString());
    hamburger.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
    const spans = hamburger.querySelectorAll('span');
    if (isOpen) {
      spans[0].style.transform = 'rotate(45deg) translate(5px, 5px)';
      spans[1].style.opacity = '0';
      spans[2].style.transform = 'rotate(-45deg) translate(5px, -5px)';
    } else {
      spans.forEach(s => { s.style.transform = ''; s.style.opacity = ''; });
    }
  });
  document.querySelectorAll('.mobile-link').forEach(l => {
    l.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      hamburger.querySelectorAll('span').forEach(s => { s.style.transform = ''; s.style.opacity = ''; });
    });
  });

  // Contact form
  const form = document.getElementById('contactForm');
  const success = document.getElementById('formSuccess');
  const formStatus = document.getElementById('form-status');
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type=submit]');
    btn.textContent = 'Sending...'; btn.disabled = true;
    formStatus.textContent = 'Submitting your request...';
    try {
      const res = await fetch(form.action, { method: 'POST', body: new FormData(form) });
      if (res.ok) {
        form.style.display = 'none';
        success.style.display = 'block';
        formStatus.textContent = 'Your audit request has been sent. We will respond within 24 hours.';
        if (window.posthog) posthog.capture('audit_request_submitted');
      } else { throw new Error('Form error'); }
    } catch {
      btn.textContent = 'Get My Free Audit'; btn.disabled = false;
      formStatus.textContent = 'Error sending your request. Please email hello@thryvmarketingsolutions.com directly.';
      alert('Something went wrong. Please email us directly at hello@thryvmarketingsolutions.com');
    }
  });

  // Review rating calculator
  function calcReviews() {
    const N = parseInt(document.getElementById('rc-count').value);
    const R = parseFloat(document.getElementById('rc-current').value);
    const T = parseFloat(document.getElementById('rc-target').value);
    const res = document.getElementById('rc-result');
    const numEl = document.getElementById('rc-num');
    const lblEl = document.getElementById('rc-label');
    if (!N || !R || !T) { alert('Please fill in all three fields.'); return; }
    if (T <= R) { numEl.textContent = '0'; lblEl.textContent = "You're already there! Keep collecting reviews to maintain it."; res.classList.add('show'); return; }
    if (T >= 5) { numEl.textContent = '∞'; lblEl.textContent = 'A perfect 5.0 is mathematically unreachable at scale.'; res.classList.add('show'); return; }
    const x = Math.ceil(N * (T - R) / (5 - T));
    numEl.textContent = x.toLocaleString();
    lblEl.textContent = `5-star reviews needed to reach ${T} ★`;
    res.classList.add('show');
    if (window.posthog) posthog.capture('tool_review_calc_used', { count: N, current: R, target: T, result: x });
  }

  // GBP score calculator
  function calcGBP() {
    const checks = document.querySelectorAll('#gbp-checklist input[type=checkbox]');
    let score = 0;
    checks.forEach(c => { if (c.checked) score += parseInt(c.dataset.pts); });
    const bar = document.getElementById('gbp-bar');
    const label = document.getElementById('gbp-label');
    const res = document.getElementById('gbp-result');
    const numEl = document.getElementById('gbp-score-num');
    const gradeEl = document.getElementById('gbp-grade');
    const ctaEl = document.getElementById('gbp-cta');
    bar.style.transform = 'scaleX(' + (score / 100) + ')';
    let grade, cta;
    if (score === 0) { label.textContent = 'Check items above to see your score'; return; }
    else if (score < 40) { grade = '🚨 Needs Urgent Attention'; cta = 'Your profile is costing you customers. <a href="#contact">Let\'s fix it.</a>'; }
    else if (score < 65) { grade = '⚠️ Room for Improvement'; cta = 'You\'re missing easy wins. <a href="#contact">We\'ll handle it for you.</a>'; }
    else if (score < 85) { grade = '✅ Pretty Good'; cta = 'A few gaps are holding you back. <a href="#contact">We can close them.</a>'; }
    else { grade = '🏆 Fully Optimized'; cta = 'Great work! Keep it consistent. <a href="#contact">Ask us about staying on top.</a>'; }
    label.textContent = `Your score: ${score}/100`;
    numEl.textContent = score + '/100';
    gradeEl.textContent = grade;
    ctaEl.innerHTML = cta;
    res.classList.add('show');
    if (window.posthog) posthog.capture('tool_gbp_score_used', { score });
  }

  // Counter animation
  const counters = document.querySelectorAll('.stat-num[data-target]');
  const counterObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target;
      const target = parseInt(el.dataset.target);
      const duration = 1200;
      let start = null;
      function tick(ts) {
        if (!start) start = ts;
        const progress = Math.min((ts - start) / duration, 1);
        const ease = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(ease * target);
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
      counterObs.unobserve(el);
    });
  }, { threshold: 0.6 });
  counters.forEach(c => counterObs.observe(c));

  // Sticky nav shadow
  const navEl = document.querySelector('nav');
  window.addEventListener('scroll', () => {
    navEl.style.boxShadow = window.scrollY > 20 ? '0 4px 24px rgba(0,0,0,.12)' : '0 2px 16px rgba(0,0,0,.06)';
  }, { passive: true });

  // Active section nav tracking
  const navLinks = document.querySelectorAll('.nav-links a[href^="#"]');
  const pageSections = document.querySelectorAll('section[id]');
  const sectionObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinks.forEach(link => {
          link.classList.toggle('nav-active', link.getAttribute('href') === '#' + entry.target.id);
        });
      }
    });
  }, { threshold: 0.35 });
  pageSections.forEach(s => sectionObserver.observe(s));

  // Hero floating cards after entrance
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    setTimeout(() => {
      const heroVisual = document.querySelector('.hero-visual');
      if (heroVisual) {
        const cards = heroVisual.querySelectorAll(':scope > .hero-card');
        const row = heroVisual.querySelector('.hero-cards-row');
        if (cards[0]) cards[0].classList.add('hero-float');
        if (row) row.classList.add('hero-float-mid');
        if (cards[1]) cards[1].classList.add('hero-float-last');
      }
    }, 900);
  }

  // Mobile menu: close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu.classList.contains('open')) {
      mobileMenu.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.setAttribute('aria-label', 'Open navigation menu');
      hamburger.querySelectorAll('span').forEach(s => { s.style.transform = ''; s.style.opacity = ''; });
    }
  });
</script>

</BaseLayout>
