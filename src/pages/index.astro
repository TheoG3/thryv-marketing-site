---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';

// Home FAQ. Visible accordion plus FAQPage schema. Answers are plain text for schema validity.
const faqs = [
  { q: "Do I have to sign a long-term contract?", a: "No. Every Thryv engagement is month to month. No 12-month lock-in and no early termination fee. If we are not earning our keep, you can leave any time. We would rather keep your business by performing than by trapping you in a contract." },
  { q: "How much does it cost?", a: "Plans start at $297/mo, and you can see every price on our pricing page without booking a sales call. No setup fees and no platform fees added later. You pay for the plan you pick, nothing buried." },
  { q: "How soon will I see results?", a: "It depends on where you start and which services you run. Paid ads can drive calls within days, while local SEO and reputation work usually build over the first 60 to 90 days. We tell you honestly what to expect for your situation, and your monthly report shows the movement as it happens." },
  { q: "Do you only work with Miami businesses?", a: "Miami is home and the market we know best, but we work with local businesses across the country. The playbook for ranking and getting found in a local market travels well." },
  { q: "Can you work with us in Spanish?", a: "Yes. We run campaigns, manage listings, respond to reviews, and talk strategy fluently in English and Spanish." },
  { q: "Who actually does the work?", a: "You work directly with the founder, not a rotating junior account manager. Every strategy is built and reviewed by the person whose name is on the company." },
  { q: "Do I own my Google Ads account and Google Business Profile?", a: "Yes, always, and this matters more than most owners realize. Every account is created in your name from day one. You keep full access to every campaign, keyword, dollar spent, and your Google Business Profile. If we ever part ways, you walk away with everything. We never hold your accounts hostage." },
  { q: "What industries do you work with?", a: "We work with local service businesses across Miami: HVAC, plumbing, electrical, dental and med spas, restaurants, law firms, roofing, and home services. The common thread is a business that depends on local search, Google Maps, and reviews to win new customers, which is exactly what our playbook is built for." },
  { q: "What makes you an AI-powered marketing agency?", a: "Beyond the core marketing work, we offer AI add-ons built to capture leads around the clock: an AI phone receptionist that answers and books in English and Spanish, a website chat agent that qualifies visitors, lead follow-up designed to respond within seconds, and review automation. The goal is simple, stop letting leads slip through after hours." },
  { q: "Which Miami neighborhoods and cities do you serve?", a: "We serve all of Miami-Dade, including Brickell, Coral Gables, Doral, Hialeah, Kendall, Miami Beach, Wynwood, and Aventura. Ranking in Brickell is not the same as ranking in Hialeah, and we build each plan around how customers actually search in your specific area." },
];

// "How It Works". Three-step process that removes the what-happens-next friction.
const howSteps = [
  { n: "01", title: "We Audit What You Have", desc: "Tell us about your business. We review your Google presence, your reviews, your website, and what local competitors are doing, then send you a plain-English breakdown of where you stand. Free, no commitment." },
  { n: "02", title: "We Build Your Plan", desc: "You get a plan built for your market and your budget, not a template. We show you what we would do first, what it costs, and what it should move. You approve before any work starts." },
  { n: "03", title: "We Execute and Report", desc: "We do the work and send you a monthly report that ties every action to an outcome you care about: calls booked, reviews earned, rankings climbed. Month to month, cancel any time." },
];

// Three-up focus row for the intro section (skimmable, keyword-natural).
const focusPoints = [
  { title: "Get Found", desc: "We put you in the Google map pack and local search when someone nearby looks up your exact service, not three pages deep where nobody scrolls." },
  { title: "Get Chosen", desc: "More 5-star reviews, answered questions, and a complete Google Business Profile turn a search result into the obvious call over the business listed next to you." },
  { title: "Get Booked", desc: "A fast website, click to call, and AI follow-up that answers in seconds turn that lead into a booked job instead of a missed voicemail." },
];

// NOTE: LocalBusiness schema now lives in BaseLayout.astro as `businessSchema` and is emitted on every page.
// This homepage schema only carries the WebSite-level signal + the Organization shell (no duplicate LocalBusiness).
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://thryvmarketingsolutions.com/#organization",
      "name": "Thryv Marketing Solutions",
      "url": "https://thryvmarketingsolutions.com",
      "logo": { "@type": "ImageObject", "url": "https://thryvmarketingsolutions.com/logos/logo-trimmed.png" },
      "sameAs": ["https://twitter.com/thryvmarketing"]
    },
    {
      "@type": "WebSite",
      "@id": "https://thryvmarketingsolutions.com/#website",
      "url": "https://thryvmarketingsolutions.com",
      "name": "Thryv Marketing Solutions",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://thryvmarketingsolutions.com/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://thryvmarketingsolutions.com/#homefaq",
      "mainEntity": faqs.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};

const services = [
  { icon: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>`, title: 'Google Business Profile', desc: 'Show up in Google Maps before your competitors. Full listing management, posts, photos, and Q&A.', price: 'From $297/mo', slug: 'google-business-profile' },
  { icon: `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>`, title: 'Reputation Management', desc: 'More 5-star reviews on autopilot. Automated requests, monitoring, and response management.', price: 'From $297/mo', slug: 'reputation-management' },
  { icon: `<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>`, title: 'Local SEO', desc: 'Get found by customers searching your exact service in your exact neighborhood.', price: 'From $797/mo', slug: 'seo' },
  { icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`, title: 'Website Builds', desc: 'Clean, fast, mobile-first websites built to convert visitors into paying customers.', price: 'From $1,497', slug: 'website-design' },
  { icon: `<circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>`, title: 'Google Ads', desc: 'Search campaigns built for local intent. Paid search that gets you in front of ready buyers.', price: 'Ask about availability', slug: 'google-ads' },
  { icon: `<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>`, title: 'Social Media Ads', desc: 'Instagram and Facebook ads targeting people in your zip code before they ever search Google.', price: 'Ask about availability', slug: 'social-media-ads' },
];

const checkIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>`;

// AS SEEN IN. Flip to true ONLY after these directory listings are actually live and verifiable.
// Real targets from the citation research (thryv-citation-directory-list-2026-05-25). Do not show before live.
const showAsSeenIn = false;
const directories = [
  "Clutch", "Semrush Agency Directory", "UpCity", "GoodFirms", "DesignRush", "Google Partners",
];

// Flip to true once you have real client quotes. Section goes live instantly.
const showTestimonials = false;

const testimonials = [
  {
    quote: "",
    name: "",
    business: "",
    service: "",
    result: "",
  },
  {
    quote: "",
    name: "",
    business: "",
    service: "",
    result: "",
  },
  {
    quote: "",
    name: "",
    business: "",
    service: "",
    result: "",
  },
];
---

<BaseLayout
  title="Miami AI-Powered Growth Marketing Agency | Thryv Marketing Solutions"
  description="Miami AI-powered growth marketing agency. Local SEO, Google Ads, reputation management, and website builds for small operators. Month-to-month, no lock-ins. Free audit."
  canonical="https://thryvmarketingsolutions.com/"
  ogImage="https://thryvmarketingsolutions.com/og-home.jpg"
  schema={schema}
>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-content" data-experiment="hero-headline">
        <div class="hero-eyebrow">
          <span></span> Miami-Based Growth Marketing Agency
        </div>
        <h1>
          The Agency That Earns<br />
          Your Business<br />
          <em>Every Month.</em>
        </h1>
        <p class="hero-sub">
          No 12-month contracts. No hidden fees. No junior account managers.
          AI-powered local marketing with results you can see and billing you can cancel any time.
        </p>
        <div class="hero-actions">
          <a href="/contact/" class="btn btn-primary" data-experiment-cta="hero">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            Get Free Proposal
          </a>
          <a href="/pricing/" class="btn btn-outline" data-experiment-cta="hero">See Pricing</a>
        </div>
        <div class="hero-pills">
          <div class="hero-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            Month-to-month, always
          </div>
          <div class="hero-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            Monthly performance reports
          </div>
          <div class="hero-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            AI automation included
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-card">
          <div class="hero-card-label">What We Track</div>
          <div class="hero-card-metric" style="font-size:22px;line-height:1.3;">Rankings. Reviews. Revenue.</div>
          <div class="hero-card-sub" style="margin-top:6px;">Every report connects activity to outcomes, not vanity metrics.</div>
        </div>
        <div class="hero-cards-row">
          <div class="hero-card">
            <div class="hero-card-label">Billing</div>
            <div class="hero-card-metric">Month<br />-to-Month</div>
            <div class="hero-card-sub">No long contracts. Ever.</div>
          </div>
          <div class="hero-card">
            <div class="hero-card-label">Technology</div>
            <div class="hero-card-metric">AI-First</div>
            <div class="hero-card-sub">Automation that works while you sleep.</div>
          </div>
        </div>
        <div class="hero-card">
          <div class="hero-card-label">Our Promise</div>
          <div class="hero-card-metric" style="font-size:22px;line-height:1.3;">No lock-ins. No surprises. Cancel anytime.</div>
          <div class="hero-card-sub" style="margin-top:8px;">Unlike the big-agency model: we earn your business every month.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STATS BAR -->
<div class="stats-bar">
  <div class="container">
    <div class="stats-inner">
      <div class="stat-item">
        <div class="stat-num" data-target="6">6</div>
        <div class="stat-desc">Revenue-generating services</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">0</div>
        <div class="stat-desc">Lock-in contracts. Ever.</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">0</div>
        <div class="stat-desc">Hidden fees. Ever.</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">24/7</div>
        <div class="stat-desc">AI automation. Never clocks out.</div>
      </div>
    </div>
  </div>
</div>

<!-- LOCAL MARKETING INTRO (indexable body copy) -->
<section class="section intro-section">
  <div class="container">
    <div class="intro-head reveal">
      <div class="label">Local Marketing, Done Right</div>
      <h2>Marketing Built Around How Miami Customers Actually Find You</h2>
    </div>
    <div class="intro-body reveal reveal-delay-1">
      <p>When someone in Miami needs a plumber, a dentist, or a med spa, <strong>they rarely scroll past the first screen.</strong> They open Google, glance at the map, read a few reviews, and call one of the first names they trust. If your business is not in that short list, <strong>you stay invisible for the searches that matter most,</strong> no matter how good your work is.</p>
      <p>Thryv Marketing Solutions is built for that moment. We are a <strong>Miami-based, founder-led agency</strong> focused on the channels that put local businesses in front of ready buyers: your Google Business Profile, local SEO, your online reviews, a website that loads fast and converts, and paid search and social when the numbers make sense. <strong>No vanity metrics, and no bloated retainer</strong> for services you will never use.</p>
      <p>Most agencies make you sit through a sales call just to learn what they charge, then lock you into a year. <strong>We do the opposite.</strong> Every price is published on our pricing page, <strong>every plan is month to month,</strong> and every report ties the work we did to the outcomes you actually care about. You can read what it costs right now, and <strong>you can cancel any time.</strong></p>
      <p>We work fluently in <strong>English and Spanish,</strong> we know why ranking in Brickell looks different from ranking in Hialeah, and <strong>we treat your budget like it is real money, because it is.</strong> That is the difference between a partner who lives in your market and a national franchise running your account from a spreadsheet.</p>
    </div>
    <div class="intro-focus">
      {focusPoints.map((f, i) => (
        <div class={`intro-focus-card reveal reveal-delay-${i + 1}`}>
          <div class="intro-focus-dot"></div>
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SERVICES PREVIEW -->
<section class="section" id="services">
  <div class="container">
    <div class="section-head reveal">
      <div class="label">What We Do</div>
      <h2>Six Services. One Goal:<br />More Revenue for Your Business.</h2>
      <p class="lead">We focus only on the channels that generate real, measurable returns. No bloat. No upsells you don't need.</p>
    </div>
    <div class="services-grid">
      {services.map((s, i) => (
        <a href={`/services/${s.slug}/`} class={`service-card reveal reveal-delay-${(i % 3) + 1}`}>
          <div class="service-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" set:html={s.icon} />
          </div>
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
          <div class="service-footer">
            <div class="service-price">{s.price}</div>
            <span class="service-link">Learn more <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
          </div>
        </a>
      ))}
    </div>
    <div class="section-cta reveal">
      <a href="/services/" class="btn btn-blue">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        View All Services
      </a>
    </div>
  </div>
</section>

<!-- CONSULTING STRIP -->
<div class="consulting-strip">
  <div class="container">
    <div class="cs-inner">
      <p class="cs-text"><strong>Want strategy, not a retainer?</strong> Our consulting engagements give you a clear SEO or AI roadmap to execute yourself. One session, no monthly commitment.</p>
      <a href="/consulting/" class="cs-link">Explore Consulting <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
    </div>
  </div>
</div>

<!-- AI TOOLS PREVIEW -->
<section class="section ai-section" id="ai-services">
  <div class="container" style="position:relative;z-index:1;">
    <div class="section-head center ai-head reveal">
      <div class="label" style="background:rgba(27,79,168,.15);color:#7EB3FF;">AI-Powered Add-Ons</div>
      <h2>Marketing Automation<br />That Never Clocks Out</h2>
      <p class="lead center" style="color:rgba(255,255,255,.6);">AI tools that handle your calls, chats, follow-ups, and reviews around the clock, so you capture leads whether you're open or not.</p>
    </div>
    <div class="ai-teaser-grid">
      <div class="ai-teaser-card reveal reveal-delay-1">
        <div class="ai-badge">24/7 Coverage</div>
        <h3>AI Phone Receptionist</h3>
        <p>Answers inbound calls, qualifies leads, books appointments, and sends you a summary. In English and Spanish.</p>
      </div>
      <div class="ai-teaser-card reveal reveal-delay-2">
        <div class="ai-badge">Lead Capture</div>
        <h3>AI Website Chat Agent</h3>
        <p>A smart chat widget that qualifies visitors and routes hot leads to you via text or email, designed to run 24/7.</p>
      </div>
      <div class="ai-teaser-card reveal reveal-delay-3">
        <div class="ai-badge">Speed to Lead</div>
        <h3>AI Lead Follow-Up</h3>
        <p>Designed to respond to new leads within 60 seconds with personalized SMS and email. Speed-to-lead is the strongest predictor of conversion.</p>
      </div>
      <div class="ai-teaser-card reveal reveal-delay-4">
        <div class="ai-badge">Reputation</div>
        <h3>AI Review Automation</h3>
        <p>Sends review requests automatically based on triggers you set. Monitors Google, Yelp, and Facebook. Drafts responses for one-click approval.</p>
      </div>
    </div>
    <div class="ai-cta reveal">
      <a href="/ai/" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        Explore AI Automation Tools
      </a>
    </div>
  </div>
</section>

<!-- WHY THRYV -->
<section class="section why-section" id="why">
  <div class="container">
    <div class="section-head center why-head reveal">
      <div class="label" style="background:rgba(245,166,35,.15);color:var(--orange);">Why Thryv</div>
      <h2>We Do What the Big Agencies Won't</h2>
      <p class="lead center" style="color:rgba(255,255,255,.6);">Big national agencies hide their prices and lock you in for a year. We don't.</p>
    </div>
    <div class="why-grid">
      <div class="why-card reveal reveal-delay-1">
        <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <h3>No Hidden Fees</h3>
        <p>What you see is what you pay. No setup fees buried in the contract, no platform fees added later.</p>
        <div class="vs">vs. the big-agency model: hidden fees are standard</div>
      </div>
      <div class="why-card reveal reveal-delay-2">
        <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg></div>
        <h3>Month-to-Month Only</h3>
        <p>No 12-month contracts. No early termination fees. We earn your business every month.</p>
        <div class="vs">vs. the standard 12-month SEO lock-in</div>
      </div>
      <div class="why-card reveal reveal-delay-3">
        <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
        <h3>Reports You Can Actually Read</h3>
        <p>Plain-English updates that connect the work we did to the business outcomes you care about.</p>
        <div class="vs">vs. quarterly PDF reports nobody reads</div>
      </div>
      <div class="why-card reveal reveal-delay-4">
        <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg></div>
        <h3>Bilingual Service</h3>
        <p>We run campaigns, manage listings, and communicate fluently in English and Espa&ntilde;ol.</p>
        <div class="vs">vs. national agencies with no bilingual capability</div>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="section how-section" id="how-it-works">
  <div class="container">
    <div class="section-head center reveal">
      <div class="label">How It Works</div>
      <h2>Getting Started Takes<br />One Conversation</h2>
      <p class="lead center">No long onboarding and no runaround. Here is exactly what happens from the day you reach out.</p>
    </div>
    <div class="how-grid">
      {howSteps.map((s, i) => (
        <div class={`how-card reveal reveal-delay-${i + 1}`}>
          <div class="how-num">{s.n}</div>
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
    <div class="section-cta reveal">
      <a href="/contact/" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Start With a Free Proposal
      </a>
    </div>
  </div>
</section>

<!-- TESTIMONIALS (hidden until showTestimonials = true) -->
{showTestimonials && (
<section class="section testimonials-section">
  <div class="container">
    <div class="section-head center reveal">
      <div class="label">Client Results</div>
      <h2>What Miami Business Owners Say</h2>
    </div>
    <div class="testimonials-grid">
      {testimonials.map(t => (
        <div class="testimonial-card reveal">
          <div class="testimonial-result">{t.result}</div>
          <blockquote class="testimonial-quote">"{t.quote}"</blockquote>
          <div class="testimonial-footer">
            <div class="testimonial-name">{t.name}</div>
            <div class="testimonial-meta">{t.business} &middot; {t.service}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
)}

<!-- TRUST BAR -->
<section class="trust-bar">
  <div class="container">
    <div class="trust-inner">
      <div class="trust-label">Certified &amp; Trusted</div>
      <div class="trust-badges">
        <div class="trust-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
          <span>Google Ads Certified</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
          <span>Meta Blueprint Certified</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Month-to-Month Only. No Contracts.</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>Miami-Based, Founder-Led</span>
        </div>
      </div>
    </div>
  </div>
</section>

