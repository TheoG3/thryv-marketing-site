---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://thryvmarketingsolutions.com/#organization",
      "name": "Thryv Marketing Solutions",
      "url": "https://thryvmarketingsolutions.com",
      "logo": { "@type": "ImageObject", "url": "https://thryvmarketingsolutions.com/logos/logo-trimmed.png" },
      "sameAs": ["https://twitter.com/thryvmarketing"]
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://thryvmarketingsolutions.com/#localbusiness",
      "name": "Thryv Marketing Solutions",
      "description": "Miami-based growth marketing agency using AI automation, local SEO, and paid media to help businesses dominate their market. Month-to-month, no lock-ins.",
      "url": "https://thryvmarketingsolutions.com",
      "email": "hello@thryvmarketingsolutions.com",

      "priceRange": "$$",
      "address": { "@type": "PostalAddress", "addressLocality": "Miami", "addressRegion": "FL", "addressCountry": "US" },
      "areaServed": "United States",
      "serviceType": ["SEO","Google Business Profile Management","Google Ads","Website Design","Reputation Management","AI Marketing Automation"]
    },
    {
      "@type": "WebSite",
      "@id": "https://thryvmarketingsolutions.com/#website",
      "url": "https://thryvmarketingsolutions.com",
      "name": "Thryv Marketing Solutions"
    }
  ]
};

const services = [
  { icon: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>`, title: 'Google Business Profile', desc: 'Show up in Google Maps before your competitors. Full listing management, posts, photos, and Q&A.', price: 'From $199/mo', slug: 'google-business-profile' },
  { icon: `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>`, title: 'Reputation Management', desc: 'More 5-star reviews on autopilot. Automated requests, monitoring, and response management.', price: 'From $99/mo', slug: 'reputation-management' },
  { icon: `<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>`, title: 'Local SEO', desc: 'Get found by customers searching your exact service in your exact neighborhood.', price: 'From $999/mo', slug: 'local-seo' },
  { icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`, title: 'Website Builds', desc: 'Clean, fast, mobile-first websites built to convert visitors into paying customers.', price: 'From $2,500', slug: 'website-design' },
  { icon: `<circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>`, title: 'Google Ads', desc: 'Search campaigns built for local intent. Paid search that gets you in front of ready buyers.', price: 'Ask about availability', slug: 'google-ads' },
  { icon: `<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>`, title: 'Social Media Ads', desc: 'Instagram and Facebook ads targeting people in your zip code before they ever search Google.', price: 'Ask about availability', slug: 'social-media-ads' },
];

const checkIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>`;

// Flip to true once you have real client quotes — section goes live instantly
const showTestimonials = false;

const testimonials = [
  {
    quote: "",
    name: "",
    business: "",
    service: "",
    result: "",
  },
  {
    quote: "",
    name: "",
    business: "",
    service: "",
    result: "",
  },
  {
    quote: "",
    name: "",
    business: "",
    service: "",
    result: "",
  },
];
---

<BaseLayout
  title="Thryv Marketing Solutions | AI-Powered Growth Marketing Agency"
  description="Miami-based growth marketing agency. AI-powered local SEO, Google Ads, reputation management, and website builds. Month-to-month, no lock-ins. Free audit."
  canonical="https://thryvmarketingsolutions.com/"
  ogImage="https://thryvmarketingsolutions.com/og-home.jpg"
  schema={schema}
>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-content">
        <div class="hero-eyebrow">
          <span></span> Miami-Based Growth Marketing Agency
        </div>
        <h1>
          The Agency That Earns<br />
          Your Business<br />
          <em>Every Month.</em>
        </h1>
        <p class="hero-sub">
          No 12-month contracts. No hidden fees. No junior account managers.
          AI-powered local marketing with results you can see and billing you can cancel any time.
        </p>
        <div class="hero-actions">
          <a href="/contact/" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            Get Free Audit
          </a>
          <a href="/pricing/" class="btn btn-outline">See Pricing</a>
        </div>
        <div class="hero-pills">
          <div class="hero-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            Month-to-month, always
          </div>
          <div class="hero-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            Live results dashboard
          </div>
          <div class="hero-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            AI automation included
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-card">
          <div class="hero-card-label">What We Track</div>
          <div class="hero-card-metric" style="font-size:22px;line-height:1.3;">Rankings. Reviews. Revenue.</div>
          <div class="hero-card-sub" style="margin-top:6px;">Every report connects activity to outcomes, not vanity metrics.</div>
        </div>
        <div class="hero-cards-row">
          <div class="hero-card">
            <div class="hero-card-label">Billing</div>
            <div class="hero-card-metric">Month<br />-to-Month</div>
            <div class="hero-card-sub">No long contracts. Ever.</div>
          </div>
          <div class="hero-card">
            <div class="hero-card-label">Technology</div>
            <div class="hero-card-metric">AI-First</div>
            <div class="hero-card-sub">Automation that works while you sleep.</div>
          </div>
        </div>
        <div class="hero-card">
          <div class="hero-card-label">Our Promise</div>
          <div class="hero-card-metric" style="font-size:22px;line-height:1.3;">No lock-ins. No surprises. Cancel anytime.</div>
          <div class="hero-card-sub" style="margin-top:8px;">Unlike Scorpion, Hibu, and Podium: we earn your business every month.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STATS BAR -->
<div class="stats-bar">
  <div class="container">
    <div class="stats-inner">
      <div class="stat-item">
        <div class="stat-num" data-target="6">6</div>
        <div class="stat-desc">Revenue-generating services</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">0</div>
        <div class="stat-desc">Lock-in contracts. Ever.</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">0</div>
        <div class="stat-desc">Hidden fees. Ever.</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">24/7</div>
        <div class="stat-desc">AI automation. Never clocks out.</div>
      </div>
    </div>
  </div>
</div>

<!-- SERVICES PREVIEW -->
<section class="section" id="services">
  <div class="container">
    <div class="section-head reveal">
      <div class="label">What We Do</div>
      <h2>Six Services. One Goal:<br />More Revenue for Your Business.</h2>
      <p class="lead">We focus only on the channels that generate real, measurable returns. No bloat. No upsells you don't need.</p>
    </div>
    <div class="services-grid">
      {services.map((s, i) => (
        <a href={`/services/${s.slug}/`} class={`service-card reveal reveal-delay-${(i % 3) + 1}`}>
          <div class="service-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" set:html={s.icon} />
          </div>
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
          <div class="service-footer">
            <div class="service-price">{s.price}</div>
            <span class="service-link">Learn more <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
          </div>
        </a>
      ))}
    </div>
    <div class="section-cta reveal">
      <a href="/services/" class="btn btn-blue">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        View All Services
      </a>
    </div>
  </div>
</section>

<!-- AI TOOLS PREVIEW -->
<section class="section ai-section" id="ai-services">
  <div class="container" style="position:relative;z-index:1;">
    <div class="section-head center ai-head reveal">
      <div class="label" style="background:rgba(27,79,168,.15);color:#7EB3FF;">AI-Powered Add-Ons</div>
      <h2>Marketing Automation<br />That Never Clocks Out</h2>
      <p class="lead center" style="color:rgba(255,255,255,.6);">AI tools that handle your calls, chats, follow-ups, and reviews around the clock, so you capture leads whether you're open or not.</p>
    </div>
    <div class="ai-teaser-grid">
      <div class="ai-teaser-card reveal reveal-delay-1">
        <div class="ai-badge">24/7 Coverage</div>
        <h3>AI Phone Receptionist</h3>
        <p>Answers every inbound call, qualifies leads, books appointments, and sends you a summary. In English and Spanish.</p>
      </div>
      <div class="ai-teaser-card reveal reveal-delay-2">
        <div class="ai-badge">Lead Capture</div>
        <h3>AI Website Chat Agent</h3>
        <p>A smart chat widget that qualifies visitors and routes hot leads to you instantly via text or email, 24/7.</p>
      </div>
      <div class="ai-teaser-card reveal reveal-delay-3">
        <div class="ai-badge">Speed to Lead</div>
        <h3>AI Lead Follow-Up</h3>
        <p>Responds to new leads in under 60 seconds with personalized SMS and email. Most competitors take hours.</p>
      </div>
      <div class="ai-teaser-card reveal reveal-delay-4">
        <div class="ai-badge">Reputation</div>
        <h3>AI Review Automation</h3>
        <p>Auto-sends review requests after every job. Monitors Google, Yelp, and Facebook. Drafts responses for one-click approval.</p>
      </div>
    </div>
    <div class="ai-cta reveal">
      <a href="/ai-tools/" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        Explore AI Automation Tools
      </a>
    </div>
  </div>
</section>

<!-- WHY THRYV -->
<section class="section why-section" id="why">
  <div class="container">
    <div class="section-head center why-head reveal">
      <div class="label" style="background:rgba(245,166,35,.15);color:var(--orange);">Why Thryv</div>
      <h2>We Do What the Big Agencies Won't</h2>
      <p class="lead center" style="color:rgba(255,255,255,.6);">Scorpion, Hibu, and Podium hide their prices and lock you in for a year. We don't.</p>
    </div>
    <div class="why-grid">
      <div class="why-card reveal reveal-delay-1">
        <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <h3>No Hidden Fees</h3>
        <p>What you see is what you pay. No setup fees buried in the contract, no platform fees added later.</p>
        <div class="vs">vs. Hibu, Scorpion, Podium: all have hidden fees</div>
      </div>
      <div class="why-card reveal reveal-delay-2">
        <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg></div>
        <h3>Month-to-Month Only</h3>
        <p>No 12-month contracts. No early termination fees. We earn your business every month.</p>
        <div class="vs">vs. Scorpion's 12-month SEO lock-in</div>
      </div>
      <div class="why-card reveal reveal-delay-3">
        <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
        <h3>Reports You Can Actually Read</h3>
        <p>Plain-English updates that connect the work we did to the business outcomes you care about.</p>
        <div class="vs">vs. quarterly PDF reports nobody reads</div>
      </div>
      <div class="why-card reveal reveal-delay-4">
        <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg></div>
        <h3>Bilingual Service</h3>
        <p>We run campaigns, manage listings, and communicate fluently in English and Espa&ntilde;ol.</p>
        <div class="vs">vs. national agencies with no bilingual capability</div>
      </div>
    </div>
  </div>
</section>

<!-- TESTIMONIALS (hidden until showTestimonials = true) -->
{showTestimonials && (
<section class="section testimonials-section">
  <div class="container">
    <div class="section-head center reveal">
      <div class="label">Client Results</div>
      <h2>What Miami Business Owners Say</h2>
    </div>
    <div class="testimonials-grid">
      {testimonials.map(t => (
        <div class="testimonial-card reveal">
          <div class="testimonial-result">{t.result}</div>
          <blockquote class="testimonial-quote">"{t.quote}"</blockquote>
          <div class="testimonial-footer">
            <div class="testimonial-name">{t.name}</div>
            <div class="testimonial-meta">{t.business} &middot; {t.service}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
)}

<!-- TRUST BAR -->
<section class="trust-bar">
  <div class="container">
    <div class="trust-inner">
      <div class="trust-label">Certified &amp; Trusted</div>
      <div class="trust-badges">
        <div class="trust-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
          <span>Google Ads Certified</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
          <span>Meta Blueprint Certified</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Month-to-Month Only. No Contracts.</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>Miami-Based Team</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PRICING PREVIEW -->
<section class="section" id="pricing">
  <div class="container">
    <div class="section-head center reveal">
      <div class="label">Our Packages</div>
      <h2>Pricing You Can See<br />Without a Sales Call</h2>
      <p class="lead center">Three tiers. Month-to-month on all of them.</p>
    </div>
    <div class="pricing-preview-grid">
      <div class="price-preview-card reveal reveal-delay-1">
        <div class="price-tier">Starter</div>
        <div class="price-num">$297<span>/mo</span></div>
        <div class="price-period">Month-to-month &middot; No contracts</div>
        <ul class="ppf-list">
          <li>GBP setup and optimization</li>
          <li>Review request automation</li>
          <li>Review response management</li>
        </ul>
        <a href="/pricing/" class="btn btn-blue">See Full Package</a>
      </div>
      <div class="price-preview-card featured reveal reveal-delay-2">
        <div class="popular-badge">Most Popular</div>
        <div class="price-tier">Growth</div>
        <div class="price-num">$797<span>/mo</span></div>
        <div class="price-period">Month-to-month &middot; No contracts</div>
        <ul class="ppf-list">
          <li>Everything in Starter</li>
          <li>Local SEO: on-page and citations</li>
          <li>Monthly strategy call</li>
        </ul>
        <a href="/pricing/" class="btn btn-primary">See Full Package</a>
      </div>
      <div class="price-preview-card reveal reveal-delay-3">
        <div class="price-tier">Pro</div>
        <div class="price-num">$1,497<span>/mo</span></div>
        <div class="price-period">Month-to-month &middot; No contracts</div>
        <ul class="ppf-list">
          <li>Everything in Growth</li>
          <li>Google Ads management</li>
          <li>Instagram and Facebook Ads</li>
        </ul>
        <a href="/pricing/" class="btn btn-blue">See Full Package</a>
      </div>
    </div>
    <div class="section-cta reveal">
      <a href="/pricing/" class="btn btn-outline-dark">
        Compare All Packages in Detail
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- ABOUT PREVIEW -->
<section class="section" id="about" style="background:var(--light);">
  <div class="container">
    <div class="about-preview-grid">
      <div class="about-preview-image reveal">
        <div class="founder-photo-wrap">
          <img src="/founder-theodore-grimes.jpg" alt="Theodore Grimes, Founder of Thryv Marketing Solutions" style="width:100%;height:100%;object-fit:cover;display:block;" />
        </div>
        <div class="founder-creds">
          <span class="founder-cred">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
            Google Ads Certified
          </span>
          <span class="founder-cred">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
            Meta Blueprint Certified
          </span>
        </div>
      </div>
      <div class="about-preview-content reveal reveal-delay-2">
        <div class="label">Meet the Founder</div>
        <h2>Built Because Local Businesses Deserve Better</h2>
        <p>I started Thryv because I kept watching great local businesses get buried by competitors who weren't better. Just better marketed. A big agency charges a big retainer, assigns a junior account manager, and delivers a quarterly report that says "impressions are up."</p>
        <p>Every client works directly with me. Every strategy is built from scratch for your market, your competition, and your goals.</p>
        <div class="founder-quote">"Most agencies sell deliverables. I sell outcomes. That one distinction changes every decision we make."</div>
        <a href="/about/" class="btn btn-blue" style="margin-top:28px;">
          Meet the Team
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- FREE TOOLS PREVIEW -->
<section class="section tools-preview-section" id="tools">
  <div class="container">
    <div class="section-head center reveal">
      <div class="label">Free Tools</div>
      <h2>See Where You Stand Right Now</h2>
      <p class="lead center">Two free tools. No email required. Get real numbers on your reviews and Google Business Profile in under a minute.</p>
    </div>
    <div class="tools-preview-grid">
      <div class="tool-preview-card reveal reveal-delay-1">
        <div class="tool-preview-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <div class="tool-preview-body">
          <h3>Review Rating Calculator</h3>
          <p>Find out exactly how many 5-star reviews you need to hit your target rating on Google. Instant results.</p>
          <a href="/free-tools/" class="tool-link">
            Try the calculator
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
      <div class="tool-preview-card reveal reveal-delay-2">
        <div class="tool-preview-icon" style="background:rgba(245,166,35,.12);border-color:rgba(245,166,35,.3);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="color:#F5A623;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div class="tool-preview-body">
          <h3>Google Business Profile Scorer</h3>
          <p>Check off what you have set up. Get scored out of 100 and see exactly where you're leaving customers on the table.</p>
          <a href="/free-tools/" class="tool-link">
            Score my profile
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section class="section contact-section" id="contact">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info reveal">
        <div class="label" style="background:rgba(245,166,35,.15);color:var(--orange);">Free Audit</div>
        <h2>Let's See What You're Missing.</h2>
        <p class="lead">Tell us about your business. We'll review your local presence and send you a plain-English breakdown. No charge. No pressure.</p>
        <p style="margin-top:14px;font-size:15px;font-weight:600;color:var(--orange);">Prefieres en Espa&ntilde;ol? Esc&iacute;benos, hablamos con gusto.</p>
        <div class="contact-details" style="margin-top:40px;">
          <div class="contact-detail">
            <div class="contact-detail-icon">
