---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://thryvmarketingsolutions.com/#organization",
      "name": "Thryv Marketing Solutions",
      "url": "https://thryvmarketingsolutions.com",
      "logo": { "@type": "ImageObject", "url": "https://thryvmarketingsolutions.com/logos/logo-trimmed.png" },
      "sameAs": ["https://twitter.com/thryvmarketing"]
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://thryvmarketingsolutions.com/#localbusiness",
      "name": "Thryv Marketing Solutions",
      "description": "Miami-based growth marketing agency using AI automation, local SEO, and paid media to help businesses dominate their market. Month-to-month, no lock-ins.",
      "url": "https://thryvmarketingsolutions.com",
      "telephone": "+13055550100",
      "email": "hello@thryvmarketingsolutions.com",
      "priceRange": "$$",
      "address": { "@type": "PostalAddress", "addressLocality": "Miami", "addressRegion": "FL", "addressCountry": "US" },
      "openingHoursSpecification": { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "09:00", "closes": "19:00" },
      "areaServed": "United States",
      "serviceType": ["Local SEO","Google Business Profile Management","Google Ads","Website Design","Reputation Management","AI Marketing Automation"]
    },
    {
      "@type": "WebSite",
      "@id": "https://thryvmarketingsolutions.com/#website",
      "url": "https://thryvmarketingsolutions.com",
      "name": "Thryv Marketing Solutions"
    },
    {
      "@type": "WebPage",
      "@id": "https://thryvmarketingsolutions.com/",
      "url": "https://thryvmarketingsolutions.com/",
      "name": "Thryv Marketing Solutions | AI-Powered Growth Marketing Agency",
      "description": "Thryv Marketing Solutions is a Miami-based growth marketing agency using AI automation, local SEO, and paid media to help businesses dominate their market.",
      "isPartOf": { "@id": "https://thryvmarketingsolutions.com/#website" },
      "publisher": { "@id": "https://thryvmarketingsolutions.com/#organization" }
    }
  ]
};

const checkIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>`;
---

<BaseLayout
  title="Thryv Marketing Solutions | AI-Powered Growth Marketing Agency"
  description="Thryv Marketing Solutions is a Miami-based growth marketing agency using AI automation, local SEO, and paid media to help businesses dominate their market. Month-to-month. No lock-ins."
  canonical="https://thryvmarketingsolutions.com/"
  schema={schema}
>

<a href="#main-content" class="skip-link">Skip to main content</a>

<!-- NAV -->
<nav>
  <div class="container">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Thryv Marketing Solutions">
        <img src="/logos/logo-trimmed.png" alt="Thryv Marketing Solutions" />
      </a>
      <ul class="nav-links">
        <li><a href="#services">Services</a></li>
        <li><a href="#ai-services">AI Tools</a></li>
        <li><a href="#tools">Free Tools</a></li>
        <li><a href="#pricing">Pricing</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
      <div class="nav-cta">
        <a href="#contact" class="btn btn-blue">Get Free Audit</a>
        <button class="hamburger" id="hamburger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobileMenu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>
</nav>

<main id="main-content">

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Navigation menu">
  <a href="#services" class="mobile-link">Services</a>
  <a href="#ai-services" class="mobile-link">AI Tools</a>
  <a href="#tools" class="mobile-link">Free Tools</a>
  <a href="#pricing" class="mobile-link">Pricing</a>
  <a href="#about" class="mobile-link">About</a>
  <a href="/blog/" class="mobile-link">Blog</a>
  <a href="#contact" class="mobile-link">Contact</a>
  <a href="#contact" class="btn btn-primary">Get Free Audit</a>
</div>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-content">
        <div class="hero-eyebrow">
          <span></span> Miami-Based Growth Marketing Agency
        </div>
        <h1>
          The Agency That Earns<br />
          Your Business<br />
          <em>Every Month.</em>
        </h1>
        <p class="hero-sub">
          No 12-month contracts. No hidden fees. No junior account managers.
          AI-powered local marketing (SEO, Google Ads, reviews, and automation) with results you can see and billing you can cancel any time.
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            Get Free Audit
          </a>
          <a href="#pricing" class="btn btn-outline">See Pricing</a>
        </div>
        <div class="hero-pills">
          <div class="hero-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            Month-to-month, always
          </div>
          <div class="hero-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            Live results dashboard
          </div>
          <div class="hero-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            AI automation included
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-card">
          <div class="hero-card-label">What We Track</div>
          <div class="hero-card-metric" style="font-size:22px;line-height:1.3;">Rankings. Reviews. Revenue.</div>
          <div class="hero-card-sub" style="margin-top:6px;">Every report connects activity to outcomes, not vanity metrics.</div>
        </div>
        <div class="hero-cards-row">
          <div class="hero-card">
            <div class="hero-card-label">Billing</div>
            <div class="hero-card-metric">Month<br />-to-Month</div>
            <div class="hero-card-sub">No long contracts. Ever.</div>
          </div>
          <div class="hero-card">
            <div class="hero-card-label">Technology</div>
            <div class="hero-card-metric">AI-First</div>
            <div class="hero-card-sub">Automation that works while you sleep.</div>
          </div>
        </div>
        <div class="hero-card">
          <div class="hero-card-label">Our Promise</div>
          <div class="hero-card-metric" style="font-size:22px;line-height:1.3;">No lock-ins. No surprises. Cancel anytime.</div>
          <div class="hero-card-sub" style="margin-top:8px;">Unlike Scorpion, Hibu, and Podium: we earn your business every month.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STATS BAR -->
<div class="stats-bar">
  <div class="container">
    <div class="stats-inner">
      <div class="stat-item">
        <div class="stat-num" data-target="6">6</div>
        <div class="stat-desc">Revenue-generating services</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">0</div>
        <div class="stat-desc">Lock-in contracts. Ever.</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">0</div>
        <div class="stat-desc">Hidden fees. Ever.</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">24/7</div>
        <div class="stat-desc">AI automation. Never clocks out.</div>
      </div>
    </div>
  </div>
</div>

<!-- SERVICES -->
<section class="section" id="services">
  <div class="container">
    <div class="section-head reveal">
      <div class="label">What We Do</div>
      <h2>Six Services. One Goal:<br />More Revenue for Your Business.</h2>
      <p class="lead">We focus only on the channels that generate real, measurable returns. No bloat. No upsells you don't need.</p>
    </div>
    <div class="services-grid">

      <div class="service-card reveal reveal-delay-1">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3>Google Business Profile</h3>
        <p>Show up in Google Maps before your competitors do. We handle every part of your listing (posts, photos, Q&amp;A) so Google has every reason to rank you first.</p>
        <div class="service-price">From $199/mo</div>
      </div>

      <div class="service-card reveal reveal-delay-2">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <h3>Reputation Management</h3>
        <p>More 5-star reviews, on autopilot. We send requests after every job, monitor Google and Yelp, and handle responses so your rating keeps climbing without you chasing anyone.</p>
        <div class="service-price">From $99/mo</div>
      </div>

      <div class="service-card reveal reveal-delay-3">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </div>
        <h3>Local SEO</h3>
        <p>Get found by customers searching your exact service in your exact neighborhood. Rankings that build over time: the longer we work together, the harder it pays off.</p>
        <div class="service-price">From $999/mo</div>
      </div>

      <div class="service-card reveal reveal-delay-1">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
        </div>
        <h3>Website Builds &amp; Fixes</h3>
        <p>Clean, fast, mobile-first websites built to convert. Whether you need a fresh site or a broken one fixed, we deliver results without the agency markup.</p>
        <div class="service-price">From $2,500 one-time</div>
      </div>

      <div class="service-card reveal reveal-delay-2">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
        </div>
        <h3>Google Ads Management</h3>
        <p>Search campaigns built for local intent. When organic alone isn't enough, paid search gets you in front of buyers actively looking for what you offer.</p>
        <div class="service-price">Ask about availability</div>
      </div>

      <div class="service-card reveal reveal-delay-3">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </div>
        <h3>Social Media Ads</h3>
        <p>Put your business in front of people in your zip code before they ever search Google. Instagram and Facebook ads that build name recognition and generate direct inquiries.</p>
        <div class="service-price">Ask about availability</div>
      </div>

    </div>
  </div>
</section>

<!-- AI SERVICES -->
<section class="section ai-section" id="ai-services">
  <div class="container" style="position:relative;z-index:1;">
    <div class="section-head center ai-head reveal">
      <div class="label" style="background:rgba(27,79,168,.15);color:#7EB3FF;">AI-Powered Add-Ons</div>
      <h2>Marketing Automation<br />That Never Clocks Out</h2>
      <p class="lead center" style="color:rgba(255,255,255,.6);">AI tools that handle your calls, chats, follow-ups, and reviews around the clock, so you capture leads whether you're open or not.</p>
    </div>
    <div class="ai-grid">

      <div class="ai-card reveal reveal-delay-1">
        <div class="ai-badge">⚡ 24/7 Coverage</div>
        <div class="ai-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.5a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .84h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16l.01-.08z"/></svg>
        </div>
        <h3>AI Phone Receptionist</h3>
        <p>Never miss a call. Our AI voice agent answers inbound calls, qualifies leads with smart questions, books appointments directly into your calendar, and sends you a summary. All without lifting a finger.</p>
        <div class="ai-features">
          <div class="ai-feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>Answers calls in English &amp; Spanish</div>
          <div class="ai-feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>Books appointments to your calendar</div>
          <div class="ai-feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>Sends you a call summary via SMS</div>
        </div>
      </div>

      <div class="ai-card reveal reveal-delay-2">
        <div class="ai-badge">💬 Lead Capture</div>
        <div class="ai-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        </div>
        <h3>AI Website Chat Agent</h3>
        <p>A smart chat widget that lives on your site and works 24/7: qualifying visitors, answering common questions, and routing hot leads to you instantly via text or email. More conversations, more booked jobs.</p>
        <div class="ai-features">
          <div class="ai-feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>Qualifies visitors before they bounce</div>
          <div class="ai-feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>Instant lead alerts via text</div>
          <div class="ai-feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>Fully branded to your business</div>
        </div>
      </div>

      <div class="ai-card reveal reveal-delay-3">
        <div class="ai-badge">🚀 Speed to Lead</div>
        <div class="ai-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3>AI Lead Follow-Up</h3>
        <p>The moment a new lead comes in (from your website, GMB, or ads) an automated sequence fires off: instant SMS, personalized email, and a follow-up if they don't respond. Most competitors take hours. You respond in seconds.</p>
        <div class="ai-features">
          <div class="ai-feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>Responds in under 60 seconds</div>
          <div class="ai-feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>Automated SMS + email sequences</div>
          <div class="ai-feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>Works across all lead sources</div>
        </div>
      </div>

      <div class="ai-card reveal reveal-delay-4">
        <div class="ai-badge">⭐ Reputation</div>
        <div class="ai-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <h3>AI Review Automation</h3>
        <p>After every job or appointment, your AI automatically sends a review request via SMS. When reviews come in (on Google, Yelp, or anywhere else) it drafts a thoughtful response for you to approve in one click.</p>
        <div class="ai-features">
          <div class="ai-feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>Auto-sends review requests post-service</div>
          <div class="ai-feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>Monitors Google, Yelp, Facebook</div>
          <div class="ai-feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>AI-drafted responses, you approve</div>
        </div>
      </div>

    </div>
    <div class="ai-cta reveal">
      <a href="#contact" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Add AI Automation to Your Package
      </a>
      <p>Ask about AI tools when you request your free audit.</p>
    </div>
  </div>
</section>

<!-- WHY THRYV -->
<section class="section why-section" id="why">
  <div class="container">
    <div class="section-head center why-head reveal">
      <div class="label" style="background:rgba(245,166,35,.15);color:var(--orange);">Why Thryv</div>
      <h2>We Do What the Big Agencies Won't</h2>
      <p class="lead center" style="color:rgba(255,255,255,.6);">Scorpion, Hibu, and Podium hide their prices and lock you in for a year. We don't.</p>
    </div>
    <div class="why-grid">
      <div class="why-card reveal reveal-delay-1">
        <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <h3>No Hidden Fees</h3>
        <p>What you see is what you pay. No setup fees buried in the contract, no "platform fees" added later, no surprise invoices.</p>
        <div class="vs">vs. Hibu, Scorpion, Podium: all have hidden fees</div>
      </div>
      <div class="why-card reveal reveal-delay-2">
        <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg></div>
        <h3>Month-to-Month Only</h3>
        <p>No 12-month contracts. No early termination fees. No proprietary CMS that makes switching painful. We earn your business every month.</p>
        <div class="vs">vs. Scorpion's 12-month SEO lock-in</div>
      </div>
      <div class="why-card reveal reveal-delay-3">
        <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
        <h3>Reports You Can Actually Read</h3>
        <p>No jargon-heavy PDFs buried in a portal. We send plain-English updates that connect the work we did to the business outcomes you care about.</p>
        <div class="vs">vs. quarterly PDF reports nobody reads</div>
      </div>
      <div class="why-card reveal reveal-delay-4">
        <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg></div>
        <h3>Bilingual Service</h3>
        <p>Reaching Spanish-speaking customers is a competitive advantage most agencies miss. We run campaigns, manage listings, and communicate fluently in English and Español.</p>
        <div class="vs">vs. national agencies with no bilingual capability</div>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="section how-section">
  <div class="container">
    <div class="section-head center reveal">
      <div class="label">The Process</div>
      <h2>Up and Running in 5 Business Days</h2>
      <p class="lead center">Three steps. No complexity. Most clients see their first results before they've had time to second-guess the decision.</p>
    </div>
    <div class="steps-grid">
      <div class="step-card reveal reveal-delay-1">
        <div class="step-num">1</div>
        <h3>Free Audit</h3>
        <p>We review your GMB, website, local rankings, and reputation. You get a plain-English breakdown of what's costing you customers. No charge. No obligation.</p>
      </div>
      <div class="step-card reveal reveal-delay-2">
        <div class="step-num">2</div>
        <h3>Custom Plan</h3>
        <p>We recommend only the services that fit your goals and budget. No bloated packages. You pick what makes sense. We show you the ROI projection first.</p>
      </div>
      <div class="step-card reveal reveal-delay-3">
        <div class="step-num">3</div>
        <h3>Launch &amp; Grow</h3>
        <p>We go live within 5 business days. You get a live dashboard to track results. Monthly reports in plain English: what changed and what it's worth.</p>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section class="section" id="pricing">
  <div class="container">
    <div class="section-head center reveal">
      <div class="label">Our Packages</div>
      <h2>Pricing You Can See<br />Without a Sales Call</h2>
      <p class="lead center">Three tiers. Month-to-month on all of them. Pick what fits your goals right now and scale when you're ready.</p>
    </div>
    <div class="pricing-grid">

      <div class="price-card reveal reveal-delay-1">
        <div class="price-tier">Starter</div>
        <div class="price-num">$299<span>/mo</span></div>
        <div class="price-period">Month-to-month · Cancel anytime</div>
        <div class="price-desc">Build the foundation your business runs on. Google Maps, reviews, and a profile that earns trust before a prospect ever calls.</div>
        <div class="price-divider"></div>
        <div class="price-features">
          <div class="price-feature"><Fragment set:html={checkIcon} />GMB full setup &amp; optimization</div>
          <div class="price-feature"><Fragment set:html={checkIcon} />4 Google posts per month</div>
          <div class="price-feature"><Fragment set:html={checkIcon} />Review request automation</div>
          <div class="price-feature"><Fragment set:html={checkIcon} />Review response management</div>
          <div class="price-feature"><Fragment set:html={checkIcon} />Monthly performance report</div>
        </div>
        <a href="#contact" class="btn btn-blue">Claim My Free Audit</a>
      </div>

      <div class="price-card featured reveal reveal-delay-2">
        <div class="popular-badge">Most Popular</div>
        <div class="price-tier">Growth</div>
        <div class="price-num">$1,199<span>/mo</span></div>
        <div class="price-period">Month-to-month · Cancel anytime</div>
        <div class="price-desc">Everything in Starter, plus local SEO that compounds over time. The package most clients start with and never leave.</div>
        <div class="price-divider"></div>
