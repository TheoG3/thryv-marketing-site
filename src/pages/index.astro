    .how-grid { grid-template-columns: 1fr; }
    .pricing-preview-grid { grid-template-columns: 1fr; }
    .price-preview-card.featured { transform: none; }
    .about-preview-grid { grid-template-columns: 1fr; gap: 48px; }
    .about-preview-image { display: none; }
    .tools-preview-grid { grid-template-columns: 1fr; }
    .tool-preview-card { flex-direction: column; }
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important; }
    .reveal { opacity: 1; transform: none; }
    .hero-eyebrow, .hero h1, .hero-sub, .hero-actions, .hero-pills, .hero-visual > .hero-card, .hero-visual .hero-cards-row { opacity: 1; transform: none; animation: none; }
  }
</style>

<script>
  // Scroll reveal
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, { threshold: 0.12 });
  revealEls.forEach(el => observer.observe(el));

  // Counter animation
  const counters = document.querySelectorAll('.stat-num[data-target]');
  const counterObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target as HTMLElement;
      const target = parseInt(el.dataset.target || '0');
      let start: number | null = null;
      const tick = (ts: number) => {
        if (!start) start = ts;
        const progress = Math.min((ts - start) / 1200, 1);
        const ease = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(ease * target).toString();
        if (progress < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
      counterObs.unobserve(el);
    });
  }, { threshold: 0.6 });
  counters.forEach(c => counterObs.observe(c));

  // Hero float after entrance
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    setTimeout(() => {
      const heroVisual = document.querySelector('.hero-visual');
      if (heroVisual) {
        const cards = heroVisual.querySelectorAll(':scope > .hero-card');
        const row = heroVisual.querySelector('.hero-cards-row');
        if (cards[0]) cards[0].classList.add('hero-float');
        if (row) row.classList.add('hero-float-mid');
        if (cards[1]) cards[1].classList.add('hero-float-last');
      }
    }, 900);
  }
</script>

<!-- A/B Test: homepage-hero-headline (PostHog feature flag) -->
<script is:inline>
  (function () {
    var FLAG_KEY = 'homepage-hero-headline';
    var VARIANTS = {
      variant: {
        h1: "Miami's Honest Marketing Agency.<br />Month-to-Month.<br /><em>No Lock-Ins.</em>",
        sub: "Local SEO, Google Ads, and AI automation, billed monthly and cancellable anytime. No 12-month contracts, no hidden fees, no junior account managers."
      }
    };

    function applyVariant(variantKey) {
      if (!variantKey || variantKey === 'control') return;
      var v = VARIANTS[variantKey];
      if (!v) return;
      var scope = document.querySelector('[data-experiment="hero-headline"]');
      if (!scope) return;
      var h1 = scope.querySelector('h1');
      var sub = scope.querySelector('.hero-sub');
      if (h1 && v.h1) h1.innerHTML = v.h1;
      if (sub && v.sub) sub.textContent = v.sub;
    }

    function whenPostHogReady(fn) {
      var tries = 0;
      var iv = setInterval(function () {
        if (window.posthog && typeof window.posthog.onFeatureFlags === 'function') {
          clearInterval(iv);
          window.posthog.onFeatureFlags(fn);
        } else if (++tries > 100) {
          clearInterval(iv);
          fn('control');
        }
      }, 50);
    }

    whenPostHogReady(function () {
      var variantKey = 'control';
      try {
        variantKey = window.posthog.getFeatureFlag(FLAG_KEY) || 'control';
      } catch (e) {}
      applyVariant(variantKey);
      try {
        var props = {};
        props['$feature/' + FLAG_KEY] = variantKey;
        window.posthog.register(props);
        window.posthog.capture('experiment_viewed', {
          experiment: FLAG_KEY,
          variant: variantKey
        });
      } catch (e) {}
    });

    document.addEventListener('click', function (e) {
      var cta = e.target.closest ? e.target.closest('[data-experiment-cta="hero"]') : null;
      if (!cta || !window.posthog) return;
      var variantKey = 'control';
      try {
        variantKey = window.posthog.getFeatureFlag(FLAG_KEY) || 'control';
      } catch (err) {}
      window.posthog.capture('hero_cta_click', {
        experiment: FLAG_KEY,
        variant: variantKey,
        cta_text: (cta.textContent || '').trim(),
        cta_href: cta.getAttribute('href')
      });
    });
  })();
</script>

