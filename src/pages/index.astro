  /* ── AS SEEN IN ──────────────────────────── */
  .as-seen-in { background: var(--white); border-bottom: 1px solid var(--border); padding: 26px 0; }
  .asi-inner { display: flex; align-items: center; gap: 28px; flex-wrap: wrap; justify-content: center; }
