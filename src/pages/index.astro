  /* ── HOME FAQ ────────────────────────────── */
  .faq-home-section { background: var(--white); }
  .faq-home-list { max-width: 780px; margin: 8px auto 0; display: flex; flex-direction: column; gap: 12px; }
  .faq-home-item { background: var(--light); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; transition: border-color .2s, box-shadow .2s, background .2s; }
  .faq-home-item[open] { border-color: var(--blue); box-shadow: 0 4px 20px rgba(27,79,168,.08); background: var(--white); }
  .faq-home-item summary { display: flex; align-items: center; justify-content: space-between; gap: 16px; cursor: pointer; padding: 19px 24px; font-size: 16px; font-weight: 700; color: var(--dark); list-style: none; }
  .faq-home-item summary::-webkit-details-marker { display: none; }
  .faq-home-item summary svg { width: 20px; height: 20px; color: var(--blue); flex-shrink: 0; transition: transform .25s; }
  .faq-home-item[open] summary svg { transform: rotate(180deg); }
  .faq-home-answer { padding: 0 24px 22px; }
  .faq-home-answer p { font-size: 15px; line-height: 1.75; color: var(--gray); margin: 0; }

  /* ── ANIMATIONS ──────────────────────────── */
  @keyframes heroFadeUp { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes heroScaleIn { from { opacity: 0; transform: translateY(16px) scale(.97); } to { opacity: 1; transform: translateY(0) scale(1); } }
  @keyframes heroFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
  .hero-float     { animation: heroFloat 4.5s ease-in-out infinite; will-change: transform; }
  .hero-float-mid { animation: heroFloat 5s ease-in-out .65s infinite; will-change: transform; }
  .hero-float-last { animation: heroFloat 4s ease-in-out 1.3s infinite; will-change: transform; }

  /* ── RESPONSIVE ──────────────────────────── */
  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .ai-teaser-grid { grid-template-columns: repeat(2, 1fr); }
    .why-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 768px) {
    .section { padding: 64px 0; }
    .hero-grid { grid-template-columns: 1fr; gap: 48px; }
    .hero-visual { display: none; }
    .stats-inner { grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .stat-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,.1); padding: 12px; }
    .stat-item:nth-child(odd) { border-right: 1px solid rgba(255,255,255,.1); }
    .stat-item:last-child, .stat-item:nth-last-child(2):nth-child(odd) { border-bottom: none; }
    .services-grid { grid-template-columns: 1fr; }
    .ai-teaser-grid { grid-template-columns: 1fr; }
    .why-grid { grid-template-columns: 1fr; }
