---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",     "item": "https://thryvmarketingsolutions.com/" },
    { "@type": "ListItem", "position": 2, "name": "AI", "item": "https://thryvmarketingsolutions.com/ai/" }
  ]
};
---

<BaseLayout
  title="AI Automation for Miami Businesses | Thryv Marketing Solutions"
  description="AI tools that handle review responses, lead follow-up, monthly reporting, and GBP posting automatically. Starting at $297/mo. Included in Growth and Pro plans."
  canonical="https://thryvmarketingsolutions.com/ai/"
  schema={schema}
>

  <section class="ai-hero">
    <div class="container">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Home</a><span aria-hidden="true"> › </span><span>AI Tools</span>
      </nav>
      <span class="label">AI Automation</span>
      <h1>AI Tools That Work While You Do</h1>
      <p class="lead">Four automations that handle the repetitive marketing work so your team can focus on customers. Each one is controlled by you and approved before anything goes out.</p>
      <div class="hero-ctas">
        <a href="/contact/" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Get a Free AI Audit
        </a>
        <a href="/pricing/" class="btn btn-ghost">See Pricing</a>
      </div>
    </div>
  </section>

  <section class="section tools-section">
    <div class="container">
      <div class="section-head center">
        <span class="label">The Tools</span>
        <h2>Four Automations. One Less Thing to Worry About.</h2>
      </div>
      <div class="tools-grid">
        <div class="tool-card reveal">
          <span class="tool-icon">💬</span>
          <h3>Review Response Bot</h3>
          <p>Auto-drafts personalized responses to every new Google review. Tone matches your brand voice. You approve before anything posts.</p>
          <div class="tool-benefit">Never leave a review unanswered</div>
        </div>
        <div class="tool-card reveal">
          <span class="tool-icon">⚡</span>
          <h3>Lead Follow-Up Sequences</h3>
          <p>When a new lead fills out your form, an AI-powered SMS and email sequence follows up instantly and keeps following up until they respond.</p>
          <div class="tool-benefit">Convert more leads without more effort</div>
        </div>
        <div class="tool-card reveal">
          <span class="tool-icon">📊</span>
          <h3>Monthly Report Generator</h3>
          <p>Pulls your GBP, ads, and SEO data and generates a plain-English performance summary every month, automatically, before your strategy call.</p>
          <div class="tool-benefit">Spend less time in spreadsheets</div>
        </div>
        <div class="tool-card reveal">
          <span class="tool-icon">📅</span>
          <h3>GBP Post Scheduler</h3>
          <p>Generates and schedules Google Business Profile posts weekly based on your services, promotions, and seasonal topics.</p>
          <div class="tool-benefit">Stay active on Google without the work</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section steps-section">
    <div class="container">
      <div class="section-head center">
        <span class="label">How It Works</span>
        <h2>Up and Running in Days, Not Weeks</h2>
      </div>
      <div class="steps-row">
        <div class="step-card reveal">
          <div class="step-num">01</div>
          <h3>Connect Your Accounts</h3>
          <p>We link your Google Business Profile, ads accounts, and website analytics.</p>
        </div>
        <div class="step-card reveal">
          <div class="step-num">02</div>
          <h3>Choose Your Tools</h3>
          <p>Start with one automation or enable the full suite. You pick what fits.</p>
        </div>
        <div class="step-card reveal">
          <div class="step-num">03</div>
          <h3>Review and Approve</h3>
          <p>Nothing posts or sends without your sign-off. You stay in control.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section pricing-note">
    <div class="container">
      <div class="pricing-card reveal">
        <div class="pricing-copy">
          <span class="label label-orange">Pricing</span>
          <h2>Starting at $297/mo</h2>
          <p class="lead">AI automation is included in our Growth ($797/mo) and Pro ($1,497/mo) plans. It is also available as a standalone add-on.</p>
          <a href="/pricing/" class="btn btn-blue" style="margin-top:24px;">View Full Pricing</a>
        </div>
        <div class="pricing-includes">
          <div class="inc-row"><span>Review Response Bot</span><span class="inc-check">✓</span></div>
          <div class="inc-row"><span>Lead Follow-Up Sequences</span><span class="inc-check">✓</span></div>
          <div class="inc-row"><span>Monthly Report Generator</span><span class="inc-check">✓</span></div>
          <div class="inc-row"><span>GBP Post Scheduler</span><span class="inc-check">✓</span></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section contact-section">
    <div class="container">
      <div class="contact-split">
        <div class="reveal">
          <span class="label">Free AI Integration Audit</span>
          <h2>Not Sure If AI Can Help Your Business?</h2>
          <p class="lead" style="margin-bottom:24px;">We will look at your current workflow and tell you exactly where AI saves time, what tools fit your situation, and what is not worth your attention. No pitch, no commitment.</p>
        </div>
        <ContactForm title="Get a Free AI Integration Audit" subject="Free AI Integration Audit Request | Thryv" serviceDefault="ai" />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .ai-hero { padding: 80px 0 64px; background: linear-gradient(135deg, var(--blue-deeper) 0%, var(--blue) 100%); color: var(--white); }
  .ai-hero .label { background: rgba(255,255,255,.15); color: var(--white); }
  .ai-hero h1 { font-size: clamp(36px, 5vw, 56px); font-weight: 800; line-height: 1.1; letter-spacing: -.02em; margin: 16px 0; color: var(--white); max-width: 600px; }
  .ai-hero .lead { color: rgba(255,255,255,.8); max-width: 520px; margin-bottom: 32px; }
  .breadcrumb { display: flex; align-items: center; gap: 4px; font-size: 13px; color: rgba(255,255,255,.6); margin-bottom: 24px; }
  .breadcrumb a { color: rgba(255,255,255,.6); }
  .breadcrumb a:hover { color: var(--white); }
  .hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-ghost { background: rgba(255,255,255,.15); color: var(--white); padding: 14px 24px; border-radius: 100px; font-weight: 700; font-size: 15px; transition: background .2s; display: inline-flex; align-items: center; }
  .btn-ghost:hover { background: rgba(255,255,255,.25); }

  .tools-section { background: var(--white); }
  .tools-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .tool-card { background: var(--light); border: 1.5px solid var(--border); border-radius: var(--radius-lg); padding: 36px; }
  .tool-icon { font-size: 44px; display: block; margin-bottom: 16px; }
  .tool-card h3 { font-size: 20px; font-weight: 800; color: var(--dark); margin-bottom: 12px; }
  .tool-card p { font-size: 15px; line-height: 1.7; color: var(--gray); margin-bottom: 20px; }
  .tool-benefit { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 700; color: var(--blue); background: var(--blue-light); padding: 6px 14px; border-radius: 100px; }
  .tool-benefit::before { content: '→'; }

  .steps-section { background: var(--light); }
  .steps-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .step-card { text-align: center; padding: 32px 24px; background: var(--white); border-radius: var(--radius-lg); border: 1.5px solid var(--border); }
  .step-num { font-size: 48px; font-weight: 800; color: var(--border); line-height: 1; margin-bottom: 16px; }
  .step-card h3 { font-size: 18px; font-weight: 800; color: var(--dark); margin-bottom: 10px; }
  .step-card p { font-size: 14px; line-height: 1.7; color: var(--gray); }

  .pricing-note { background: var(--white); }
  .pricing-card { background: linear-gradient(135deg, var(--blue-deeper) 0%, var(--blue) 100%); border-radius: var(--radius-lg); padding: 48px; display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
  .pricing-card h2 { color: var(--white); }
  .pricing-card .lead { color: rgba(255,255,255,.8); }
  .pricing-card .label { background: rgba(255,255,255,.15); color: var(--white); }
  .pricing-includes { background: rgba(255,255,255,.1); border-radius: var(--radius); padding: 24px; }
  .inc-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,.1); font-size: 14px; color: rgba(255,255,255,.9); }
  .inc-row:last-child { border-bottom: none; }
  .inc-check { color: #4ade80; font-weight: 800; font-size: 16px; }

  .contact-section { background: var(--light); }
  .contact-split { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }

  .reveal { opacity: 0; transform: translateY(24px); transition: opacity .55s ease, transform .55s ease; }
  .reveal.visible { opacity: 1; transform: none; }

  @media (max-width: 900px) {
    .tools-grid { grid-template-columns: 1fr; }
    .steps-row { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
    .pricing-card { grid-template-columns: 1fr; }
    .contact-split { grid-template-columns: 1fr; gap: 40px; }
  }
</style>

<script>
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>
