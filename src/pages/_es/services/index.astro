---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const services = [
  { slug: 'google-business-profile', icon: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>`, title: 'Google Business Profile', desc: 'Aparece cuando los clientes locales buscan. Optimizamos y gestionamos tu GBP cada mes.', price: '$297/mes' },
  { slug: 'reputation-management',   icon: `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>`, title: 'Gestión de Reputación', desc: 'Más reseñas de 5 estrellas, respuestas profesionales y una calificación que genera confianza.', price: '$297/mes' },
  { slug: 'seo',                     icon: `<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>`, title: 'SEO, AEO y GEO', desc: 'Posiciónate en Google, Maps, resúmenes de IA y sé citado por ChatGPT y Perplexity.', price: '$797/mes' },
  { slug: 'website-design',          icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`, title: 'Diseño Web', desc: 'Sitios web rápidos y optimizados para móvil, construidos para convertir visitantes en llamadas y prospectos.', price: 'Desde $1,497' },
  { slug: 'google-ads',              icon: `<circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>`, title: 'Google Ads', desc: 'Campañas de búsqueda gestionadas que te ponen frente a clientes listos para comprar.', price: '$597/mes + inversión' },
  { slug: 'social-media-ads',        icon: `<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>`, title: 'Anuncios en Instagram y Facebook', desc: 'Campañas sociales dirigidas que construyen reconocimiento de marca y generan tráfico local.', price: '$497/mes + inversión' },
];
---

<BaseLayout
  title="Servicios de Marketing para Negocios en Miami | Thryv"
  description="SEO local, Google Ads, gestión de reputación y diseño web. Todo mes a mes, sin contratos. Equipo basado en Miami listo para hacer crecer tu negocio."
  canonical="https://thryvmarketingsolutions.com/es/services/"
  ogImage="https://thryvmarketingsolutions.com/og-services.jpg"
  lang="es"
>

  <section class="hero-services">
    <div class="container">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/es/">Inicio</a><span aria-hidden="true"> › </span><span>Servicios</span>
      </nav>
      <span class="label">Lo que Hacemos</span>
      <h1>Servicios de Marketing para Negocios en Miami</h1>
      <p class="lead">Seis servicios enfocados. Mes a mes. Sin permanencias. Cada compromiso comienza con una auditoría gratis para saber exactamente qué moverá la aguja para ti.</p>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="services-grid reveal">
        {services.map(s => (
          <a href={`/services/${s.slug}/`} class="svc-card">
            <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" set:html={s.icon} /></div>
            <h3 class="svc-title">{s.title}</h3>
            <p class="svc-desc">{s.desc}</p>
            <div class="svc-foot">
              <span class="svc-price">{s.price}</span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="consulting-strip">
    <div class="container">
      <div class="cs-inner">
        <p class="cs-text"><strong>¿No estás listo para externalizar?</strong> Nuestras consultorías te dan un plan claro de SEO o IA para ejecutar tú mismo. Una sesión, sin retención requerida.</p>
        <a href="/consulting/" class="cs-link">Explorar Consultoría <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      </div>
    </div>
  </div>

  <section class="section mtm-section">
    <div class="container">
      <div class="mtm-inner">
        <div class="mtm-copy reveal">
          <span class="label">Nuestra Promesa</span>
          <h2>Sin Contratos. Sin Sorpresas.</h2>
          <p class="lead">La mayoría de agencias te encierran por 12 meses, lleguen o no los resultados. Nosotros nos ganamos tu negocio cada mes entregando trabajo que se refleja en tus números.</p>
          <ul class="check-list">
            <li>Acuerdos mes a mes en cada servicio</li>
            <li>Cancela cuando quieras con 30 días de aviso</li>
            <li>Sin tarifas ocultas de configuración</li>
            <li>Un punto de contacto dedicado, no un centro de llamadas</li>
          </ul>
          <a href="/es/contact/" class="btn btn-primary" style="margin-top:32px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            Obtener Mi Auditoría Gratis
          </a>
        </div>
        <div class="badges reveal">
          <div class="badge-card">
            <div class="badge-num">30</div>
            <div class="badge-lbl">Días de aviso para cancelar</div>
          </div>
          <div class="badge-card">
            <div class="badge-num">0</div>
            <div class="badge-lbl">Contratos a largo plazo</div>
          </div>
          <div class="badge-card">
            <div class="badge-num">0</div>
            <div class="badge-lbl">Tarifas ocultas</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container">
      <div class="section-head center"><h2>Preguntas Frecuentes sobre Nuestros Servicios</h2></div>
      <div class="faq-list">
        <details class="faq-item reveal"><summary>¿Necesito firmar un contrato a largo plazo?</summary><p>No. Todos los servicios de Thryv Marketing Solutions son mes a mes. Puedes cancelar con 30 días de aviso en cualquier momento.</p></details>
        <details class="faq-item reveal"><summary>¿Cuándo veré resultados?</summary><p>Para Google Business Profile y gestión de reputación, la mayoría de clientes nota mejoras en los primeros 60 días. SEO y anuncios típicamente muestran resultados significativos en 90 días.</p></details>
        <details class="faq-item reveal"><summary>¿Trabajan con negocios fuera de Miami?</summary><p>Estamos basados en Miami y nos especializamos en los mercados del sur de Florida, pero trabajamos con negocios en todo el país que quieren un enfoque de crecimiento local primero.</p></details>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero-services { padding: 72px 0 56px; background: linear-gradient(135deg, var(--blue-deeper) 0%, var(--blue) 100%); color: var(--white); }
  .hero-services .label { background: rgba(255,255,255,.15); color: var(--white); }
  .hero-services h1 { font-size: clamp(28px, 4.5vw, 48px); font-weight: 800; line-height: 1.1; letter-spacing: -.02em; margin: 16px 0; color: var(--white); max-width: 680px; }
  .hero-services .lead { color: rgba(255,255,255,.8); max-width: 560px; font-size: 17px; line-height: 1.7; }
  .breadcrumb { display: flex; align-items: center; gap: 4px; font-size: 13px; color: rgba(255,255,255,.55); margin-bottom: 20px; }
  .breadcrumb a { color: rgba(255,255,255,.55); } .breadcrumb a:hover { color: var(--white); }

  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; padding-top: 48px; }
  .svc-card { display: flex; flex-direction: column; background: var(--white); border: 1.5px solid var(--border); border-radius: var(--radius-lg); padding: 28px; text-decoration: none; color: inherit; transition: box-shadow .2s, transform .2s, border-color .2s; }
  .svc-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); border-color: var(--blue); }
  .svc-icon { width: 48px; height: 48px; border-radius: 12px; background: var(--blue-light); display: flex; align-items: center; justify-content: center; margin-bottom: 18px; }
  .svc-icon svg { width: 24px; height: 24px; stroke: var(--blue); }
  .svc-title { font-size: 17px; font-weight: 800; color: var(--dark); margin-bottom: 10px; }
  .svc-desc { font-size: 14px; line-height: 1.65; color: var(--gray); flex: 1; margin-bottom: 20px; }
  .svc-foot { display: flex; align-items: center; justify-content: space-between; margin-top: auto; }
  .svc-price { font-size: 13px; font-weight: 700; color: var(--blue); background: var(--blue-light); border-radius: 100px; padding: 4px 12px; }
  .svc-foot svg { stroke: var(--blue); }

  .consulting-strip { background: var(--blue-light); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 18px 0; }
  .cs-inner { display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .cs-text { font-size: 15px; color: var(--dark); line-height: 1.5; }
  .cs-text strong { color: var(--blue); font-weight: 700; }
  .cs-link { display: inline-flex; align-items: center; gap: 6px; font-size: 14px; font-weight: 700; color: var(--blue); white-space: nowrap; flex-shrink: 0; transition: opacity .2s; }
  .cs-link:hover { opacity: .7; }

  .mtm-section { background: var(--light); }
  .mtm-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .mtm-copy .label { margin-bottom: 12px; }
  .mtm-copy h2 { margin-bottom: 16px; }
  .mtm-copy .lead { margin-bottom: 28px; }
  .check-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .check-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 15px; color: var(--dark); font-weight: 500; }
  .check-list li::before { content: '✓'; color: var(--blue); font-weight: 800; flex-shrink: 0; }
  .badges { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .badge-card { background: var(--white); border: 1.5px solid var(--border); border-radius: var(--radius-lg); padding: 28px 20px; text-align: center; }
  .badge-num { font-size: 40px; font-weight: 800; color: var(--blue); line-height: 1; margin-bottom: 8px; }
  .badge-lbl { font-size: 13px; color: var(--gray); line-height: 1.4; }

  .faq-section { background: var(--white); }
  .faq-list { max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; gap: 12px; }
  .faq-item { border: 1.5px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .faq-item summary { padding: 18px 24px; font-size: 16px; font-weight: 700; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; color: var(--dark); }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; font-size: 20px; font-weight: 400; color: var(--blue); transition: transform .2s; }
  .faq-item[open] summary::after { transform: rotate(45deg); }
  .faq-item p { padding: 0 24px 18px; font-size: 15px; line-height: 1.7; color: var(--gray); margin: 0; }

  .reveal { opacity: 0; transform: translateY(24px); transition: opacity .55s ease, transform .55s ease; }
  .reveal.visible { opacity: 1; transform: none; }

  @media (max-width: 1024px) { .services-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 768px) {
    .services-grid { grid-template-columns: 1fr; }
    .mtm-inner { grid-template-columns: 1fr; gap: 40px; }
    .badges { grid-template-columns: 1fr; }
  }
</style>

<script>
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>
