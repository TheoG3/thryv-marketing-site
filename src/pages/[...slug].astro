---
import BaseLayout from '../layouts/BaseLayout.astro';
import pagesData from '../data/pages.json';

export async function getStaticPaths() {
  return pagesData.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;

// ── Display name maps ────────────────────────────────────────────────
const serviceLabel: Record<string, string> = {
  'GBP Management':        'Google Business Profile Management',
  'Local SEO':             'Local SEO',
  'Google Ads':            'Google Ads Management',
  'Reputation Management': 'Reputation Management',
  'Social Media Ads':      'Social Media Advertising',
  'Website Design':        'Website Design & Development',
  'AI Automation':         'AI Marketing Automation',
};

const serviceDir: Record<string, string> = {
  'GBP Management':        'gbp',
  'Local SEO':             'seo',
  'Google Ads':            'ads',
  'Reputation Management': 'reputation',
  'Social Media Ads':      'social-ads',
  'Website Design':        'web-design',
  'AI Automation':         'ai',
};

const nicheLabel: Record<string, string> = {
  'Plumbing':                     'Plumbers',
  'HVAC':                         'HVAC Companies',
  'Dental':                       'Dental Practices',
  'Roofing':                      'Roofing Companies',
  'Electricians':                 'Electricians',
  'Lawyers':                      'Law Firms',
  'Real Estate':                  'Real Estate Agents',
  'Restaurants':                  'Restaurants',
  'Landscaping':                  'Landscaping Companies',
  'Pest Control':                 'Pest Control Companies',
  'Moving Companies':             'Moving Companies',
  'General Contractors':          'General Contractors',
  'Auto Repair':                  'Auto Repair Shops',
  'Cleaning Services':            'Cleaning Services',
  'Hair Salons & Beauty':         'Hair Salons',
  'Gyms & Fitness':               'Gyms & Fitness Studios',
  'Chiropractors':                'Chiropractors',
  'Veterinary & Pet Care':        'Veterinarians',
  'Retail':                       'Retail Stores',
  'Multiple':                     'Local Businesses',
  'Painting':                     'Painting Contractors',
  'Flooring':                     'Flooring Companies',
  'Kitchen & Bath Remodeling':    'Kitchen & Bath Remodelers',
  'Impact Windows & Doors':       'Impact Window Companies',
  'Fencing':                      'Fencing Contractors',
  'Pool & Spa':                   'Pool & Spa Companies',
  'Pressure Washing':             'Pressure Washing Companies',
  'Solar':                        'Solar Installers',
  'Concrete & Masonry':           'Concrete & Masonry Contractors',
  'Drywall & Interiors':          'Drywall Contractors',
  '40-Year Recertification':      'Building Recertification Companies',
  'Structural Engineering':       'Structural Engineering Firms',
  'Concrete Restoration':         'Concrete Restoration Contractors',
  'Facade & Balcony Repair':      'Facade & Balcony Repair Contractors',
  'Wind Mitigation Inspection':   'Wind Mitigation Inspectors',
  'Building Permit Expediting':   'Permit Expediting Services',
  'Waterproofing':                'Waterproofing Contractors',
  'Condo & HOA Consulting':       'Condo & HOA Consultants',
  'Roof Certification':           'Roof Certification Inspectors',
  'Building Code Compliance':     'Building Code Compliance Consultants',
  'Elevator Inspection':          'Elevator Inspection Companies',
  'Commercial Painting':          'Commercial Painting Contractors',
  'Balcony Waterproofing':        'Balcony Waterproofing Contractors',
  'Building Inspection':          'Building Inspection Companies',
  'Condo Reserve Study':          'Reserve Study Consultants',
};

const nicheWord: Record<string, string> = {
  'Plumbing':                     'plumbing',
  'HVAC':                         'HVAC',
  'Dental':                       'dental',
  'Roofing':                      'roofing',
  'Electricians':                 'electrical',
  'Lawyers':                      'legal',
  'Real Estate':                  'real estate',
  'Restaurants':                  'restaurant',
  'Landscaping':                  'landscaping',
  'Pest Control':                 'pest control',
  'Moving Companies':             'moving',
  'General Contractors':          'contracting',
  'Auto Repair':                  'auto repair',
  'Cleaning Services':            'cleaning',
  'Hair Salons & Beauty':         'salon',
  'Gyms & Fitness':               'fitness',
  'Chiropractors':                'chiropractic',
  'Veterinary & Pet Care':        'veterinary',
  'Retail':                       'retail',
  'Multiple':                     'local',
  'Painting':                     'painting',
  'Flooring':                     'flooring',
  'Kitchen & Bath Remodeling':    'remodeling',
  'Impact Windows & Doors':       'impact window',
  'Fencing':                      'fencing',
  'Pool & Spa':                   'pool',
  'Pressure Washing':             'pressure washing',
  'Solar':                        'solar',
  'Concrete & Masonry':           'concrete',
  'Drywall & Interiors':          'drywall',
  '40-Year Recertification':      'recertification',
  'Structural Engineering':       'structural engineering',
  'Concrete Restoration':         'concrete restoration',
  'Facade & Balcony Repair':      'facade repair',
  'Wind Mitigation Inspection':   'wind mitigation',
  'Building Permit Expediting':   'permit expediting',
  'Waterproofing':                'waterproofing',
  'Condo & HOA Consulting':       'condo association',
  'Roof Certification':           'roof certification',
  'Building Code Compliance':     'code compliance',
  'Elevator Inspection':          'elevator',
  'Commercial Painting':          'commercial painting',
  'Balcony Waterproofing':        'balcony waterproofing',
  'Building Inspection':          'building inspection',
  'Condo Reserve Study':          'reserve study',
};

// ── Service-specific hero copy ───────────────────────────────────────
type HeroCopyFn = (niche: string, loc: string) => string;
const heroCopy: Record<string, HeroCopyFn> = {
  'GBP Management':        (n, l) => `Your ${nicheWord[n] || 'local'} business shows up first on Google Maps in ${l}. We manage every detail so you don't have to.`,
  'Local SEO':             (n, l) => `${nicheLabel[n] || 'Local businesses'} in ${l} that rank higher get more calls. We build the rankings that compound month after month.`,
  'Google Ads':            (n, l) => `Get in front of ${l} customers the moment they search for ${nicheWord[n] || 'local'} services. Paid search built for local intent.`,
  'Reputation Management': (n, l) => `More 5-star reviews for your ${nicheWord[n] || 'local'} business in ${l}. Automated, consistent, and fully compliant.`,
  'Social Media Ads':      (n, l) => `Put your ${nicheWord[n] || 'local'} business in front of ${l} residents before they ever search Google. Social ads that build recognition and generate calls.`,
  'Website Design':        (n, l) => `A fast, conversion-built website for ${nicheLabel[n] || 'local businesses'} in ${l}. Done in weeks. Built to rank and built to close.`,
  'AI Automation':         (n, l) => `AI that answers calls, captures leads, and follows up 24/7 for your ${nicheWord[n] || 'local'} business in ${l}. Never miss a job again.`,
};

// ── Service features (3 per service) ────────────────────────────────
const features: Record<string, string[]> = {
  'GBP Management':        ['Full profile setup and optimization across every field Google ranks', 'Weekly posts, Q&A management, and photo updates to stay active', 'Monthly reporting on calls, views, and direction requests from your listing'],
  'Local SEO':             ['On-page optimization targeting your exact service area keywords', 'Citation building across 60+ local directories for consistent NAP signals', 'Google Maps strategy with neighborhood-level targeting for your top service areas'],
  'Google Ads':            ['Search campaigns built around high-intent local keywords in your service area', 'Location targeting and bid adjustments by neighborhood and time of day', 'Conversion tracking tied to calls and form fills, not just clicks'],
  'Reputation Management': ['Automated review requests via SMS after every completed job', 'Real-time monitoring across Google, Yelp, and Facebook', 'Drafted responses for every review — you approve, we post'],
  'Social Media Ads':      ['Radius-targeted campaigns on Instagram and Facebook in your service area', 'Creative built around your services, reviews, and local credibility', 'Lead generation ads that capture name, phone, and service needed'],
  'Website Design':        ['Mobile-first, fast-loading sites built to convert local visitors into callers', 'Local SEO baked in from day one: schema, page speed, heading structure', 'Fixed-price builds with no ongoing license fees or platform lock-in'],
  'AI Automation':         ['AI phone receptionist that answers, qualifies, and books in English and Spanish', 'Website chat agent that captures leads and alerts you via text instantly', 'Automated follow-up sequences that respond to new leads in under 60 seconds'],
};

// ── FAQs (5 per service) ─────────────────────────────────────────────
type FAQFn = (niche: string, loc: string) => { q: string; a: string }[];
const faqs: Record<string, FAQFn> = {
  'GBP Management': (n, l) => [
    { q: `Why does Google Business Profile matter for ${nicheLabel[n] || 'local businesses'} in ${l}?`, a: `Google Maps is where most ${nicheWord[n] || 'local'} customers in ${l} make their decision. A fully optimized profile ranks higher, shows more trust signals, and converts more views into calls than a bare-bones listing.` },
    { q: `What does monthly GBP management include?`, a: `Full profile optimization, keyword-rich business description, weekly Google Posts, photo uploads, Q&A monitoring, review response support, and monthly reporting on calls, views, and direction requests.` },
    { q: `How soon will I see results from GBP optimization?`, a: `Most clients see movement in 30 to 60 days. Google Maps ranking factors update frequently, and consistent activity (posts, photos, Q&A) compounds over time. The business that stays active wins.` },
    { q: `Do you optimize for Spanish-language searches in ${l}?`, a: `Yes. Miami and South Florida have significant Spanish-speaking search volume that most agencies ignore. We optimize your profile and posts for both English and Spanish queries.` },
    { q: `Is there a long-term contract?`, a: `No. All packages are month-to-month. You can cancel any time. We earn your business every month by delivering results, not by locking you in.` },
  ],
  'Local SEO': (n, l) => [
    { q: `How long does local SEO take for ${nicheLabel[n] || 'local businesses'} in ${l}?`, a: `Most clients see meaningful Google Maps movement within 60 to 90 days. Competitive areas like Brickell and Coral Gables can take 3 to 5 months to crack the top 3. Rankings compound: work done in month 1 keeps paying in month 12.` },
    { q: `What does local SEO include?`, a: `Google Business Profile optimization, on-page website optimization, local citation building across 60+ directories, neighborhood keyword targeting, review generation automation, and monthly plain-English reporting.` },
    { q: `How much does local SEO cost in ${l}?`, a: `Our Growth package starts at $1,199/month. No setup fees, no contracts, cancel anytime. Most ${l} businesses see positive ROI within 90 days based on call volume increase.` },
    { q: `Do you target Spanish-language searches in ${l}?`, a: `Yes. Miami-area Spanish searches have high volume and lower competition than English equivalents. We optimize for both and target bilingual queries your competitors miss.` },
    { q: `What makes your approach different from other SEO agencies?`, a: `We focus exclusively on local businesses in competitive markets. No national playbooks, no junior account managers. Your strategy is built for your exact neighborhood, your actual competitors, and the customers searching your service area.` },
  ],
  'Google Ads': (n, l) => [
    { q: `How quickly can Google Ads generate calls for my ${nicheWord[n] || 'local'} business in ${l}?`, a: `Campaigns go live within 5 business days. You can receive calls on day one. The first 30 days are a refinement period where we tighten targeting, pause wasted spend, and optimize bids from real conversion data.` },
    { q: `What keywords do you target for ${nicheLabel[n] || 'local businesses'} in ${l}?`, a: `High-intent local keywords: service + city, service + neighborhood, emergency terms, and Spanish-language searches where CPCs are often lower and competition is thinner.` },
    { q: `How much ad budget do I need to start?`, a: `We recommend a minimum of $1,000/month in ad spend for the ${l} market. Our management fee is separate and billed monthly with no contract.` },
    { q: `Do you manage Google Local Services Ads too?`, a: `Yes. We manage both traditional search campaigns and Google Local Services Ads (LSA) depending on your service type and budget. LSAs often deliver the lowest cost per lead for home service businesses.` },
    { q: `Can I pause or cancel if I get too busy?`, a: `Yes, any time. No long-term contracts, no penalties. We have had clients pause during slow seasons and reactivate when they need volume again.` },
  ],
  'Reputation Management': (n, l) => [
    { q: `How does automated review generation work for ${nicheLabel[n] || 'local businesses'}?`, a: `After each completed job or appointment, our system sends a personalized SMS or email asking the customer to leave a Google review. The timing and message are optimized for response rate. You get more reviews without chasing anyone manually.` },
    { q: `How fast can my Google rating improve?`, a: `Businesses averaging 5 to 10 new jobs per week typically see noticeable rating improvement within 30 to 60 days once automation is running.` },
    { q: `What happens when I get a negative review?`, a: `We monitor all review platforms in real time. When a negative review comes in, you get an instant alert. We draft a professional response for you to approve and coach on whether escalation or resolution is the right move.` },
    { q: `Which platforms do you monitor?`, a: `Google, Yelp, Facebook, and industry-specific platforms. For ${nicheLabel[n] || 'local businesses'} in ${l}, Google and Yelp are the highest priority, but we set alerts everywhere your customers leave feedback.` },
    { q: `Do you buy or incentivize reviews?`, a: `No. All review generation is compliant with Google and Yelp guidelines. We only ask real customers who have experienced your service. Fake or incentivized reviews create legal and platform risk. We do not offer them.` },
  ],
  'Social Media Ads': (n, l) => [
    { q: `Why run social ads for a ${nicheWord[n] || 'local'} business in ${l}?`, a: `Social ads put your business in front of ${l} residents before they have a problem. When they do need a ${nicheWord[n] || 'local'} service, they call the name they recognize. Brand presence in a hyperlocal radius is one of the most underused advantages in local marketing.` },
    { q: `What does a typical social campaign look like?`, a: `A 3 to 5 mile radius campaign on Instagram and Facebook targeting your core demographics. Creative built around trust signals: reviews, before/after results, and local credibility. We test two to three creative variants per month.` },
    { q: `How much should I budget for social ads in ${l}?`, a: `We recommend a minimum of $600/month in ad spend. Our management fee covers creative production, targeting setup, monthly optimization, and reporting.` },
    { q: `How soon will I see results?`, a: `Brand awareness builds over 60 to 90 days. Lead generation campaigns with direct call or form CTAs can generate inquiries within the first two weeks of launch.` },
    { q: `Is there a contract?`, a: `No. Month-to-month, cancel anytime. We stop earning your business the month we stop delivering results.` },
  ],
  'Website Design': (n, l) => [
    { q: `What does a website build for a ${nicheWord[n] || 'local'} business include?`, a: `Custom design, mobile-first development, local SEO foundation (schema markup, page speed optimization, heading structure), contact form with spam protection, Google Analytics setup, and on-page content written for your service and market.` },
    { q: `How long does a build take?`, a: `Standard sites deliver in 3 to 4 weeks. More complex sites with multiple service areas take 5 to 7 weeks. We set expectations in a kick-off call before any work begins.` },
    { q: `Will my site rank on Google after the build?`, a: `A well-built site with proper SEO foundation will outperform a template site significantly. For serious ranking results, pair the build with our Local SEO package. The site creates the foundation; ongoing SEO builds the traffic.` },
    { q: `Do you use templates or build custom?`, a: `We use Astro and Tailwind: modern tools that produce fast, custom-looking sites at fixed prices. Your site will not look like a template and will load faster than competitors using WordPress page builders.` },
    { q: `What happens after the site launches?`, a: `We offer optional $299/month maintenance covering hosting, security updates, content edits, and monthly performance checks. No lock-in, month-to-month.` },
  ],
  'AI Automation': (n, l) => [
    { q: `What AI tools do you offer for ${nicheLabel[n] || 'local businesses'} in ${l}?`, a: `AI phone receptionist (answers calls, qualifies leads, books appointments), website chat agent (captures and routes leads 24/7), automated follow-up sequences (SMS and email within 60 seconds of lead submission), and AI review automation.` },
    { q: `How does the AI phone receptionist work?`, a: `A voice AI answers your inbound calls when you are unavailable, asks qualifying questions, collects customer info, and can book appointments directly into your calendar. You get a text summary of every call. It speaks both English and Spanish.` },
    { q: `Will it sound robotic to my customers?`, a: `Modern AI voice is significantly more natural than it was a few years ago. We configure the voice, tone, and script to match your brand. Customers are told upfront they are speaking with an AI assistant for your business.` },
    { q: `How fast is the lead follow-up automation?`, a: `Under 60 seconds from lead submission to first contact. Response time is the single biggest factor in converting inbound leads. Most ${nicheWord[n] || 'local'} competitors take hours or days.` },
    { q: `Is there a long-term contract for AI tools?`, a: `No. AI automation tools are billed month-to-month. Add or remove them from your package any time.` },
  ],
};

// ── Derive values ────────────────────────────────────────────────────
const svc   = page.service;
const niche = page.niche;
const loc   = page.location;

const svcName    = serviceLabel[svc]  || svc;
const nicheName  = nicheLabel[niche]  || niche;
const nicheWord2 = nicheWord[niche]   || 'local';
const hero       = (heroCopy[svc] || (() => `${svcName} for ${nicheName} in ${loc}`))(niche, loc);
const pageFeatures = features[svc] || ['Full setup and ongoing optimization', 'Monthly strategy and reporting', 'Month-to-month, no contracts'];
const pageFaqs   = (faqs[svc] || (() => []))(niche, loc);
const svcDirSlug = serviceDir[svc] || 'services';

const title      = `${svcName} for ${nicheName} in ${loc} | Thryv Marketing Solutions`;
const metaDesc   = `${hero} Month-to-month, no lock-ins. Miami-based agency serving ${loc}.`;
const canonical  = `https://thryvmarketingsolutions.com/${page.slug}`;

// Related pages — same service OR same location (max 6)
const related = pagesData
  .filter(p => p.slug !== page.slug && (p.service === svc || p.location === loc))
  .slice(0, 6);

// Schema
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",      "item": "https://thryvmarketingsolutions.com/" },
        { "@type": "ListItem", "position": 2, "name": "Services",  "item": "https://thryvmarketingsolutions.com/#services" },
        { "@type": "ListItem", "position": 3, "name": svcName,     "item": `https://thryvmarketingsolutions.com/services/${svcDirSlug}/` },
        { "@type": "ListItem", "position": 4, "name": `${nicheName} in ${loc}`, "item": canonical }
      ]
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": title,
      "description": metaDesc,
      "isPartOf": { "@id": "https://thryvmarketingsolutions.com/#website" },
      "publisher": { "@id": "https://thryvmarketingsolutions.com/#organization" },
      "breadcrumb": { "@id": `${canonical}#breadcrumb` }
    },
    {
      "@type": "Service",
      "name": `${svcName} for ${nicheName} in ${loc}`,
      "provider": { "@type": "Organization", "@id": "https://thryvmarketingsolutions.com/#organization" },
      "areaServed": { "@type": "City", "name": loc, "addressRegion": "FL" },
      "description": metaDesc,
      "url": canonical
    },
    ...(pageFaqs.length ? [{
      "@type": "FAQPage",
      "mainEntity": pageFaqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }] : [])
  ]
};

const chk = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:18px;height:18px;color:var(--blue);flex-shrink:0;margin-top:2px"><path d="M20 6L9 17l-5-5"/></svg>`;
---

<BaseLayout title={title} description={metaDesc} canonical={canonical} schema={schema}>

<a href="#main-content" class="skip-link">Skip to main content</a>

<!-- NAV -->
<nav>
  <div class="container">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Thryv Marketing Solutions">
        <img src="/logos/logo-trimmed.webp" alt="Thryv Marketing Solutions" />
      </a>
      <ul class="nav-links">
        <li><a href="/#services">Services</a></li>
        <li><a href="/#pricing">Pricing</a></li>
        <li><a href="/#about">About</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
      <div class="nav-cta">
        <a href="#contact" class="btn btn-blue">Get Free Audit</a>
        <button class="hamburger" id="hamburger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobileMenu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>
</nav>

<main id="main-content">

<div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Navigation menu">
  <a href="/#services" class="mobile-link">Services</a>
  <a href="/#pricing" class="mobile-link">Pricing</a>
  <a href="/#about" class="mobile-link">About</a>
  <a href="/blog/" class="mobile-link">Blog</a>
  <a href="#contact" class="mobile-link">Contact</a>
  <a href="#contact" class="btn btn-primary">Get Free Audit</a>
</div>

<!-- BREADCRUMB -->
<nav aria-label="Breadcrumb" style="background:var(--light);border-bottom:1px solid var(--border);padding:14px 0;">
  <div class="container">
    <ol style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--gray);list-style:none;flex-wrap:wrap;">
      <li><a href="/" style="color:var(--blue);font-weight:600;">Home</a></li>
      <li aria-hidden="true" style="opacity:.4;">/</li>
      <li><a href="/#services" style="color:var(--blue);font-weight:600;">Services</a></li>
      <li aria-hidden="true" style="opacity:.4;">/</li>
      <li style="font-weight:600;color:var(--dark);">{svcName} for {nicheName} in {loc}</li>
    </ol>
  </div>
</nav>

<!-- HERO -->
<section style="background:linear-gradient(135deg,var(--blue-deeper) 0%,var(--blue-dark) 60%,#1a3a7a 100%);padding:80px 0 64px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse 700px 500px at 65% 50%,rgba(245,166,35,.07) 0%,transparent 70%);pointer-events:none;"></div>
  <div class="container" style="position:relative;z-index:1;">
    <div style="max-width:700px;">
      <div style="display:inline-flex;align-items:center;gap:8px;font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--orange);margin-bottom:20px;">
        <span style="display:inline-block;width:24px;height:2px;background:var(--orange);border-radius:2px;"></span>
        {svcName} · {loc}, FL
      </div>
      <h1 style="font-size:clamp(30px,5vw,52px);font-weight:800;line-height:1.1;letter-spacing:-0.02em;color:var(--white);margin-bottom:20px;">
        {svcName} for<br />
        <em style="font-style:normal;color:var(--orange);">{nicheName}</em> in {loc}
      </h1>
      <p style="font-size:17px;line-height:1.7;color:rgba(255,255,255,.72);margin-bottom:32px;max-width:560px;">
        {hero} No 12-month contracts. No hidden fees. Results you can see, billing you can cancel.
      </p>
      <div style="display:flex;gap:16px;flex-wrap:wrap;">
        <a href="#contact" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Get Free Audit
        </a>
        <a href="/#pricing" class="btn btn-outline">See Pricing</a>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:32px;">
        <div class="hero-pill">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
          Month-to-month, always
        </div>
        <div class="hero-pill">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
          Live results dashboard
        </div>
        <div class="hero-pill">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
          Hablamos Español
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT'S INCLUDED -->
<section class="section" style="background:var(--light);">
  <div class="container">
    <div class="section-head reveal">
      <div class="label">What You Get</div>
      <h2>{svcName} Built for {nicheName} in {loc}</h2>
      <p class="lead">No generic playbooks. Every strategy is built for your market, your competition, and your customers searching in {loc}.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;">
      {pageFeatures.map((feat, i) => (
        <div class="service-card reveal" style={`animation-delay:${i * 100}ms`}>
          <div class="service-icon">
            {i === 0 && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 6L9 17l-5-5"/><circle cx="12" cy="12" r="10"/></svg>}
            {i === 1 && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>}
