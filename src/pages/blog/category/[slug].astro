---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  categoryMeta,
  getPostsByCategory,
  getRealCategories,
} from '../../../data/blog-posts';

// Generates one /blog/category/<slug>/ page per category that has >=3 posts.
// Thin categories (1-2 posts) intentionally do NOT get a page; their pills on
// /blog/ act as client-side filters only. Promotion to a real page happens
// automatically as soon as a 3rd post in that category is published.
export async function getStaticPaths() {
  const real = getRealCategories(3);
  return real.map((meta) => ({
    params: { slug: meta.slug },
    props: { meta },
  }));
}

const { meta } = Astro.props;
const posts = getPostsByCategory(meta.label);
const pageUrl = `https://thryvmarketingsolutions.com/blog/category/${meta.slug}/`;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thryvmarketingsolutions.com/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://thryvmarketingsolutions.com/blog/" },
      { "@type": "ListItem", "position": 3, "name": meta.label, "item": pageUrl },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `${meta.label} Articles`,
    "description": meta.description,
    "url": pageUrl,
    "isPartOf": {
      "@type": "Blog",
      "name": "Thryv Marketing Solutions Blog",
      "url": "https://thryvmarketingsolutions.com/blog/",
    },
    "mainEntity": {
      "@type": "ItemList",
      "numberOfItems": posts.length,
      "itemListElement": posts.map((p, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": `https://thryvmarketingsolutions.com${p.slug}`,
        "name": p.title,
      })),
    },
  },
];
---

<BaseLayout
  title={`${meta.label} Articles | Thryv Marketing Solutions`}
  description={meta.description}
  canonical={pageUrl}
  ogImage="https://thryvmarketingsolutions.com/og-blog.jpg"
  schema={schema}
>

<section class="cat-hero">
  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/blog/">Blog</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{meta.label}</span>
    </nav>
    <div class="cat-hero-inner">
      <div class="cat-eyebrow">
        <span class="eyebrow-bar"></span>
        {meta.heroEyebrow}
      </div>
      <h1>{meta.label}</h1>
      <p class="lead">{meta.description}</p>
      {meta.verticalLink && (
        <a href={meta.verticalLink.href} class="vertical-cta" aria-label={`Explore ${meta.verticalLink.label}`}>
          Explore {meta.verticalLink.label}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      )}
    </div>
  </div>
</section>

<section class="posts-section">
  <div class="container">
    <div class="section-head">
      <h2>All {meta.label} Articles</h2>
      <span class="post-count">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</span>
    </div>
    <div class="posts-grid">
      {posts.map((post, i) => (
        <article class="post-card reveal" style={`transition-delay:${(i % 3) * 0.08}s`}>
          {post.heroImage && (
            <a href={post.slug} class="post-thumb" aria-label={post.title}>
              <img src={post.heroImage} alt={post.title} title={post.title} loading="lazy" width="640" height="360" />
            </a>
          )}
          <div class="post-body">
            <div class="post-category">{post.category}</div>
            <h3 class="post-title"><a href={post.slug}>{post.title}</a></h3>
            <p class="post-excerpt">{post.excerpt}</p>
            <div class="post-meta">
              <span>{post.date}</span>
              <span>{post.readTime}</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="back-link-row">
      <a href="/blog/" class="back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Browse all blog posts
      </a>
    </div>
  </div>
</section>

<style>
  .cat-hero {
    background: linear-gradient(135deg, #0A2E6E 0%, var(--blue) 100%);
    padding: 36px 0 64px;
    color: var(--white);
  }
  .breadcrumbs {
    display: flex; gap: 8px; align-items: center;
    font-size: 13px; color: rgba(255,255,255,.7);
    margin-bottom: 32px;
  }
  .breadcrumbs a { color: rgba(255,255,255,.8); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--white); text-decoration: underline; }
  .breadcrumbs span[aria-current] { color: var(--white); font-weight: 600; }

  .cat-hero-inner { max-width: 720px; }
  .cat-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 12px; font-weight: 700; letter-spacing: .12em;
    text-transform: uppercase; color: var(--orange); margin-bottom: 20px;
  }
  .eyebrow-bar { display: inline-block; width: 24px; height: 2px; background: var(--orange); border-radius: 2px; }
  .cat-hero h1 {
    font-size: clamp(32px, 4.5vw, 48px); font-weight: 800; line-height: 1.1;
    letter-spacing: -0.02em; color: var(--white); margin-bottom: 16px;
  }
  .cat-hero .lead {
    font-size: 18px; line-height: 1.65; color: rgba(255,255,255,.82);
    margin-bottom: 28px;
  }
  .vertical-cta {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 14px; font-weight: 700; color: var(--white);
    background: rgba(255,255,255,.12);
    border: 1.5px solid rgba(255,255,255,.25);
    border-radius: 100px; padding: 10px 18px;
    text-decoration: none; transition: background .15s, border-color .15s;
  }
  .vertical-cta:hover { background: rgba(255,255,255,.2); border-color: var(--white); }

  .posts-section { background: var(--light); padding: 56px 0; }
  .section-head {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 28px; flex-wrap: wrap; gap: 12px;
  }
  .section-head h2 {
    font-size: 22px; font-weight: 800; color: var(--dark);
    letter-spacing: -0.01em;
  }
  .post-count {
    font-size: 13px; font-weight: 600; color: var(--gray);
    background: var(--white); border: 1px solid var(--border);
    border-radius: 100px; padding: 4px 12px;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 28px;
    margin-bottom: 40px;
  }
  .post-card {
    background: var(--white); border: 1px solid var(--border);
    border-radius: var(--radius-lg); overflow: hidden;
    transition: box-shadow .25s, transform .25s;
    display: flex; flex-direction: column;
  }
  .post-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,.08); transform: translateY(-2px); }
  .post-thumb {
    display: block; aspect-ratio: 16 / 9; overflow: hidden;
    background: var(--light);
  }
  .post-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .post-body { padding: 24px; display: flex; flex-direction: column; flex: 1; }
  .post-category {
    display: inline-flex; align-self: flex-start;
    font-size: 11px; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; color: var(--blue); background: #EEF4FF;
    border-radius: 100px; padding: 4px 12px; margin-bottom: 12px;
  }
  .post-title { font-size: 17px; font-weight: 700; color: var(--dark); line-height: 1.35; margin-bottom: 10px; }
  .post-title a { color: inherit; text-decoration: none; }
  .post-title a:hover { color: var(--blue); }
  .post-excerpt { font-size: 14px; line-height: 1.65; color: var(--gray); margin-bottom: 18px; flex: 1; }
  .post-meta {
    display: flex; justify-content: space-between;
    font-size: 12px; color: var(--gray-light);
    border-top: 1px solid var(--border); padding-top: 14px;
  }

  .back-link-row { text-align: center; padding: 16px 0 8px; }
  .back-link {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 14px; font-weight: 700; color: var(--blue);
    text-decoration: none;
  }
  .back-link:hover { text-decoration: underline; }

  .reveal { opacity: 0; transform: translateY(20px); transition: opacity .5s ease, transform .5s ease; }
  .reveal.visible { opacity: 1; transform: none; }

  @media (max-width: 768px) {
    .cat-hero { padding: 24px 0 48px; }
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
    }),
    { threshold: 0.1 }
  );
  revealEls.forEach(el => observer.observe(el));
</script>

</BaseLayout>
