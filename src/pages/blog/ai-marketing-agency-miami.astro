<script>
  function animateNum(el: HTMLElement) {
    const raw = el.textContent?.trim() ?? '';
    const prefix = raw.startsWith('~') ? '~' : '';
    const suffix = raw.endsWith('%') ? '%' : '';
    const val = parseFloat(raw.replace(/[^0-9.]/g, ''));
    if (isNaN(val) || val === 0) return;
    const decimals = raw.includes('.') ? 1 : 0;
    const t0 = performance.now();
    const dur = 1300;
    function step(now: number) {
      const p = Math.min((now - t0) / dur, 1);
      const ease = 1 - Math.pow(1 - p, 3);
      el.textContent = prefix + (ease * val).toFixed(decimals) + suffix;
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  // Count-up on stat-callout scroll-in
  const calloutObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      if (el.dataset.counted) return;
      el.dataset.counted = '1';
      el.querySelectorAll<HTMLElement>('.callout-num').forEach(animateNum);
      calloutObs.unobserve(el);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll<HTMLElement>('.stat-callout').forEach(el => calloutObs.observe(el));

  // Fade-up + count-up on block stat elements
  const blockObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const siblings = [...(el.parentElement?.querySelectorAll<HTMLElement>('.stat-card') ?? [])];
      const idx = siblings.indexOf(el);
      if (idx >= 0) el.style.transitionDelay = `${idx * 0.1}s`;
      el.classList.add('visible');
      el.querySelectorAll<HTMLElement>('.stat-num, .pull-num').forEach(animateNum);
      blockObs.unobserve(el);
    });
  }, { threshold: 0.2 });
  document.querySelectorAll<HTMLElement>('.stat-card, .key-takeaways').forEach(el => blockObs.observe(el));

  // Newsletter reveal
  document.querySelectorAll<HTMLButtonElement>('.js-nl-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const wrap = btn.closest('.blog-cta')?.querySelector<HTMLElement>('.nl-cta-wrap');
      if (wrap) { wrap.classList.add('open'); btn.style.display = 'none'; }
    });
  });
</script>
