              <tr><td>Profile completeness</td><td>Every field filled</td><td>Full</td><td>Complete this week</td></tr>
              <tr><td>Services + keywords</td><td>"Botox", "Dysport" named</td><td>Full</td><td>Add named services</td></tr>
              <tr><td>Review rating</td><td>4.7+ stars</td><td>High</td><td>Reply to all, fix issues</td></tr>
              <tr><td>Review volume + velocity</td><td>50+ and steady weekly</td><td>High</td><td>Request at every visit</td></tr>
              <tr class="highlight"><td><strong>Neighborhood pages</strong></td><td><strong>Specific local content</strong></td><td><strong>Full</strong></td><td><strong>Build Brickell first</strong></td></tr>
            </tbody>
