---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { publishedPosts, getAllCategoriesWithCount } from '../../data/blog-posts';

// Single source of truth: data/blog-posts.ts
// publishedPosts respects the liveAfter gate (scheduled posts stay hidden until their date).
// Sort by date descending so newest is first.
const posts = [...publishedPosts].sort((a, b) => +new Date(b.date) - +new Date(a.date));

// Category pills for the filter row.
// Each pill knows whether it has a real /blog/category/<slug>/ page or is
// filter-only (renders as a button, no href).
const categories = getAllCategoriesWithCount();

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Thryv Marketing Solutions Blog",
  "url": "https://thryvmarketingsolutions.com/blog/",
  "description": "Marketing insights, local SEO tips, and growth strategies for local businesses.",
  "publisher": {
    "@type": "Organization",
    "name": "Thryv Marketing Solutions",
    "url": "https://thryvmarketingsolutions.com"
  },
  "blogPost": posts.slice(0, 10).map((p) => ({
    "@type": "BlogPosting",
    "headline": p.title,
    "url": `https://thryvmarketingsolutions.com${p.slug}`,
    "datePublished": p.date,
    "articleSection": p.category,
  })),
};
---

<BaseLayout
  title="Blog | Thryv Marketing Solutions"
  description="Marketing insights, local SEO tips, and growth strategies for local businesses, from the team at Thryv Marketing Solutions."
  canonical="https://thryvmarketingsolutions.com/blog/"
  ogImage="https://thryvmarketingsolutions.com/og-blog.jpg"
  schema={schema}
>

<section class="blog-hero">
  <div class="container">
    <div class="hero-inner">
      <div class="blog-eyebrow">
        <span class="eyebrow-bar"></span>
        Thryv Blog
      </div>
      <h1>Marketing That Actually Works<br />for Local Businesses</h1>
      <p class="lead">Practical insights on local SEO, reputation management, AI automation, and everything else that drives real growth for service businesses.</p>
    </div>
  </div>
</section>

<section class="filter-bar" aria-label="Filter posts by topic">
  <div class="container">
    <div class="filter-row">
      <button class="filter-pill is-active" data-filter="all" type="button" aria-pressed="true">
        All Posts <span class="filter-count">{posts.length}</span>
      </button>
      {categories.map((c) => (
        c.isRealPage ? (
          <a
            class="filter-pill"
            href={`/blog/category/${c.meta.slug}/`}
            data-filter={c.meta.label}
            aria-label={`Browse all ${c.meta.label} posts`}
          >
            {c.meta.label} <span class="filter-count">{c.count}</span>
          </a>
        ) : (
          <button
            class="filter-pill"
            data-filter={c.meta.label}
            type="button"
            aria-pressed="false"
            aria-label={`Filter to ${c.meta.label} posts`}
          >
            {c.meta.label} <span class="filter-count">{c.count}</span>
          </button>
        )
      ))}
    </div>
  </div>
</section>

<section class="posts-section">
  <div class="container">
    <div class="posts-grid" id="posts-grid">
      {posts.map((post, i) => (
        <article
          class="post-card reveal"
          data-category={post.category}
          style={`transition-delay:${(i % 3) * 0.08}s`}
        >
          <div class="post-category-row">
            <div class="post-category">{post.category}</div>
          </div>
          <h2 class="post-title">
            <a href={post.slug}>{post.title}</a>
          </h2>
          <p class="post-excerpt">{post.excerpt}</p>
          <div class="post-meta">
            <span>{post.date}</span>
            <span>{post.readTime}</span>
          </div>
        </article>
      ))}
    </div>

    <p class="filter-empty" id="filter-empty" hidden>
      No posts in this topic yet. <button type="button" class="filter-reset" data-reset>Show all posts</button>
    </p>

    <div class="more-coming">
      <div class="label">Stay in the Loop</div>
      <h3>Get New Posts Delivered to Your Inbox</h3>
      <p>Local SEO, Google Ads, AI tools, and what's actually working for Miami businesses. No fluff. Unsubscribe anytime.</p>
      <form class="newsletter-form" id="blog-newsletter">
        <input type="hidden" name="access_key" value="d1c9b652-c7bb-46e0-86fc-57e0f59f8e02" />
        <input type="hidden" name="subject" value="New Blog Newsletter Signup | Thryv" />
        <input type="hidden" name="from_name" value="Thryv Blog" />
        <div class="newsletter-row">
          <input type="email" name="email" placeholder="Your email address" required autocomplete="email" />
          <button type="submit" class="btn btn-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            Subscribe
          </button>
        </div>
        <p class="newsletter-success" id="nl-success" style="display:none;">You're in. We'll send new posts straight to your inbox.</p>
      </form>
    </div>
  </div>
</section>

<style>
  .blog-hero {
    background: linear-gradient(135deg, #0A2E6E 0%, var(--blue) 100%);
    padding: 72px 0 56px;
    color: var(--white);
  }
  .hero-inner { max-width: 600px; }
  .blog-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 12px; font-weight: 700; letter-spacing: .12em;
    text-transform: uppercase; color: var(--orange); margin-bottom: 20px;
  }
  .eyebrow-bar { display: inline-block; width: 24px; height: 2px; background: var(--orange); border-radius: 2px; }
  .blog-hero h1 {
    font-size: clamp(28px, 4vw, 44px); font-weight: 800; line-height: 1.15;
    letter-spacing: -0.02em; color: var(--white); margin-bottom: 16px;
  }
  .blog-hero .lead { font-size: 17px; line-height: 1.7; color: rgba(255,255,255,.7); }

  .filter-bar { background: var(--white); padding: 28px 0 8px; border-bottom: 1px solid var(--border); }
  .filter-row {
    display: flex; flex-wrap: wrap; gap: 8px;
    align-items: center;
  }
  .filter-pill {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: inherit; font-size: 13px; font-weight: 600;
    color: var(--dark); background: var(--white);
    border: 1.5px solid var(--border); border-radius: 100px;
    padding: 7px 14px; cursor: pointer;
    text-decoration: none;
    transition: background .15s, border-color .15s, color .15s;
  }
  .filter-pill:hover { border-color: var(--blue); color: var(--blue); }
  .filter-pill.is-active {
    background: var(--blue); color: var(--white); border-color: var(--blue);
  }
  .filter-pill.is-active .filter-count { background: rgba(255,255,255,.22); color: var(--white); }
  .filter-count {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 22px; height: 18px; padding: 0 6px;
    background: var(--light); color: var(--gray);
    border-radius: 100px; font-size: 11px; font-weight: 700;
  }

  .posts-section { background: var(--light); padding: 40px 0 64px; }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 28px;
    margin-bottom: 48px;
  }

  .post-card {
    background: var(--white); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 32px;
    transition: box-shadow .25s, transform .25s, opacity .2s;
  }
  .post-card.is-hidden { display: none; }
  .post-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,.08); transform: translateY(-2px); }

  .post-category-row { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
  .post-category {
    display: inline-flex; font-size: 11px; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; color: var(--blue); background: #EEF4FF;
    border-radius: 100px; padding: 4px 12px;
  }
  .post-title { font-size: 17px; font-weight: 700; color: var(--dark); line-height: 1.35; margin-bottom: 12px; }
  .post-title a { color: inherit; text-decoration: none; }
  .post-title a:hover { color: var(--blue); }
  .post-excerpt { font-size: 14px; line-height: 1.7; color: var(--gray); margin-bottom: 20px; }
  .post-meta {
    display: flex; justify-content: space-between;
    font-size: 12px; color: var(--gray-light);
    border-top: 1px solid var(--border); padding-top: 16px;
  }

  .filter-empty {
    text-align: center; font-size: 15px; color: var(--gray);
    padding: 32px 0;
  }
  .filter-reset {
    background: none; border: none; color: var(--blue);
    font: inherit; font-weight: 700; cursor: pointer;
    text-decoration: underline;
  }

  .more-coming {
    text-align: center; padding: 48px;
    background: var(--white); border-radius: var(--radius-lg); border: 1px solid var(--border);
  }
  .more-coming .label { display: inline-flex; margin-bottom: 12px; }
  .more-coming h3 { font-size: 22px; font-weight: 800; color: var(--dark); margin-bottom: 12px; }
  .more-coming p { font-size: 15px; color: var(--gray); max-width: 440px; margin: 0 auto 24px; }
  .newsletter-form { max-width: 460px; margin: 0 auto; }
  .newsletter-row { display: flex; gap: 8px; }
  .newsletter-row input[type="email"] {
    flex: 1; padding: 11px 16px; border: 1.5px solid var(--border);
    border-radius: 8px; font-size: 14px; color: var(--dark); outline: none;
    transition: border-color .2s;
  }
  .newsletter-row input[type="email"]:focus { border-color: var(--blue); }
  .newsletter-success { font-size: 14px; color: #16a34a; font-weight: 600; margin-top: 12px; }
  @media (max-width: 480px) { .newsletter-row { flex-direction: column; } }

  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px; border-radius: 8px; font-size: 14px;
    font-weight: 700; text-decoration: none; transition: opacity .2s;
  }
  .btn-primary { background: var(--orange); color: var(--dark); }
  .btn-primary:hover { opacity: .9; }

  .reveal { opacity: 0; transform: translateY(20px); transition: opacity .5s ease, transform .5s ease; }
  .reveal.visible { opacity: 1; transform: none; }

  @media (max-width: 768px) {
    .blog-hero { padding: 48px 0 40px; }
    .posts-grid { grid-template-columns: 1fr; }
    .more-coming { padding: 32px 20px; }
  }
</style>

<script>
  // Reveal animations
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
    }),
    { threshold: 0.1 }
  );
  revealEls.forEach(el => observer.observe(el));

  // Category filter (client-side only for filter-only pills; real-page pills are
  // anchors and navigate normally). Persists last-clicked filter to URL hash.
  const pills = document.querySelectorAll('button.filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');
  const emptyMsg = document.getElementById('filter-empty') as HTMLElement | null;

  function applyFilter(filter: string) {
    let visibleCount = 0;
    cards.forEach((card) => {
      const matches = filter === 'all' || card.dataset.category === filter;
      card.classList.toggle('is-hidden', !matches);
      if (matches) visibleCount++;
    });
    pills.forEach((p) => {
      const isActive = (p as HTMLElement).dataset.filter === filter;
      p.classList.toggle('is-active', isActive);
      p.setAttribute('aria-pressed', String(isActive));
    });
    if (emptyMsg) emptyMsg.hidden = visibleCount > 0;
    // Update URL hash without scroll
    if (filter === 'all') {
      history.replaceState(null, '', location.pathname + location.search);
    } else {
      const slug = filter.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
      history.replaceState(null, '', '#topic=' + slug);
    }
  }

  pills.forEach((p) => {
    p.addEventListener('click', (e) => {
      e.preventDefault();
      applyFilter((p as HTMLElement).dataset.filter || 'all');
    });
  });

  // "Show all posts" reset link in the empty state
  document.querySelector('[data-reset]')?.addEventListener('click', () => applyFilter('all'));

  // Restore from URL hash on load
  const hash = location.hash.match(/topic=([a-z0-9-]+)/);
  if (hash) {
    const slug = hash[1];
    // Find the pill whose data-filter slugifies to this hash
    pills.forEach((p) => {
      const filter = (p as HTMLElement).dataset.filter || '';
      const filterSlug = filter.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
      if (filterSlug === slug) applyFilter(filter);
    });
  }

  // Newsletter form
  const nlForm = document.getElementById('blog-newsletter') as HTMLFormElement | null;
  const nlSuccess = document.getElementById('nl-success');
  nlForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(nlForm));
    const res = await fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    if (res.ok) {
      nlForm.reset();
      if (nlSuccess) { nlSuccess.style.display = 'block'; }
      const row = nlForm.querySelector('.newsletter-row') as HTMLElement | null;
      if (row) row.style.display = 'none';
    }
  });
</script>

</BaseLayout>
