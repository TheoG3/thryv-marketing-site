---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';

const liveTools = [
  {
    href: 'https://thryv-map-report.pages.dev',
    icon: '🗺️',
    name: 'Local Map Report (Free)',
    desc: 'See where you rank vs competitors for local searches in your market',
    isExternal: true,
  },
  {
    href: 'https://thryv-ada-scanner.theodoreg3.workers.dev',
    icon: '♿',
    name: 'ADA Accessibility Scanner',
    desc: 'Free scan of your website for ADA compliance issues and fixes',
    isExternal: true,
  },
];

const tools = [
  {
    href: '/free-tools/review-revenue-calculator/',
    icon: '💰',
    name: 'Review Revenue Calculator',
    desc: 'See how much a higher Google rating could earn you',
  },
  {
    href: '/free-tools/gbp-audit-scorer/',
    icon: '📋',
    name: 'GBP Audit Scorer',
    desc: '10 yes or no questions to score your Google Business Profile',
  },
  {
    href: '/free-tools/local-seo-score-checker/',
    icon: '🔍',
    name: 'Local SEO Score Checker',
    desc: '10 questions to find out where your local SEO stands',
  },
  {
    href: '/free-tools/google-ads-budget-calculator/',
    icon: '📈',
    name: 'Google Ads Budget Calculator',
    desc: 'See what ad spend it takes to hit your lead goal',
  },
  {
    href: '/free-tools/review-gap-calculator/',
    icon: '⭐',
    name: 'Review Gap Calculator',
    desc: 'See how far behind your top competitor you are on reviews',
  },
  {
    href: '/free-tools/missed-call-revenue-calculator/',
    icon: '📞',
    name: 'Missed Call Revenue Calculator',
    desc: 'See how much unanswered calls are costing you each month',
  },
  {
    href: '/free-tools/med-spa-marketing-roi-calculator/',
    icon: '💉',
    name: 'Med Spa Marketing ROI Calculator',
    desc: 'New patients, CAC, year-one revenue, and 5-year LTV for Miami med spas',
  },
];

const allTools = [...liveTools, ...tools];
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",       "item": "https://thryvmarketingsolutions.com/" },
        { "@type": "ListItem", "position": 2, "name": "Free Tools", "item": "https://thryvmarketingsolutions.com/free-tools/" }
      ]
    },
    {
      "@type": "ItemList",
      "name": "Free Marketing Tools for Miami Businesses",
      "numberOfItems": allTools.length,
      "itemListElement": allTools.map((t, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": t.isExternal ? t.href : `https://thryvmarketingsolutions.com${t.href}`,
        "name": t.name
      }))
    }
  ]
};
---

<BaseLayout
  title="Free Marketing Tools for Miami Businesses | Thryv Marketing Solutions"
  description="Free calculators and audit tools for Miami local businesses. Review revenue, missed call revenue, Google Business Profile audit, local SEO score, Google Ads budget, med spa ROI."
  canonical="https://thryvmarketingsolutions.com/free-tools/"
  ogImage="https://thryvmarketingsolutions.com/og-free-tools.jpg"
  schema={schema}
>

  <section class="tools-hero">
    <div class="container">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Home</a><span aria-hidden="true"> › </span><span>Free Tools</span>
      </nav>
      <span class="label">Free Tools</span>
      <h1>Free Marketing Tools for Miami Businesses</h1>
      <p class="lead">Two live ranking tools powered by real SEO and accessibility APIs, plus seven calculators to benchmark your marketing. Pick one, run it, and get a real answer in under two minutes.</p>
    </div>
  </section>

  <section class="section live-tools-section">
    <div class="container">
      <div class="section-head center">
        <span class="label">Real-Time Ranking Data</span>
        <h2>Two Live Tools, No Signup Required</h2>
        <p class="lead center" style="max-width:680px;margin:0 auto;">These tools hit real SEO APIs and accessibility scanners on demand. See where you actually rank, spot ADA compliance gaps, and understand what to fix.</p>
      </div>
      <div class="live-tools-grid">
        {liveTools.map((t) => (
          <a href={t.href} target={t.isExternal ? '_blank' : undefined} rel={t.isExternal ? 'noopener noreferrer' : undefined} class="live-tool-card reveal" aria-label={`Open ${t.name}`}>
            <div class="lt-icon">{t.icon}</div>
            <h3>{t.name}</h3>
            <p>{t.desc}</p>
            <span class="lt-cta">Open Tool →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section tools-section">
    <div class="container">
      <div class="tiles-row">
        {tools.map((t) => (
          <a href={t.href} class="tile-card reveal" aria-label={`Open ${t.name}`}>
            <div class="tile-left">
              <span class="tile-icon" aria-hidden="true">{t.icon}</span>
              <div class="tile-text">
                <div class="tile-name">{t.name}</div>
                <div class="tile-desc">{t.desc}</div>
              </div>
            </div>
            <span class="tile-arrow" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section coming-soon-section">
    <div class="container">
      <div class="section-head center">
        <span class="label">Building Now</span>
        <h2>One More Tool in Development</h2>
        <p class="lead center" style="max-width:620px;margin:0 auto;">The next tool pulls real keywords and search volumes on demand. Drop your email below to be first in line when it ships.</p>
      </div>
      <div class="cs-grid single">
        <div class="cs-card reveal">
          <div class="cs-tag">Coming Soon</div>
          <div class="cs-icon">🎯</div>
          <h3>Keyword Opportunity Finder</h3>
          <p>Paste a competitor URL. We pull every keyword they rank for that you don't, with monthly search volume and difficulty score. Built on the same data source pro SEOs pay $400/mo for.</p>
        </div>
      </div>
      <div class="cs-waitlist reveal">
        <ContactForm
          title="Get Early Access (Free)"
          subject="Free Tools Early-Access Waitlist | Thryv"
        />
      </div>
    </div>
  </section>

  <section class="section contact-section">
    <div class="container">
      <div class="contact-split">
        <div class="reveal">
          <span class="label">Next Step</span>
          <h2>Want Us to Fix What the Tools Found?</h2>
          <p class="lead" style="margin-bottom:24px;">Get a free professional audit from our team. We will dig into your GBP, reviews, SEO, and website and tell you exactly what to fix.</p>
        </div>
        <ContactForm title="Get Your Free Proposal" subject="New Free Tools Page Inquiry | Thryv" />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .tools-hero { padding: 80px 0 64px; background: linear-gradient(135deg, var(--blue-deeper) 0%, var(--blue) 100%); color: var(--white); }
  .tools-hero .label { background: rgba(255,255,255,.15); color: var(--white); }
  .tools-hero h1 { font-size: clamp(32px, 5vw, 52px); font-weight: 800; line-height: 1.1; letter-spacing: -.02em; margin: 16px 0; color: var(--white); max-width: 640px; }
  .tools-hero .lead { color: rgba(255,255,255,.85); max-width: 720px; }
  .tools-disclaimer { margin-top: 18px; padding: 12px 16px; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; color: rgba(255,255,255,.7); font-size: 12.5px; line-height: 1.55; max-width: 720px; }
  .breadcrumb { display: flex; align-items: center; gap: 4px; font-size: 13px; color: rgba(255,255,255,.6); margin-bottom: 24px; }
  .breadcrumb a { color: rgba(255,255,255,.6); }
  .breadcrumb a:hover { color: var(--white); }

  .live-tools-section { background: var(--white); border-top: 1px solid var(--border); }
  .live-tools-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 40px; max-width: 920px; margin-left: auto; margin-right: auto; }
  .live-tool-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 32px;
    background: linear-gradient(135deg, rgba(20,140,202,.02) 0%, rgba(20,140,202,.04) 100%);
    border: 1.5px solid var(--blue-lighter);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: box-shadow .18s ease, border-color .18s ease, transform .18s ease;
  }
  .live-tool-card:hover {
    border-color: var(--blue);
    box-shadow: 0 12px 36px rgba(20,140,202,.12);
    transform: translateY(-2px);
  }
  .live-tool-card:focus-visible {
    outline: 3px solid var(--orange);
    outline-offset: 3px;
  }
  .lt-icon { font-size: 40px; line-height: 1; }
  .live-tool-card h3 { font-size: 18px; font-weight: 800; color: var(--dark); margin: 0; }
  .live-tool-card p { font-size: 14px; line-height: 1.65; color: var(--gray); margin: 0; }
  .lt-cta { font-size: 13px; font-weight: 700; color: var(--blue); margin-top: 8px; transition: transform .18s ease; }
  .live-tool-card:hover .lt-cta { transform: translateX(4px); }

  .coming-soon-section { background: var(--light); border-top: 1px solid var(--border); }
  .cs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; max-width: 880px; margin-left: auto; margin-right: auto; }
  .cs-grid.single { grid-template-columns: 1fr; max-width: 480px; }
  .cs-card { background: var(--white); border: 1.5px dashed var(--orange); border-radius: var(--radius-lg); padding: 32px; position: relative; }
  .cs-tag { position: absolute; top: 18px; right: 18px; font-size: 10px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; color: var(--orange); background: rgba(245,166,35,.12); padding: 5px 10px; border-radius: 100px; }
  .cs-icon { font-size: 36px; margin-bottom: 14px; }
  .cs-card h3 { font-size: 19px; font-weight: 800; color: var(--dark); margin-bottom: 10px; }
  .cs-card p { font-size: 14px; line-height: 1.7; color: var(--gray); margin: 0; }
  .cs-waitlist { max-width: 560px; margin: 40px auto 0; }
  @media (max-width: 720px) {
    .cs-grid { grid-template-columns: 1fr; }
    .live-tools-grid { grid-template-columns: 1fr; }
  }

  .tools-section { background: var(--white); }
  .tiles-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .tile-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    height: 132px;
    padding: 20px 24px;
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: box-shadow .18s ease, border-color .18s ease, transform .18s ease;
  }
  .tile-card:hover {
    border-color: var(--blue);
    box-shadow: 0 12px 32px rgba(0,0,0,.08);
    transform: translateY(-2px);
  }
  .tile-card:focus-visible {
    outline: 3px solid var(--orange);
    outline-offset: 3px;
  }

  .tile-left { display: flex; align-items: center; gap: 18px; min-width: 0; }
  .tile-icon { font-size: 36px; line-height: 1; flex-shrink: 0; }
  .tile-text { min-width: 0; }
  .tile-name {
    font-size: 18px; font-weight: 800; color: var(--dark); margin-bottom: 4px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .tile-desc {
    font-size: 14px; color: var(--gray);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .tile-arrow {
    color: var(--blue);
    flex-shrink: 0;
    transition: transform .18s ease;
  }
  .tile-card:hover .tile-arrow { transform: translateX(4px); }

  .contact-section { background: var(--light); }
  .contact-split { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }

  .reveal { opacity: 0; transform: translateY(24px); transition: opacity .55s ease, transform .55s ease; }
  .reveal.visible { opacity: 1; transform: none; }

  @media (max-width: 1024px) {
    .tiles-row { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .tiles-row { grid-template-columns: 1fr; max-width: 600px; }
    .tile-card { padding: 18px 20px; }
    .contact-split { grid-template-columns: 1fr; gap: 40px; }
  }
</style>

<script>
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>
