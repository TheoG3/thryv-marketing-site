---
import { blogPosts, getRelatedPosts } from '../data/blog-posts';

export interface Props {
  currentSlug: string;
  max?: number;
  heading?: string;
}

const { currentSlug, max = 3, heading = "Keep Reading" } = Astro.props;
const related = getRelatedPosts(currentSlug, max);
const current = blogPosts.find((p) => p.slug === currentSlug);
const hub = current?.topicHub;
---

<section class="related-articles" aria-labelledby="related-heading">
  <div class="container">
    <div class="related-header">
      <h2 id="related-heading">{heading}</h2>
      {hub && (
        <a href={hub.href} class="hub-link" aria-label={`Browse ${hub.label}`}>
          {hub.label} <span aria-hidden="true">→</span>
        </a>
      )}
    </div>
    <div class="related-grid">
      {related.map((post) => (
        <a href={post.slug} class="related-card" aria-label={post.title}>
          {post.heroImage ? (
            <div class="related-thumb">
              <img src={post.heroImage} alt={post.title} title={post.title} loading="lazy" width="640" height="360" />
            </div>
          ) : (
            <div class="related-thumb related-thumb-placeholder" aria-hidden="true">
              <span>{post.category}</span>
            </div>
          )}
          <div class="related-body">
            <span class="related-category">{post.category}</span>
            <h3>{post.title}</h3>
            <p class="related-excerpt">{post.excerpt}</p>
            <span class="related-readtime">{post.date} · {post.readTime}</span>
          </div>
        </a>
      ))}
    </div>
    <div class="related-footer">
      <a href="/blog/" class="all-link">Browse all articles <span aria-hidden="true">→</span></a>
    </div>
  </div>
</section>

<style>
  .related-articles {
    background: var(--light, #f8fafc);
    padding: 56px 0 64px;
    border-top: 1.5px solid var(--border, #e2e8f0);
  }
  .related-header {
    display: flex; justify-content: space-between; align-items: baseline;
    max-width: 1120px; margin: 0 auto 28px; padding: 0 24px;
    flex-wrap: wrap; gap: 12px;
  }
  .related-header h2 {
    font-size: clamp(22px, 3vw, 28px); font-weight: 800; color: var(--dark);
    margin: 0; letter-spacing: -0.01em;
  }
  .hub-link {
    color: var(--blue); font-weight: 700; font-size: 14px; text-decoration: none;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .hub-link:hover { text-decoration: underline; }

  .related-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
    max-width: 1120px; margin: 0 auto; padding: 0 24px;
  }
  .related-card {
    display: flex; flex-direction: column;
    background: var(--white); border: 1.5px solid var(--border, #e2e8f0);
    border-radius: var(--radius-lg, 14px); overflow: hidden;
    text-decoration: none; color: inherit;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }
  .related-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 30px -14px rgba(10, 46, 110, 0.22);
    border-color: rgba(10, 46, 110, 0.18);
    text-decoration: none;
  }
  .related-thumb { aspect-ratio: 16 / 9; overflow: hidden; background: #eef2f7; }
  .related-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .related-thumb-placeholder {
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #0A2E6E 0%, var(--blue, #1B4FA8) 100%);
    color: rgba(255,255,255,0.92);
    font-size: 12px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase;
  }
  .related-thumb-placeholder span { padding: 8px 14px; }

  .related-body { padding: 18px 20px 20px; display: flex; flex-direction: column; gap: 8px; }
  .related-category {
    font-size: 11px; font-weight: 800; letter-spacing: .1em;
    text-transform: uppercase; color: var(--blue);
  }
  .related-card h3 {
    font-size: 16px; font-weight: 700; line-height: 1.3;
    color: var(--dark); margin: 0;
  }
  .related-excerpt {
    font-size: 13px; line-height: 1.55; color: var(--gray);
    margin: 0;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .related-readtime { font-size: 12px; color: var(--gray); margin-top: auto; padding-top: 4px; }

  .related-footer {
    max-width: 1120px; margin: 28px auto 0; padding: 0 24px; text-align: center;
  }
  .all-link {
    color: var(--blue); font-weight: 700; font-size: 14px;
    text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 18px; border: 1.5px solid var(--border, #e2e8f0); border-radius: 100px;
    background: var(--white);
    transition: border-color .18s, color .18s;
  }
  .all-link:hover { border-color: var(--blue); color: var(--blue); text-decoration: none; }

  @media (max-width: 900px) {
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
