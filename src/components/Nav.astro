---
const pathname = Astro.url.pathname;
const isSpanish = pathname.startsWith('/es');
const altPath = isSpanish
  ? (pathname.replace(/^\/es/, '') || '/')
  : ('/es' + pathname);

const services = [
  { label: 'Google Business Profile & Reviews', slug: 'google-business-profile' },
  { label: '— Reputation Management', slug: 'reputation-management' },
  { label: 'AI SEO (all 3 channels)', slug: 'ai-seo' },
  { label: '— Local SEO',             slug: 'seo' },
  { label: '— AEO (AI Overviews)',    slug: 'aeo' },
  { label: '— GEO (ChatGPT, Gemini)', slug: 'geo' },
  { label: 'Website Builds',          slug: 'website-design' },
  { label: 'Google Ads',              slug: 'google-ads' },
  { label: 'Social Media Ads',        slug: 'social-media-ads' },
  { label: 'Press & PR',              slug: 'press-pr' },
];

const consulting = [
  { label: 'AI SEO Consulting',         href: '/consulting/seo/' },
  { label: 'AI Consulting',             href: '/consulting/ai/' },
];

const navLinks = [
  { label: 'AI', href: '/ai/' },
  { label: 'Free Tools', href: '/free-tools/' },
  { label: 'Pricing',    href: '/pricing/' },
  { label: 'About',      href: '/about/' },
];

function isActive(href: string) {
  return pathname === href || pathname.startsWith(href.replace(/\/$/, '') + '/');
}
---

<a href="#main-content" class="skip-link">Skip to main content</a>

<header>
  <nav class="site-nav" aria-label="Main navigation">
    <div class="container">
      <div class="nav-inner">

        <a href="/" class="nav-logo" aria-label="Thryv Marketing Solutions home">
          <img src="/logos/logo-trimmed.webp" alt="Thryv Marketing Solutions" title="Thryv Marketing Solutions" width="160" height="52" />
        </a>

        <ul class="nav-links" role="list">

          <!-- Services dropdown -->
          <li class="has-dropdown">
            <a
              href="/services/"
              class:list={['nav-link', { 'nav-active': pathname.startsWith('/services') }]}
              id="services-menu-btn"
            >
              Services
              <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </a>
            <ul class="dropdown">
              <li>
                <a href="/services/" class="dropdown-all">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                  All Services
                </a>
              </li>
              {services.map(s => (
                <li>
                  <a href={`/services/${s.slug}/`} class="dropdown-item">{s.label}</a>
                </li>
              ))}
            </ul>
          </li>

          <!-- Consulting dropdown -->
          <li class="has-dropdown">
            <a
              href="/consulting/"
              class:list={['nav-link', { 'nav-active': pathname.startsWith('/consulting') }]}
              id="consulting-menu-btn"
            >
              Consulting
              <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </a>
            <ul class="dropdown">
              <li>
                <a href="/consulting/" class="dropdown-all">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                  All Consulting
                </a>
              </li>
              {consulting.map(c => (
                <li>
                  <a href={c.href} class="dropdown-item">{c.label}</a>
                </li>
              ))}
            </ul>
          </li>

          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class:list={['nav-link', { 'nav-active': isActive(link.href) }]}
              >
                {link.label}
              </a>
            </li>
          ))}

        </ul>

        <div class="nav-cta">
          {/* Spanish toggle hidden until ES pages are reviewed & approved */}
          {/* <a href={altPath} class="lang-toggle" aria-label={isSpanish ? 'Switch to English' : 'Cambiar a Español'}>{isSpanish ? 'EN' : 'ES'}</a> */}
          <a href="https://tidycal.com/theogrimes/30-minute-meeting" class="btn btn-blue tidycal-embed">Book a Call</a>
          <button
            class="hamburger"
            id="hamburger"
            aria-label="Open navigation menu"
            aria-expanded="false"
            aria-controls="mobileMenu"
          >
            <span></span><span></span><span></span>
          </button>
        </div>

      </div>
    </div>
  </nav>
</header>

<!-- Mobile menu -->
<div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Navigation menu" aria-modal="true">
  <div class="mobile-services-group">
    <button class="mobile-services-toggle" id="mobileServicesToggle" aria-expanded="false">
      Services
      <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
    </button>
    <div class="mobile-services-list" id="mobileServicesList">
      <a href="/services/" class="mobile-link mobile-link-sub">All Services</a>
      {services.map(s => (
        <a href={`/services/${s.slug}/`} class="mobile-link mobile-link-sub">{s.label}</a>
      ))}
    </div>
  </div>
  <div class="mobile-services-group">
    <button class="mobile-services-toggle" id="mobileConsultingToggle" aria-expanded="false">
      Consulting
      <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
    </button>
    <div class="mobile-services-list" id="mobileConsultingList">
      <a href="/consulting/" class="mobile-link mobile-link-sub">All Consulting</a>
      {consulting.map(c => (
        <a href={c.href} class="mobile-link mobile-link-sub">{c.label}</a>
      ))}
    </div>
  </div>
  {navLinks.map(link => (
    <a href={link.href} class="mobile-link">{link.label}</a>
  ))}
  <a href="/contact/" class="mobile-link">Contact</a>
  {/* Spanish toggle hidden until ES pages are reviewed & approved */}
  {/* <a href={altPath} class="mobile-link" style="font-weight:700;color:var(--blue);">{isSpanish ? '🇺🇸 English' : '🇪🇸 Español'}</a> */}
  <a href="https://tidycal.com/theogrimes/30-minute-meeting" class="btn btn-primary tidycal-embed" style="justify-content:center;margin-top:8px;">Book Free Proposal Call</a>
</div>

<style>
  .skip-link {
    position: absolute; top: -48px; left: 0;
    background: var(--blue); color: var(--white);
    padding: 10px 18px; text-decoration: none;
    z-index: 200; border-radius: 0 0 8px 0;
    font-size: 14px; font-weight: 700; transition: top .2s;
  }
  .skip-link:focus { top: 0; outline: 3px solid var(--orange); outline-offset: 2px; }

  header { position: sticky; top: 0; z-index: 100; }

  .site-nav {
    background: var(--white);
    border-bottom: 1px solid transparent;
    box-shadow: none;
    transition: box-shadow .3s ease, border-color .3s ease;
  }
  .site-nav.scrolled { box-shadow: 0 4px 24px rgba(0,0,0,.12); border-bottom-color: var(--border); }

  .nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    height: 72px;
  }
  .nav-logo img { height: 52px; width: auto; display: block; }

  .nav-links {
    display: flex; align-items: center; gap: 4px;
    list-style: none; margin: 0; padding: 0;
  }

  .nav-link {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 14px; font-weight: 600; color: var(--gray);
    padding: 8px 12px; border-radius: 8px;
    text-decoration: none; transition: color .2s, background .2s;
    white-space: nowrap;
  }
  .nav-link:hover { color: var(--blue); background: var(--blue-light); }
  .nav-link.nav-active { color: var(--blue); }
  .nav-link .chevron { transition: transform .2s; }

  .nav-cta { display: flex; align-items: center; gap: 10px; }

  .lang-toggle {
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 800; letter-spacing: .06em;
    color: var(--blue); background: var(--blue-light);
    border: 1.5px solid var(--blue); border-radius: 6px;
    padding: 5px 10px; text-decoration: none;
    transition: background .15s, color .15s;
  }
  .lang-toggle:hover { background: var(--blue); color: var(--white); }

  .nav-cta .btn-blue {
    font-size: 14px;
    font-weight: 700;
    padding: 9px 22px;
    border-radius: 8px;
    line-height: 1;
    box-shadow: none;
  }

/* ── DROPDOWN ──────────────────────────────────── */
  .has-dropdown { position: relative; }

  .dropdown {
    position: absolute; top: calc(100% + 6px); left: 0;
    min-width: 230px;
    background: var(--white); border-radius: 14px;
    border: 1px solid var(--border);
    box-shadow: 0 12px 40px rgba(0,0,0,.12);
    padding: 6px;
    list-style: none; margin: 0;
    opacity: 0; pointer-events: none;
    transform: translateY(10px);
    transition: opacity .18s ease, transform .18s ease;
    z-index: 200;
  }
  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .has-dropdown:hover .nav-link .chevron,
  .has-dropdown:focus-within .nav-link .chevron { transform: rotate(180deg); }

  .dropdown-all {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; font-weight: 700; color: var(--blue);
    padding: 10px 12px; border-radius: 8px;
    text-decoration: none; border-bottom: 1px solid var(--border);
    margin-bottom: 4px; transition: background .15s;
  }
  .dropdown-all:hover { background: var(--blue-light); }

  .dropdown-item {
    display: block; font-size: 14px; font-weight: 500; color: var(--dark);
    padding: 9px 12px; border-radius: 8px;
    text-decoration: none; transition: background .15s, color .15s;
  }
  .dropdown-item:hover { background: var(--blue-light); color: var(--blue); }

  /* ── HAMBURGER ─────────────────────────────────── */
  .hamburger {
    display: none; flex-direction: column; gap: 5px;
    cursor: pointer; padding: 4px; background: none; border: none;
  }
  .hamburger span {
    display: block; width: 24px; height: 2px;
    background: var(--dark); border-radius: 2px; transition: all .25s;
  }

  /* ── MOBILE MENU ───────────────────────────────── */
  .mobile-menu {
    display: flex; position: fixed; inset: 72px 0 0;
    background: var(--white); z-index: 99;
    flex-direction: column; padding: 24px 20px;
    gap: 4px; border-top: 1px solid var(--border);
    overflow-y: auto;
    visibility: hidden; opacity: 0; pointer-events: none;
    transform: translateY(-10px);
    transition: opacity .22s ease, transform .22s ease, visibility 0s linear .22s;
  }
  .mobile-menu.open {
    visibility: visible; opacity: 1; pointer-events: auto;
    transform: translateY(0);
    transition: opacity .22s ease, transform .22s ease, visibility 0s;
  }

  .mobile-link {
    display: block; font-size: 16px; font-weight: 600; color: var(--dark);
    padding: 12px 12px; border-radius: 8px; text-decoration: none;
    transition: background .15s, color .15s;
  }
  .mobile-link:hover { background: var(--blue-light); color: var(--blue); }
  .mobile-link-sub { font-size: 14px; font-weight: 500; color: var(--gray); padding-left: 24px; }
  .mobile-link-sub:hover { color: var(--blue); }

  .mobile-services-toggle {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; font-size: 16px; font-weight: 600; color: var(--dark);
    padding: 12px 12px; border-radius: 8px; border: none; background: none;
    cursor: pointer; font-family: var(--font); transition: background .15s;
  }
  .mobile-services-toggle:hover { background: var(--blue-light); color: var(--blue); }
  .mobile-services-toggle .chevron { transition: transform .22s; }
  .mobile-services-toggle[aria-expanded="true"] .chevron { transform: rotate(180deg); }

  .mobile-services-list {
    display: none; flex-direction: column; gap: 2px;
    padding: 4px 0;
  }
  .mobile-services-list.open { display: flex; }

  @media (max-width: 1024px) {
    .nav-link { padding: 8px 9px; font-size: 13px; }
  }

  @media (max-width: 860px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
    .nav-cta .btn-blue { display: none; }
  }
</style>

<script>
  // Sticky shadow
  const nav = document.querySelector('.site-nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  // Hamburger
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    hamburger.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
    const spans = hamburger.querySelectorAll('span');
    if (isOpen) {
      (spans[0] as HTMLElement).style.transform = 'rotate(45deg) translate(5px, 5px)';
      (spans[1] as HTMLElement).style.opacity = '0';
      (spans[2] as HTMLElement).style.transform = 'rotate(-45deg) translate(5px, -5px)';
      document.body.style.overflow = 'hidden';
      setTimeout(() => (mobileMenu?.querySelector('a, button') as HTMLElement)?.focus(), 80); // a11y: focus into menu
    } else {
      spans.forEach((s: Element) => { (s as HTMLElement).style.transform = ''; (s as HTMLElement).style.opacity = ''; });
      document.body.style.overflow = '';
      hamburger.focus(); // a11y: restore focus to trigger
    }
  });

  // a11y: trap Tab within the open mobile menu (WCAG 2.4.3 / 2.1.2)
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || !mobileMenu?.classList.contains('open')) return;
    const nodes = [...mobileMenu.querySelectorAll<HTMLElement>('a, button')].filter((el) => el.offsetParent !== null);
    if (!nodes.length) return;
    const first = nodes[0], last = nodes[nodes.length - 1];
    if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
    else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
  }, true);

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
      hamburger?.querySelectorAll('span').forEach((s: Element) => { (s as HTMLElement).style.transform = ''; (s as HTMLElement).style.opacity = ''; });
    });
  });

  // Escape key closes mobile menu
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && mobileMenu?.classList.contains('open')) {
      mobileMenu.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
      hamburger?.querySelectorAll('span').forEach((s: Element) => { (s as HTMLElement).style.transform = ''; (s as HTMLElement).style.opacity = ''; });
      document.body.style.overflow = '';
      (hamburger as HTMLElement)?.focus(); // a11y: restore focus on Escape
    }
  });

  // Mobile services accordion
  const servicesToggle = document.getElementById('mobileServicesToggle');
  const servicesList = document.getElementById('mobileServicesList');
  servicesToggle?.addEventListener('click', () => {
    const isOpen = servicesList?.classList.toggle('open');
    servicesToggle.setAttribute('aria-expanded', String(isOpen));
  });

  // Mobile consulting accordion
  const consultingToggle = document.getElementById('mobileConsultingToggle');
  const consultingList = document.getElementById('mobileConsultingList');
  consultingToggle?.addEventListener('click', () => {
    const isOpen = consultingList?.classList.toggle('open');
    consultingToggle.setAttribute('aria-expanded', String(isOpen));
  });
</script>
